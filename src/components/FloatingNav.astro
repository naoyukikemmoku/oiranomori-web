---
// 末尾スラッシュを正規化（"/" は "/" のまま、それ以外は末尾 "/" を落とす）
const normalize = (p: string) => {
  if (p === "/") return "/";
  return p.replace(/\/+$/, "");
};

const current = normalize(Astro.url.pathname);

const tabs = [
  { label: "ライト", href: "/" },
  { label: "L利用案内", href: "/light-guide/" },
  { label: "ディープ", href: "/deep/" },
  { label: "D利用案内", href: "/deep-guide/" },
  { label: "天気", href: "/now/" },
];
---

<aside class="fixed right-0 top-1/2 -translate-y-1/2 z-50">
  <div class="flex flex-col items-end gap-2">
    {tabs.map((tab) => {
      const isActive = current === normalize(tab.href);
      return (
        <a
          href={tab.href}
          class:list={[
            "floating-tab backdrop-blur transition hover:shadow-xl",
            isActive && "floating-tab--active",
          ]}
          aria-label={tab.label}
          aria-current={isActive ? "page" : undefined}
        >
          <span class="floating-tab__text">{tab.label}</span>
        </a>
      );
    })}
  </div>
</aside>
