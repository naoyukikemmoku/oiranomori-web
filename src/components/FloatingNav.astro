---
const pathname = Astro.url.pathname;
const isDeep = pathname.startsWith("/deep");
const guideHref = isDeep ? "/deep-guide/" : "/light-guide/";
const guideLabel = "利用案内";
---

<aside class="fixed right-0 top-1/2 -translate-y-1/2 z-50">
  <div class="flex flex-col items-end gap-2">
    <a
      href={guideHref}
      class="
        floating-tab
        bg-white/95 backdrop-blur
        border border-base-300
        shadow-lg
        hover:shadow-xl
        transition
      "
      aria-label={guideLabel}
    >
      <span class="floating-tab__text">{guideLabel}</span>
    </a>
  </div>
</aside>
