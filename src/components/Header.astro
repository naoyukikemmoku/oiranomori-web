---
import { topSwitch } from "../config/nav";
import HamburgerMenu from "./HamburgerMenu.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<header id="site-header" class="site-header">

  {/* Row 1: ロゴ ／ [PCのみ切り替えタブ] ／ 天気 ＋ ハンバーガー */}
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-2 md:py-3">
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="おいらの森トップへ">
      <img src="/images/logo/logo-w512.png" alt="おいらの森ロゴ" class="h-8 md:h-10 w-auto" />
      <span class="sr-only">おいらの森</span>
    </a>

    {/* PC のみ: Row 1 中央に切り替えタブ */}
    <nav class="header-switch hidden md:grid" aria-label="森の切り替え">
      {topSwitch.map((item) => (
        <a
          href={item.href}
          class={`header-switch__item ${item.href === "/" ? "is-light" : "is-deep"} ${isActive(item.href) ? "is-active" : ""}`}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a href="/now/" class="header-weather inline-flex" aria-label="現在の天気">
        <span id="header-weather-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M4.93 19.07l1.41-1.41"></path>
            <path d="M17.66 6.34l1.41-1.41"></path>
          </svg>
        </span>
        <span class="tabular-nums" id="header-temp">--℃</span>
      </a>
      <HamburgerMenu />
    </div>
  </div>

  {/* Row 2: スマホのみ・切り替えタブ（横幅100% × 2等分、高コントラスト） */}
  <nav class="md:hidden grid grid-cols-2 border-t border-zinc-200/70" aria-label="森の切り替え">
    {topSwitch.map((item) => (
      <a
        href={item.href}
        class={`header-switch-mobile__item ${item.href === "/" ? "is-light" : "is-deep"} ${isActive(item.href) ? "is-active" : ""}`}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>

</header>

<script>
  // ── スクロールで隠す ──────────────────────────────────────
  const header = document.getElementById("site-header");
  let prevY = window.scrollY;

  const onScroll = () => {
    if (!header) return;
    const currY = window.scrollY;
    if (currY > 160 && currY > prevY) {
      header.classList.add("is-hidden");
    } else {
      header.classList.remove("is-hidden");
    }
    prevY = currY;
  };

  window.addEventListener("scroll", onScroll, { passive: true });

  // ── 天気・気温の取得と表示 ─────────────────────────────
  const CACHE_KEY = "header-weather-cache";
  const CACHE_TTL_MS = 6 * 60 * 60 * 1000; // 6時間

  interface WeatherCache {
    temp_c: number;
    observed_at: string;
    fetched_at: string;
    weather_code: number;
  }

  function loadCache(): WeatherCache | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const cache: WeatherCache = JSON.parse(raw);
      const age = Date.now() - new Date(cache.fetched_at).getTime();
      return age < CACHE_TTL_MS ? cache : null;
    } catch {
      return null;
    }
  }

  function saveCache(data: WeatherCache) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify(data));
    } catch {
      // プライベートブラウジング等で書けない場合は無視
    }
  }

  function weatherCodeToSvg(code: number): string {
    if (code === 0) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path><path d="M12 20v2"></path>
        <path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path>
        <path d="M2 12h2"></path><path d="M20 12h2"></path>
        <path d="M4.93 19.07l1.41-1.41"></path><path d="M17.66 6.34l1.41-1.41"></path>
      </svg>`;
    } else if (code <= 3) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2v1"></path><path d="M4.22 4.22l.7.7"></path><path d="M2 12h1"></path>
        <circle cx="12" cy="8" r="3" fill="none"></circle>
        <path d="M18.5 13a3.5 3.5 0 0 0-7 0H7a3 3 0 0 0 0 6h12a2.5 2.5 0 0 0 0-5h-.5z"></path>
      </svg>`;
    } else if (code === 45 || code === 48) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 10h18"></path><path d="M3 14h18"></path><path d="M3 18h18"></path>
        <path d="M5 6h14a2 2 0 0 0-14 0z"></path>
      </svg>`;
    } else if ([51,53,55,61,63,65,80,81,82].includes(code)) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 17.58A5 5 0 0 0 18 8h-1.26A8 8 0 1 0 4 16.25"></path>
        <line x1="8" y1="19" x2="8" y2="21"></line>
        <line x1="12" y1="17" x2="12" y2="21"></line>
        <line x1="16" y1="19" x2="16" y2="21"></line>
      </svg>`;
    } else if ([71,73,75,77,85,86].includes(code)) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 17.58A5 5 0 0 0 18 8h-1.26A8 8 0 1 0 4 16.25"></path>
        <line x1="8" y1="20" x2="8" y2="24"></line>
        <line x1="12" y1="18" x2="12" y2="22"></line>
        <line x1="16" y1="20" x2="16" y2="24"></line>
      </svg>`;
    } else if ([95,96,99].includes(code)) {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 16.9A5 5 0 0 0 18 7h-1.26a8 8 0 1 0-11.62 9"></path>
        <polyline points="13 11 9 17 15 17 11 23"></polyline>
      </svg>`;
    } else {
      return `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18.5 13a3.5 3.5 0 0 0-7 0H7a3 3 0 0 0 0 6h12a2.5 2.5 0 0 0 0-5h-.5z"></path>
      </svg>`;
    }
  }

  async function initWeather() {
    const weatherEl = document.querySelector<HTMLElement>(".header-weather");
    const tempEl = document.getElementById("header-temp");
    const iconEl = document.getElementById("header-weather-icon");
    if (!weatherEl || !tempEl || !iconEl) return;

    // 初期値として `--℃` を非表示にしておく（DOM は維持）
    weatherEl.style.display = "none";

    const [switchbotResult, openMeteoResult] = await Promise.allSettled([
      fetch("https://oiranomori.com/app/weather/api/public/current.php")
        .then(r => r.json())
        .then(d => {
          if (!d.ok) throw new Error("ok:false");
          return d;
        }),
      fetch(
        "https://api.open-meteo.com/v1/forecast?latitude=36.641001&longitude=140.067100&current=temperature_2m,weather_code&timezone=Asia%2FTokyo"
      ).then(r => r.json()),
    ]);

    const cache = loadCache();

    // --- 温度値の決定 ---
    let tempC: number | null = null;
    let observedAt = "";
    if (switchbotResult.status === "fulfilled") {
      const uketsuke = switchbotResult.value?.stations?.uketsuke;
      if (uketsuke?.temp_c !== undefined) {
        tempC = uketsuke.temp_c;
        observedAt = uketsuke.observed_at ?? "";
      }
    }
    if (tempC === null && cache) {
      tempC = cache.temp_c;
      observedAt = cache.observed_at;
    }

    // --- アイコン用 weather_code の決定 ---
    let weatherCode: number | null = null;
    if (openMeteoResult.status === "fulfilled") {
      const code = openMeteoResult.value?.current?.weather_code;
      if (code !== undefined) weatherCode = code;
    }
    if (weatherCode === null && cache) {
      weatherCode = cache.weather_code;
    }

    // --- 表示判定 ---
    if (tempC === null) {
      // 温度が出せない → 要素ごと非表示のまま
      return;
    }

    // 温度を表示
    weatherEl.style.display = "";
    tempEl.textContent = `${tempC.toFixed(1)}℃`;

    // アイコンを表示（出せる場合のみ）
    if (weatherCode !== null) {
      iconEl.innerHTML = weatherCodeToSvg(weatherCode);
    } else {
      iconEl.innerHTML = "";
    }

    // localStorage に成功値を保存（温度APIが成功したタイミングで更新）
    if (switchbotResult.status === "fulfilled") {
      saveCache({
        temp_c: tempC,
        observed_at: observedAt,
        fetched_at: new Date().toISOString(),
        weather_code: weatherCode ?? (cache?.weather_code ?? 0),
      });
    }
  }

  initWeather();
</script>
