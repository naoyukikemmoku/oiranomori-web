---
import { topSwitch } from "../config/nav";
import HamburgerMenu from "./HamburgerMenu.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<header id="site-header" class="site-header">

  {/* Row 1: ロゴ ／ [PCのみ切り替えタブ] ／ 天気 ＋ ハンバーガー */}
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-2 md:py-3">
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="おいらの森トップへ">
      <img src="/images/logo/logo-w512.png" alt="おいらの森ロゴ" class="h-8 md:h-10 w-auto" />
      <span class="sr-only">おいらの森</span>
    </a>

    {/* PC のみ: Row 1 中央に切り替えタブ */}
    <nav class="header-switch hidden md:grid" aria-label="森の切り替え">
      {topSwitch.map((item) => (
        <a
          href={item.href}
          class={`header-switch__item ${item.href === "/" ? "is-light" : "is-deep"} ${isActive(item.href) ? "is-active" : ""}`}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a href="/now/" class="header-weather inline-flex" aria-label="現在の天気">
        <span id="header-weather-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M4.93 19.07l1.41-1.41"></path>
            <path d="M17.66 6.34l1.41-1.41"></path>
          </svg>
        </span>
        <span class="tabular-nums" id="header-temp">--℃</span>
      </a>
      <HamburgerMenu />
    </div>
  </div>

  {/* Row 2: スマホのみ・切り替えタブ（横幅100% × 2等分、高コントラスト） */}
  <nav class="md:hidden grid grid-cols-2 border-t border-zinc-200/70" aria-label="森の切り替え">
    {topSwitch.map((item) => (
      <a
        href={item.href}
        class={`header-switch-mobile__item ${item.href === "/" ? "is-light" : "is-deep"} ${isActive(item.href) ? "is-active" : ""}`}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>

</header>

<script>
  // ── スクロールで隠す ──────────────────────────────────────
  const header = document.getElementById("site-header");
  let prevY = window.scrollY;

  const onScroll = () => {
    if (!header) return;
    const currY = window.scrollY;
    if (currY > 160 && currY > prevY) {
      header.classList.add("is-hidden");
    } else {
      header.classList.remove("is-hidden");
    }
    prevY = currY;
  };

  window.addEventListener("scroll", onScroll, { passive: true });

  // ── 天気・気温の取得と表示 ─────────────────────────────
  // データソース: OirasApp current.php（stations.uketsuke の temp_c / weather）
  // フェッチ頻度はブラウザHTTPキャッシュ（current.php の max-age=60）に委ねる。
  // localStorage はフォールバック専用（取得失敗時のみ参照、鮮度閾値6時間）。
  const CACHE_KEY = "header-weather-cache";
  const CACHE_TTL_MS = 6 * 60 * 60 * 1000; // 6時間

  interface WeatherInfo {
    code: number;
    icon: string;
    text: string;
    main: string;
  }

  interface WeatherCache {
    temp_c: number;
    observed_at: string;
    fetched_at: string;
    weather: WeatherInfo | null;
  }

  function loadCache(): WeatherCache | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const cache: WeatherCache = JSON.parse(raw);
      const age = Date.now() - new Date(cache.fetched_at).getTime();
      return age < CACHE_TTL_MS ? cache : null;
    } catch {
      return null;
    }
  }

  function saveCache(data: WeatherCache) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify(data));
    } catch {
      // プライベートブラウジング等で書けない場合は無視
    }
  }

  // OpenWeather のアイコンコード（例 "04d"）を公式アイコン画像で描画
  function weatherIconImg(icon: string, alt: string): string {
    return `<img src="https://openweathermap.org/img/wn/${icon}@2x.png" width="18" height="18" alt="${alt}" loading="lazy" decoding="async" />`;
  }

  async function initWeather() {
    const weatherEl = document.querySelector<HTMLElement>(".header-weather");
    const tempEl = document.getElementById("header-temp");
    const iconEl = document.getElementById("header-weather-icon");
    if (!weatherEl || !tempEl || !iconEl) return;

    // 初期値として `--℃` を非表示にしておく（DOM は維持）
    weatherEl.style.display = "none";

    // フェッチ対象は current.php のみ。並列対象が増えた場合に備え allSettled を維持。
    const [currentResult] = await Promise.allSettled([
      fetch("https://oiranomori.com/app/weather/api/public/current.php")
        .then(r => r.json())
        .then(d => {
          if (!d.ok) throw new Error("ok:false");
          return d;
        }),
    ]);

    const cache = loadCache();

    // --- 温度・天気の決定 ---
    let tempC: number | null = null;
    let observedAt = "";
    let weather: WeatherInfo | null = null;
    let fromApi = false;

    if (currentResult.status === "fulfilled") {
      const uketsuke = currentResult.value?.stations?.uketsuke;
      if (uketsuke?.temp_c !== undefined && uketsuke?.temp_c !== null) {
        tempC = uketsuke.temp_c;
        observedAt = uketsuke.observed_at ?? "";
        fromApi = true;
        const w = uketsuke.weather;
        if (w && typeof w.icon === "string") {
          weather = { code: w.code, icon: w.icon, text: w.text ?? "", main: w.main ?? "" };
        }
      }
    }

    // 取得失敗 → 6時間以内の localStorage フォールバック
    if (tempC === null && cache) {
      tempC = cache.temp_c;
      observedAt = cache.observed_at;
      weather = cache.weather;
    }

    // --- 表示判定 ---
    // 温度が出せない（API失敗かつキャッシュも6時間超）→ 要素ごと非表示のまま
    if (tempC === null) {
      return;
    }

    // 温度を表示
    weatherEl.style.display = "";
    tempEl.textContent = `${tempC.toFixed(1)}℃`;

    // アイコンを表示（出せる場合のみ）
    if (weather && weather.icon) {
      iconEl.innerHTML = weatherIconImg(weather.icon, weather.text || "");
    } else {
      iconEl.innerHTML = "";
    }

    // localStorage に成功値を保存（APIが成功したタイミングで更新）
    if (fromApi) {
      saveCache({
        temp_c: tempC,
        observed_at: observedAt,
        fetched_at: new Date().toISOString(),
        weather,
      });
    }
  }

  initWeather();
</script>
