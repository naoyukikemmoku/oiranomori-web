---
// ディープフォレスト向け 静けさタイムライン（deep/index.astro 最終CTA直前に埋め込み）。
// 月ごとに横帯1本。帯＝その月の日数分のセグメントを連続配置（日連続。カレンダーではない）。
// 帯の下に「人の気配がある日」を要約テキストで列挙。終日静かな月は一文で出す。
// 混雑度ではなく「静けさの推移」を色の濃淡で見せる。
// 動的データのためクライアント（可視時）取得。サーバー側では骨組みのみ描画。
import { RESERVE_FALLBACK_URL } from "../lib/availability";
---

<section
  class="bg-[color:var(--forest-700)] py-20 md:py-28"
  aria-labelledby="silence-calendar-heading"
>
  <div class="mx-auto max-w-3xl px-6 md:px-10">
    <p class="text-xs tracking-[0.32em] text-zinc-600 uppercase">Silence</p>
    <h2
      id="silence-calendar-heading"
      class="mt-5 text-2xl font-semibold leading-snug text-white md:text-3xl"
    >
      静けさの、移ろい。
    </h2>
    <p class="mt-5 text-sm leading-loose text-zinc-400">
      帯が明るむ日に、人の気配がある。<br />
      誰にも会いたくない日を、ここから選んでほしい。
    </p>

    <div class="mt-10 text-sm leading-loose text-zinc-500" data-silence-state="loading">
      静けさを読み込んでいます…
    </div>

    <div class="mt-10 hidden text-sm leading-loose text-zinc-400" data-silence-state="error">
      <p>空き状況は予約サイトでご確認ください。</p>
      <p class="mt-4">
        <a
          href={RESERVE_FALLBACK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition hover:text-white"
        >
          予約・空き状況を見る ↗
        </a>
      </p>
    </div>

    <div class="mt-10 hidden" data-silence-state="ready">
      <div class="space-y-8" data-silence-months style="font-family:'Noto Serif JP',serif"></div>

      <ul class="mt-12 flex flex-wrap gap-x-6 gap-y-2 text-xs text-zinc-500" aria-hidden="true">
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm" style="background:#33433a"></span>誰もいない</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm" style="background:#4f6149"></span>ほぼ人に会わない</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm" style="background:#7a8a64"></span>人の存在を感じる</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm" style="background:#b3c08e"></span>満</li>
      </ul>
    </div>
  </div>
</section>

<script>
  import {
    buildCongestionUrl,
    type AvailabilityResponse,
  } from "../lib/availability";

  const section = document.querySelector<HTMLElement>(
    "[aria-labelledby='silence-calendar-heading']",
  );
  if (section) {
    // 静けさの濃淡。背景 --forest-700 (#1f2820) から識別できるよう「誰もいない」を一段明るく。
    // 濃い（暗い）ほど人がいない＝静か。満を最も明るく目立たせる。
    const STYLE: Record<string, { bg: string }> = {
      誰もいない: { bg: "#33433a" },
      ほぼ人に会わない: { bg: "#4f6149" },
      人の存在を感じる: { bg: "#7a8a64" },
      満: { bg: "#b3c08e" },
    };
    // フォールバック色（未知 label）。
    const FALLBACK_BG = "#2d3a30";

    // ── 状態の中間データ構造（拡張用）──────────────────────────
    // 日付ごとに「混雑label」と、将来重ねる別軸フラグ（山作業日など）を分離して持つ。
    // 山作業日は混雑色を上書きせず別マーカーで重ねる想定。今回は混雑label のみ描画。
    type DayState = {
      iso: string;
      label: string;
      // workday?: boolean;  // 将来: 山作業日フラグ（データソース未確定のため未取得）
    };

    // 状態 → セグメント装飾のマッピング（混雑色のみ。将来マーカーをここに追加）。
    const styleFor = (st: DayState): { bg: string } => {
      return STYLE[st.label] ?? { bg: FALLBACK_BG };
    };

    const show = (state: "loading" | "error" | "ready") => {
      section.querySelectorAll<HTMLElement>("[data-silence-state]").forEach((el) => {
        el.classList.toggle("hidden", el.dataset.silenceState !== state);
      });
    };

    // 「人の気配がある日」= 誰もいない 以外。連続日をまとめて要約文を作る。
    const summarize = (states: DayState[]): string => {
      const flagged = states.filter((s) => s.label !== "誰もいない");
      if (flagged.length === 0) return "ひと月まるごと、誰もいない。";

      // 同一 label が連続する日をランにまとめる。
      type Run = { label: string; start: number; end: number };
      const runs: Run[] = [];
      for (const s of flagged) {
        const day = Number(s.iso.slice(8, 10));
        const last = runs[runs.length - 1];
        if (last && last.label === s.label && day === last.end + 1) {
          last.end = day;
        } else {
          runs.push({ label: s.label, start: day, end: day });
        }
      }
      const parts = runs.map((r) => {
        const span = r.start === r.end ? `${r.start}日` : `${r.start}–${r.end}日`;
        return `${span} ${r.label}`;
      });
      return parts.join(" ／ ");
    };

    const render = (data: AvailabilityResponse) => {
      const days = data.areas.deep?.days ?? [];
      const wrap = section.querySelector("[data-silence-months]");
      if (!wrap || days.length === 0) {
        show("error");
        return;
      }

      // 月ごとにグルーピング（YYYY-MM）。
      const groups = new Map<string, DayState[]>();
      for (const d of days) {
        const ym = d.date.slice(0, 7);
        if (!groups.has(ym)) groups.set(ym, []);
        groups.get(ym)?.push({ iso: d.date, label: d.label });
      }

      const blocks: string[] = [];
      for (const [ym, list] of groups) {
        const m = Number(ym.slice(5, 7));
        // 日付昇順を保証。
        list.sort((a, b) => (a.iso < b.iso ? -1 : 1));

        // 横帯：各日を1セグメントとして連続配置。flex で日数に応じ等幅。
        const segs = list
          .map((st) => {
            const day = Number(st.iso.slice(8, 10));
            const { bg } = styleFor(st);
            const title = `${m}月${day}日：${st.label}`;
            return `<div class="h-7 flex-1 first:rounded-l-md last:rounded-r-md" style="background:${bg}" title="${title}"><span class="sr-only">${title}</span></div>`;
          })
          .join("");

        const summary = summarize(list);

        blocks.push(
          `<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">` +
            `<p class="w-16 shrink-0 text-base text-zinc-300">${m}月</p>` +
            `<div class="flex-1"><div class="flex gap-px">${segs}</div>` +
            `<p class="mt-2 text-xs leading-relaxed text-zinc-500">${summary}</p></div>` +
          `</div>`,
        );
      }

      wrap.innerHTML = blocks.join("");
      show("ready");
    };

    const load = async () => {
      try {
        const res = await fetch(buildCongestionUrl(), {
          headers: { Accept: "application/json" },
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = (await res.json()) as AvailabilityResponse;
        if (!data.ok || !data.areas) throw new Error("invalid payload");
        render(data);
      } catch (e) {
        console.warn("[silence] fetch failed, showing fallback.", e);
        show("error");
      }
    };

    let done = false;
    const trigger = () => {
      if (done) return;
      done = true;
      load();
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const en of entries) {
            if (en.isIntersecting) {
              trigger();
              io.disconnect();
              break;
            }
          }
        },
        { rootMargin: "200px" },
      );
      io.observe(section);
    } else {
      trigger();
    }
  }
</script>
