---
// ディープフォレスト向け 静けさの推移カレンダー（deep/index.astro 最終CTA直前に埋め込み）。
// deep の days を月カレンダー的に。混雑度ではなく「静けさの推移」を色の濃淡で見せる。
// 動的データのためクライアント（可視時）取得。サーバー側では骨組みのみ描画。
import { RESERVE_FALLBACK_URL } from "../lib/availability";
---

<section
  class="bg-[color:var(--forest-700)] py-20 md:py-28"
  aria-labelledby="silence-calendar-heading"
>
  <div class="mx-auto max-w-3xl px-6 md:px-10">
    <p class="text-xs tracking-[0.32em] text-zinc-600 uppercase">Silence</p>
    <h2
      id="silence-calendar-heading"
      class="mt-5 text-2xl font-semibold leading-snug text-white md:text-3xl"
    >
      静けさの、移ろい。
    </h2>
    <p class="mt-5 text-sm leading-loose text-zinc-400">
      色が濃いほど、深い森に人の気配はない。<br />
      誰にも会いたくない日を、ここから選んでほしい。
    </p>

    <div class="mt-10 text-sm leading-loose text-zinc-500" data-silence-state="loading">
      静けさを読み込んでいます…
    </div>

    <div class="mt-10 hidden text-sm leading-loose text-zinc-400" data-silence-state="error">
      <p>空き状況は予約サイトでご確認ください。</p>
      <p class="mt-4">
        <a
          href={RESERVE_FALLBACK_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="underline underline-offset-2 transition hover:text-white"
        >
          予約・空き状況を見る ↗
        </a>
      </p>
    </div>

    <div class="mt-10 hidden" data-silence-state="ready">
      <div class="space-y-12" data-silence-months style="font-family:'Noto Serif JP',serif"></div>

      <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-xs text-zinc-500" aria-hidden="true">
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full" style="background:#1c2a20"></span>誰もいない</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full" style="background:#3a4a38"></span>ほぼ人に会わない</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full" style="background:#6b7a5a"></span>人の存在を感じる</li>
        <li class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-full" style="background:#9aa884"></span>満</li>
      </ul>
    </div>
  </div>
</section>

<script>
  import {
    buildCongestionUrl,
    type AvailabilityResponse,
  } from "../lib/availability";

  const section = document.querySelector<HTMLElement>(
    "[aria-labelledby='silence-calendar-heading']",
  );
  if (section) {
    // 静けさの濃淡。濃い（誰もいない）ほど暗緑。
    const STYLE: Record<string, { bg: string; fg: string }> = {
      誰もいない: { bg: "#1c2a20", fg: "#aebda3" },
      ほぼ人に会わない: { bg: "#3a4a38", fg: "#cdd8c4" },
      人の存在を感じる: { bg: "#6b7a5a", fg: "#1a2016" },
      満: { bg: "#9aa884", fg: "#1a2016" },
    };
    const WD = ["日", "月", "火", "水", "木", "金", "土"];

    const show = (state: "loading" | "error" | "ready") => {
      section.querySelectorAll<HTMLElement>("[data-silence-state]").forEach((el) => {
        el.classList.toggle("hidden", el.dataset.silenceState !== state);
      });
    };

    const render = (data: AvailabilityResponse) => {
      const days = data.areas.deep?.days ?? [];
      const wrap = section.querySelector("[data-silence-months]");
      if (!wrap || days.length === 0) {
        show("error");
        return;
      }

      // 月ごとにグルーピング（YYYY-MM）。
      const groups = new Map<string, typeof days>();
      for (const d of days) {
        const ym = d.date.slice(0, 7);
        if (!groups.has(ym)) groups.set(ym, []);
        groups.get(ym)?.push(d);
      }

      const blocks: string[] = [];
      for (const [ym, list] of groups) {
        const [y, m] = ym.split("-").map(Number);
        const byDate = new Map(list.map((d) => [d.date, d]));
        // 月初の曜日オフセット
        const first = new Date(`${ym}-01T00:00:00+09:00`);
        const offset = first.getDay();
        const daysInMonth = new Date(y, m, 0).getDate();

        const head = WD.map(
          (w) => `<div class="text-center text-[11px] text-zinc-600">${w}</div>`,
        ).join("");

        const cells: string[] = [];
        for (let i = 0; i < offset; i++) cells.push('<div></div>');
        for (let day = 1; day <= daysInMonth; day++) {
          const iso = `${ym}-${String(day).padStart(2, "0")}`;
          const cell = byDate.get(iso);
          if (!cell) {
            cells.push(
              `<div class="flex aspect-square items-center justify-center text-sm text-zinc-700">${day}</div>`,
            );
            continue;
          }
          const s = STYLE[cell.label] ?? { bg: "#2d3a30", fg: "#aebda3" };
          const title = `${m}月${day}日：${cell.label}`;
          cells.push(
            `<div class="flex aspect-square flex-col items-center justify-center rounded-md" style="background:${s.bg};color:${s.fg}" title="${title}"><span aria-hidden="true" class="text-sm leading-none">${day}</span><span class="sr-only">${cell.label}</span></div>`,
          );
        }

        blocks.push(
          `<div><p class="mb-4 text-lg text-zinc-300">${y}年${m}月</p><div class="grid grid-cols-7 gap-1.5 md:gap-2">${head}${cells.join("")}</div></div>`,
        );
      }

      wrap.innerHTML = blocks.join("");
      show("ready");
    };

    const load = async () => {
      try {
        const res = await fetch(buildCongestionUrl(), {
          headers: { Accept: "application/json" },
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = (await res.json()) as AvailabilityResponse;
        if (!data.ok || !data.areas) throw new Error("invalid payload");
        render(data);
      } catch (e) {
        console.warn("[silence] fetch failed, showing fallback.", e);
        show("error");
      }
    };

    let done = false;
    const trigger = () => {
      if (done) return;
      done = true;
      load();
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const en of entries) {
            if (en.isIntersecting) {
              trigger();
              io.disconnect();
              break;
            }
          }
        },
        { rootMargin: "200px" },
      );
      io.observe(section);
    } else {
      trigger();
    }
  }
</script>
