---
import { siteNav } from "../config/nav";

const { lastUpdated } = Astro.props;
// フッターは siteNav の全項目を描画（menu フラグは無視）。
const footerGroups = siteNav;
---

<footer class="lp-footer">
  <div class="mx-auto max-w-6xl px-4 py-14">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-6 border-b border-zinc-800 pb-8">
      <div>
        <img src="/images/logo/logo-w512.png" onerror="this.src='/logo.svg'" alt="おいらの森" class="h-12 w-auto" style="filter: brightness(0) invert(1)" />
        <p class="mt-3 max-w-lg text-sm text-zinc-400">栃木県那須烏山の里山で、100年先の森を育てるキャンプ場</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="https://note.com/oiranomori" target="_blank" rel="noopener noreferrer" class="footer-sns">note</a>
        <a href="https://instagram.com/oiranomori" target="_blank" rel="noopener noreferrer" class="footer-sns">Instagram</a>
        <a href="https://facebook.com/oiranomori" target="_blank" rel="noopener noreferrer" class="footer-sns">Facebook</a>
        <a href="https://x.com/oiranomori" target="_blank" rel="noopener noreferrer" class="footer-sns">X</a>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
      {footerGroups.map((group) => (
        <div>
          <h3 class="mb-3 text-sm font-semibold tracking-[0.16em] text-zinc-400">{group.title}</h3>
          <ul class="space-y-1.5 text-sm leading-snug">
            {group.items.map((item) => (
              <li>
                {item.active !== false ? (
                  <a href={item.href} class="footer-link" target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}>
                    {item.label}
                  </a>
                ) : (
                  <span class="footer-link pointer-events-none opacity-40">{item.label}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-zinc-800 pt-6 text-center text-xs tracking-[0.14em] text-zinc-400">
      {lastUpdated && <p class="mb-1">最終更新：{lastUpdated}</p>}
      <p>© {new Date().getFullYear()} 里山パークおいらの森 / Satoyama Park Oira no Mori. All rights reserved.</p>
    </div>
  </div>
</footer>
