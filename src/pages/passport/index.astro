---
import PageLayout from "../../layouts/PageLayout.astro";

const newPrices = [
  { name: "プレミアム", price: "¥66,000", benefits: "サイト料¥5,500分 ＋ 薪15kg ＋ AC電源 ＋ イベント無料", color: "text-amber-600" },
  { name: "スタンダード", price: "¥44,000", benefits: "サイト料¥4,400分 ＋ 薪10kg", color: "text-zinc-700" },
  { name: "シングル", price: "¥33,000", benefits: "サイト料¥3,300分 ＋ 薪5kg", color: "text-zinc-700" },
  { name: "入場パス", price: "¥11,000", benefits: "入場料のみ（同伴者用・徒歩単独用）", color: "text-zinc-500" },
];

const repeatPrices = [
  {
    period: "3年以上",
    cond: "直前キャンセル2回以下 ＆ 延べ10回以下",
    premium: { cash: "¥52,800", card: "¥54,800" },
    standard: { cash: "¥35,200", card: "¥36,600" },
    single: { cash: "¥26,400", card: "¥27,400" },
    pass: { cash: "¥8,800", card: "¥9,200" },
  },
  {
    period: "2〜3年",
    cond: "直前キャンセル5回以下 ＆ 延べ15回以下",
    premium: { cash: "¥56,100", card: "¥58,100" },
    standard: { cash: "¥37,400", card: "¥38,800" },
    single: { cash: "¥28,100", card: "¥29,100" },
    pass: { cash: "¥9,400", card: "¥9,700" },
  },
  {
    period: "1〜2年",
    cond: "直前キャンセル5回以下 ＆ 延べ15回以下",
    premium: { cash: "¥59,400", card: "¥61,400" },
    standard: { cash: "¥39,600", card: "¥41,000" },
    single: { cash: "¥29,700", card: "¥30,700" },
    pass: { cash: "¥9,900", card: "¥10,300" },
  },
  {
    period: "1年未満",
    cond: "直前キャンセル8回以下 ＆ 延べ20回以下",
    premium: { cash: "¥61,400", card: "¥63,400" },
    standard: { cash: "¥41,000", card: "¥42,300" },
    single: { cash: "¥30,700", card: "¥31,700" },
    pass: { cash: "¥10,300", card: "¥10,600" },
  },
];
---

<PageLayout title="年間パスポート・回数券 | おいらの森">

  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Passport &amp; Coupon</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">年間パスポート・回数券</h1>
    <p class="mt-4 max-w-2xl text-base leading-loose text-zinc-600">
      おいらの森を定額または割引価格で利用できるシステムです。
      年9泊以上ご利用の方は年間パスポートが確実にお得です。
    </p>
    <nav class="mt-6 flex flex-wrap gap-3 text-sm">
      {[
        { href: "#overview",  label: "概要・購入方法" },
        { href: "#pricing",   label: "料金表（新規）" },
        { href: "#repeat",    label: "リピート割引" },
        { href: "#benefits",  label: "年パス特典・条件" },
        { href: "#coupon",    label: "回数券" },
      ].map((item) => (
        <a
          href={item.href}
          class="rounded-full border border-zinc-300 px-4 py-1.5 text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  {/* 概要・購入方法 */}
  <section id="overview" class="mb-14">
    <h2 class="mb-6 text-xl font-semibold text-zinc-800">概要・購入方法</h2>

    <div class="grid gap-5 md:grid-cols-2">
      {[
        {
          title: "販売場所・決済",
          items: [
            "当日受付での対面販売が基本",
            "回数券の一部はオンライン購入→来場時に現地渡しも可",
            "現金払いが最もお得（割引率高）",
            "クレジットカード・QUICPay・交通系IC・QR決済も利用可能",
          ],
        },
        {
          title: "チケット発行・システム",
          items: [
            "パスポートは紙のチケットを発行しない",
            "購入時の「電子領収証」が証明書となる",
            "予約システムにログインすると、自分の会員ランクと割引適用後の料金が自動表示される",
            "購入日が利用開始日。有効期限前の事前更新は不可",
          ],
        },
      ].map((block) => (
        <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-6">
          <h3 class="mb-4 text-sm font-semibold tracking-[0.12em] text-zinc-700">{block.title}</h3>
          <ul class="space-y-2">
            {block.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-zinc-600">
                <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-zinc-400"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* 料金自動計算の説明 */}
    <div class="mt-6 rounded-2xl bg-[color:var(--forest-100)] p-6">
      <h3 class="mb-2 text-sm font-semibold text-[color:var(--forest-700)]">料金の自動計算について</h3>
      <p class="text-sm leading-loose text-[color:var(--forest-700)]/80">
        当方の予約システムにログインすると、会員ランクに応じた<strong>割引後の支払額が自動表示</strong>されます。
        複雑な差額計算をご自身でする必要はありません。
      </p>
      <div class="mt-4 rounded-xl bg-white/60 p-4 text-xs leading-loose text-zinc-600">
        <p class="mb-1 font-medium text-zinc-700">表示例：5/5 オートサイトM 1名1台（通常¥5,500）の場合</p>
        <ul class="space-y-1">
          <li>シングルサイトパス会員 → <strong class="text-zinc-800">¥2,200</strong>（¥3,300引き ＋ 薪5kg）</li>
          <li>年パス会員 → <strong class="text-zinc-800">¥1,100</strong>（¥4,400引き ＋ 薪10kg）</li>
          <li>プレミアム年パス会員 → <strong class="text-zinc-800">¥0</strong>（¥5,500引き ＋ 薪15kg）</li>
        </ul>
      </div>
    </div>
  </section>

  {/* 料金表（新規） */}
  <section id="pricing" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">料金表（新規購入）</h2>
    <p class="mb-8 text-sm text-zinc-500">期間はすべて1年間の一括払いのみ。</p>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {newPrices.map((item) => (
        <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
          <p class={`text-sm font-semibold tracking-[0.1em] ${item.color}`}>{item.name}</p>
          <p class="mt-3 text-3xl font-semibold text-zinc-800">{item.price}</p>
          <p class="mt-1 text-xs text-zinc-400">1年間・一括払い</p>
          <p class="mt-4 text-xs leading-relaxed text-zinc-500">{item.benefits}</p>
        </div>
      ))}
    </div>
  </section>

  {/* リピート割引 */}
  <section id="repeat" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">リピート割引料金</h2>
    <p class="mb-2 text-sm text-zinc-500">
      過去の累積購入期間に応じ、購入時に割引が適用されます。
    </p>
    <p class="mb-8 text-xs text-zinc-400">
      ※直前キャンセル＝予約の3日前から当日・不泊。マナー違反（ゴミ放置・注意への不服従等）がある利用者は、購入歴に関わらず割引適用外。
    </p>

    <div class="overflow-x-auto">
      <table class="w-full min-w-[700px] border-collapse text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left">
            <th class="py-3 pr-4 text-xs font-semibold tracking-[0.12em] text-zinc-500">累積期間</th>
            <th class="py-3 pr-4 text-xs font-semibold tracking-[0.12em] text-zinc-500">プレミアム</th>
            <th class="py-3 pr-4 text-xs font-semibold tracking-[0.12em] text-zinc-500">スタンダード</th>
            <th class="py-3 pr-4 text-xs font-semibold tracking-[0.12em] text-zinc-500">シングル</th>
            <th class="py-3 pr-4 text-xs font-semibold tracking-[0.12em] text-zinc-500">入場パス</th>
            <th class="py-3 text-xs font-semibold tracking-[0.12em] text-zinc-500">適用条件</th>
          </tr>
        </thead>
        <tbody>
          {repeatPrices.map((row) => (
            <tr class="border-b border-zinc-100">
              <td class="py-4 pr-4 font-medium text-zinc-800">{row.period}</td>
              <td class="py-4 pr-4 text-zinc-700">
                <span class="block">現 {row.premium.cash}</span>
                <span class="text-xs text-zinc-400">カード {row.premium.card}</span>
              </td>
              <td class="py-4 pr-4 text-zinc-700">
                <span class="block">現 {row.standard.cash}</span>
                <span class="text-xs text-zinc-400">カード {row.standard.card}</span>
              </td>
              <td class="py-4 pr-4 text-zinc-700">
                <span class="block">現 {row.single.cash}</span>
                <span class="text-xs text-zinc-400">カード {row.single.card}</span>
              </td>
              <td class="py-4 pr-4 text-zinc-700">
                <span class="block">現 {row.pass.cash}</span>
                <span class="text-xs text-zinc-400">カード {row.pass.card}</span>
              </td>
              <td class="py-4 text-xs leading-relaxed text-zinc-500">{row.cond}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {/* 年パス特典・条件 */}
  <section id="benefits" class="mb-14">
    <h2 class="mb-6 text-xl font-semibold text-zinc-800">年間パスポート 共通特典・条件</h2>

    <div class="grid gap-4 md:grid-cols-2">
      {[
        {
          title: "365日利用可能",
          desc: "休業日でもパスポート保持者本人のみ利用可。ただし休業日はネット予約不可のため、電話・DM・メールで事前にご連絡ください。",
          positive: true,
        },
        {
          title: "チェックアウト時間の延長無料",
          desc: "時間を気にせずチェックアウト可能。延長料金は一切かかりません。",
          positive: true,
        },
        {
          title: "ディープフォレスト直接チェックイン",
          desc: "ディープフォレストへの直接チェックインが可能（要事前連絡）。",
          positive: true,
        },
        {
          title: "本人限定・譲渡不可",
          desc: "第三者への譲渡・貸与・払い戻しは一切不可。優先予約権はなし。",
          positive: false,
        },
        {
          title: "発行上限あり",
          desc: "混雑防止のため、ライトフォレスト50名・ディープフォレスト30名を上限とします。",
          positive: false,
        },
        {
          title: "更新は期限切れ後に購入",
          desc: "購入日が利用開始日となるため、有効期限前の事前更新は不可。期限切れ後に改めて購入してください。",
          positive: false,
        },
      ].map((item) => (
        <div class={`rounded-2xl border p-5 ${item.positive ? "border-[color:var(--forest-100)] bg-[color:var(--forest-100)]/40" : "border-zinc-200 bg-zinc-50"}`}>
          <p class={`mb-2 text-sm font-semibold ${item.positive ? "text-[color:var(--forest-700)]" : "text-zinc-700"}`}>
            {item.positive ? "✓ " : ""}{item.title}
          </p>
          <p class="text-sm leading-relaxed text-zinc-600">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* 回数券 */}
  <section id="coupon" class="mb-14">
    <div class="mb-6 flex flex-wrap items-baseline gap-4">
      <h2 class="text-xl font-semibold text-zinc-800">回数券</h2>
      <span class="rounded-full border border-red-200 bg-red-50 px-3 py-0.5 text-xs font-medium text-red-600">
        在庫限りで販売終了
      </span>
    </div>
    <p class="mb-6 text-sm leading-loose text-zinc-600">
      年間パスポートで元が取れない層向けの、有効期限のない割引チケットです。
      現庫がなくなり次第、順次販売終了となります。
    </p>
    <div class="mb-8 rounded-2xl border border-zinc-200 bg-zinc-50 p-5 text-sm leading-loose text-zinc-600">
      <p><strong class="text-zinc-800">購入・受け渡し：</strong>オンラインでの購入が可能。決済後、来場時に受付で実券をお渡しします。</p>
      <p class="mt-2"><strong class="text-zinc-800">利用条件：</strong>有効期限なし、他者利用OK、1度に複数枚消費（グループ利用等）可能。</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {[
        {
          name: "全サイト6回券",
          price: "¥24,000",
          desc: "1名分入場料、普通車1台、サイト料込。\n※LL/XLサイズは差額必要",
        },
        {
          name: "シングルサイト6回券",
          price: "¥16,500",
          desc: "1名分入場料、普通車1台、オートS・ソロ・ディープ込。\n※Mサイズ以上は差額必要",
        },
        {
          name: "入場6回券",
          price: "¥5,500",
          desc: "入場料¥1,100分のみ。\n※ディープ利用時は追加入場料¥1,100必要。車両・サイト料は別途。",
        },
      ].map((item) => (
        <div class="rounded-2xl border border-zinc-200 bg-white p-6">
          <p class="text-sm font-semibold text-zinc-700">{item.name}</p>
          <p class="mt-2 text-2xl font-semibold text-zinc-800">{item.price}</p>
          <p class="mt-1 text-xs text-zinc-400">6回分</p>
          <p class="mt-4 whitespace-pre-line text-xs leading-relaxed text-zinc-500">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* 購入ボタン */}
  <div class="mb-10 rounded-2xl bg-[color:var(--forest-700)] p-8 text-center">
    <p class="text-sm tracking-[0.2em] text-zinc-400 uppercase">Purchase</p>
    <h2 class="mt-3 text-2xl font-semibold text-white">購入・お問い合わせ</h2>
    <p class="mt-3 text-sm leading-loose text-zinc-300">
      年間パスポートは当日受付にて販売しています。<br />
      ご不明な点はお気軽にお問い合わせください。
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-4">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="lp-btn-primary"
      >
        当方の予約システムへ
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center justify-center rounded-full border border-white/30 bg-white/10 px-7 py-3 text-sm text-white transition hover:bg-white/20"
      >
        お問い合わせ
      </a>
    </div>
  </div>

</PageLayout>
