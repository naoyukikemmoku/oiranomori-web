---
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { ForestDaily } from "../../lib/forestDaily";
import {
	formatPostDate,
	getForestDailyList,
	getOgImage,
} from "../../lib/forestDaily";

const LIMIT = 20;
let items: ForestDaily[] = [];
let totalCount = 0;

try {
	const res = await getForestDailyList(LIMIT, 0);
	items = res.contents;
	totalCount = res.totalCount;
} catch (e) {
	console.warn("[forest-daily] microCMS 取得失敗", e);
}

const hasMore = totalCount > LIMIT;

const TYPE_LABEL: Record<string, string> = {
	daily: "日常",
	seasonal: "季節",
	special: "特別",
};

function typeLabel(types: string[]): string {
	if (types.includes("special")) return TYPE_LABEL.special;
	if (types.includes("seasonal")) return TYPE_LABEL.seasonal;
	return TYPE_LABEL.daily;
}

function bodySnippet(body: string, len = 80): string {
	const text = body.replace(/\r?\n/g, " ").trim();
	return text.length > len ? `${text.slice(0, len)}…` : text;
}
---

<BaseLayout
  title="今日のおいらの森 | 里山パークおいらの森"
  description="毎朝、森のいまをお届けします。ライブカメラの朝スチルと気象データから生まれた、おいらの森の日々の記録。"
  ogImage="https://oiranomori.jp/images/lp/hero.jpg"
>
  <Header />

  <main class="min-h-screen bg-[#f4f5f2] pb-32 pt-[var(--header-offset)]">
    <div class="mx-auto max-w-3xl px-5">

      <div class="pt-10 pb-10">
        <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Forest Daily</p>
        <h1 class="mt-3 font-semibold text-zinc-800" style="font-size: clamp(1.4rem, 4vw, 2rem);">
          今日のおいらの森
        </h1>
        <p class="mt-2 text-xs leading-relaxed text-zinc-500">
          毎朝、カメラが捉えた森の表情をお届けしています。
        </p>
      </div>

      {items.length === 0 ? (
        <p class="text-sm text-zinc-500">まだ記事がありません。</p>
      ) : (
        <ul class="divide-y divide-zinc-300 border-t border-zinc-300">
          {items.map((item) => {
            const ogImg = getOgImage(item);
            const label = typeLabel(item.postType ?? []);
            const isSpecial =
              (item.postType ?? []).includes("special") ||
              (item.postType ?? []).includes("seasonal");
            return (
              <li>
                <a
                  href={`/forest-daily/${item.id}/`}
                  class="group flex gap-4 py-6 -mx-2 px-2 transition hover:bg-zinc-100/60"
                >
                  <div
                    class="relative shrink-0 overflow-hidden bg-zinc-200"
                    style="width:88px;height:66px;"
                  >
                    <img
                      src={ogImg}
                      alt=""
                      width="88"
                      height="66"
                      loading="lazy"
                      class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                    />
                    {isSpecial && (
                      <span class="absolute bottom-1 left-1 bg-[color:var(--forest-700)] px-1.5 py-0.5 text-[10px] tracking-[0.1em] text-zinc-200">
                        {label}
                      </span>
                    )}
                  </div>

                  <div class="min-w-0 flex-1">
                    <div class="mb-1.5 flex flex-wrap items-center gap-2">
                      <time
                        class="text-xs tracking-[0.12em] text-zinc-400"
                        datetime={item.postDate}
                      >
                        {formatPostDate(item.postDate)}
                      </time>
                      {item.condition && (
                        <span class="text-xs text-zinc-500">{item.condition}</span>
                      )}
                      {item.tempC !== undefined && item.tempC !== null && (
                        <span class="text-xs text-zinc-400">{item.tempC}℃</span>
                      )}
                    </div>
                    <p class="text-sm font-medium leading-snug text-zinc-800 group-hover:text-[color:var(--forest-600)]">
                      {item.title}
                    </p>
                    <p class="mt-1 text-xs leading-relaxed text-zinc-500 line-clamp-2">
                      {bodySnippet(item.body)}
                    </p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}

      {hasMore && (
        <div class="mt-12 border-t border-zinc-300 pt-8 text-center">
          <p class="text-xs text-zinc-400">全{totalCount}件中 {LIMIT}件を表示しています</p>
          <p class="mt-2 text-xs text-zinc-400">バックナンバーは順次追加予定です。</p>
        </div>
      )}

      <div class="mt-16 border-t border-zinc-200 pt-10 pb-4">
        <p class="mb-1 text-xs tracking-[0.2em] text-zinc-400 uppercase">Reserve</p>
        <p class="text-sm leading-relaxed text-zinc-600">
          気になる日があったら、森に来てみてください。
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-[color:var(--light-accent)] px-6 py-2.5 text-xs font-semibold tracking-[0.12em] text-white transition hover:opacity-90"
          >
            予約する
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="M13 6l6 6-6 6"/>
            </svg>
          </a>
          <a
            href="/light-guide/"
            class="inline-flex items-center gap-2 border border-zinc-400 px-6 py-2.5 text-xs tracking-[0.12em] text-zinc-600 transition hover:border-zinc-700 hover:text-zinc-800"
          >
            利用案内を見る
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
