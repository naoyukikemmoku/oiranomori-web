---
import LpLayout from "../layouts/LpLayout.astro";
import OshiraseList from "../components/OshiraseList.astro";
import SeasonSlider from "../components/SeasonSlider.astro";
import { Image } from "astro:assets";
import { getOshirase } from "../lib/oshirase";

import planStandard from "../assets/images/plan_standard.JPEG";
import planDogrun from "../assets/images/plan_dogrun.JPEG";
import planDaycamp from "../assets/images/plan_daycamp.JPEG";
import planTrain from "../assets/images/plan_train.JPEG";

let contents: any[] = [];

try {
  const response = await getOshirase(3);
  contents = response.contents;
} catch (error) {
  console.warn("Failed to fetch news from microCMS.", error);
}

const plans = [
  {
    name: "スタンダード・\nオートサイト",
    price: "¥3,300/サイト〜",
    ci: "IN 9:00〜17:00",
    co: "OUT 12:00",
    id: 4,
    img: planStandard,
    alt: "那須烏山 里山パークおいらの森 スタンダード・オートサイトのキャンプサイト",
  },
  {
    name: "貸切\nドッグランサイト",
    price: "¥4,400/サイト〜",
    ci: "IN 9:00〜17:00",
    co: "OUT 12:00",
    id: 7,
    img: planDogrun,
    alt: "那須烏山 里山パークおいらの森 貸切ドッグランサイトのキャンプサイト",
  },
  {
    name: "日帰り\nデイキャンプ",
    price: "¥1,100〜",
    ci: "IN 9:00〜13:00",
    co: "OUT 18:00",
    id: 14,
    img: planDaycamp,
    alt: "那須烏山 里山パークおいらの森 日帰りデイキャンプのキャンプサイト",
  },
  {
    name: "電車\nプラン",
    price: "¥2,200/人〜",
    ci: "IN 9:00〜17:00",
    co: "OUT 12:00",
    id: 23,
    img: planTrain,
    alt: "那須烏山 里山パークおいらの森 電車キャンパー歓迎プランのキャンプサイト",
  },
];
---

<LpLayout
  title="栃木県那須烏山市で100年の森を育てるキャンプ場 | 里山パークおいらの森"
  description="栃木県那須烏山の里山にある、100年の森を育てるキャンプ場。明るい広葉樹林のライトフォレストと、樹齢80年の針葉樹林ディープフォレスト。2つのフィールドで森に泊まる体験を。"
  lastUpdated="2026年5月"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Campground"],
    "name": "里山パークおいらの森",
    "alternateName": "フォレストパークおいらの森",
    "url": "https://oiranomori.jp",
    "telephone": "050-3647-1047",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "JP",
      "addressRegion": "栃木県",
      "addressLocality": "那須烏山市",
      "streetAddress": "福岡1047"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 36.639896,
      "longitude": 140.068402
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "09:00",
        "closes": "18:00"
      }
    ],
    "priceRange": "¥¥",
    "image": "https://oiranomori.jp/images/lp/hero.jpg",
    "sameAs": [
      "https://note.com/oiranomori",
      "https://instagram.com/oiranomori",
      "https://facebook.com/oiranomori",
      "https://x.com/oiranomori"
    ]
  })} />

  {/* 1. Hero */}
  <section id="top" class="lp-hero" style="background-image:url('/images/lp/hero.jpg');">
    <div class="lp-hero__overlay"></div>
    <div class="mx-auto max-w-6xl px-5">
      <div class="lp-hero__content">
        <p class="text-xs tracking-[0.32em] text-zinc-400">OI RA NO MORI</p>
        <h1 class="mt-5 font-semibold leading-snug text-white">
          <span class="block text-2xl md:text-3xl">里山パーク</span>
          <span class="block text-5xl md:text-7xl">おいらの森</span>
        </h1>
        <p class="mt-8 max-w-2xl text-sm leading-[2] text-zinc-200 md:text-base">
          里山パークおいらの森は栃木県那須烏山の里山にある静かな森のキャンプ場。<br />
          森で遊び、森に泊まり、森を味わいに。<br />
          適切に伐採を行うことで森を保ちながら、100年先の森を今、育てています。<br />
          明るい広葉樹林のライトフォレスト、深い針葉樹林のディープフォレスト、<br />
          2つのフィールドでお待ちしております。
        </p>
        <p class="mt-10 text-xs tracking-[0.18em]">
          <a href="/residents/" class="text-zinc-400 transition hover:text-zinc-200">
            この森をつくる人 — 森の住人 →
          </a>
        </p>
      </div>
    </div>
    <a href="#season" class="lp-scroll">Scroll</a>
  </section>

  {/* 2. お知らせ */}
  <section id="news" class="py-12 md:py-16 bg-[#f4f5f2]">
    <div class="mx-auto max-w-6xl px-4">
      <OshiraseList items={contents} />
    </div>
  </section>

  {/* 3. 森の四季スライダー */}
  <SeasonSlider />

  {/* 4. 焚火セクション */}
  <section
    id="bonfire"
    class="relative bg-cover bg-center py-24 md:py-32"
    style="background-image:url('/images/bonfire.jpg');"
  >
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-6 md:px-10">
      <div class="max-w-2xl">
        <p class="text-xs tracking-[0.32em] text-zinc-400">CAMPFIRE</p>
        <h2 class="mt-4 text-3xl font-semibold leading-snug text-white md:text-4xl">
          キャンプといえば焚火
        </h2>
        <p class="mt-3 text-sm tracking-[0.16em] text-zinc-300 md:text-base">
          焚き火をするためにキャンプする方も
        </p>
        <a
          href="/firewood/"
          class="mt-8 inline-flex items-center gap-2 rounded border border-white/40 bg-white/10 px-5 py-2.5 text-sm tracking-[0.16em] text-zinc-200 backdrop-blur-sm transition hover:bg-white/20 hover:text-white hover:border-white/60"
        >
          林業家おいらの最高の薪
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* 5. アーリーチェックイン */}
  <section class="py-20 md:py-28 bg-[#eef1ec]">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="grid items-center gap-10 md:grid-cols-2 md:gap-16">
        <div class="overflow-hidden">
          <img
            src="/images/seasons/spring.jpg"
            alt="朝の光が差し込むおいらの森の広葉樹林"
            loading="lazy"
            class="w-full object-cover"
            style="aspect-ratio:4/3;"
          />
        </div>
        <div>
          <p class="text-xs tracking-[0.32em] text-zinc-400">EARLY CHECK-IN</p>
          <h2 class="mt-4 text-2xl font-semibold leading-snug text-zinc-800 md:text-3xl">
            キャンプを存分に楽しんでもらいたい。
          </h2>
          <p class="mt-5 text-sm leading-loose text-zinc-600 md:text-base">
            だからアーリーチェックインは無料にしています。<br />
            朝から来て、翌日12時のチェックアウトまでこの森でゆっくりと時間を過ごしてほしい。<br />
            それがおいらの想いです。
          </p>
          <p class="mt-4 text-xs text-zinc-400">繁忙期は対応できない場合もあります。</p>
        </div>
      </div>
    </div>
  </section>

  {/* 6. ライトフォレスト紹介 ① */}
  <section class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="grid items-center gap-10 md:grid-cols-2 md:gap-16">
        <div class="overflow-hidden">
          <img
            src="/images/IMG_0552.JPEG"
            alt="おいらの森 ライトフォレスト — 里山広葉樹林のキャンプサイト"
            loading="lazy"
            class="w-full object-cover"
            style="aspect-ratio:4/3;"
          />
        </div>
        <div>
          <p class="text-xs tracking-[0.32em] text-zinc-400">LIGHT FOREST</p>
          <h2 class="mt-4 text-2xl font-semibold leading-snug text-zinc-800 md:text-3xl">
            管理人常駐の、<br />安心・安全な森。
          </h2>
          <p class="mt-5 text-sm leading-loose text-zinc-600 md:text-base">
            おいらが家族と隣接地に住んでいる、管理人常駐のキャンプ場です。<br />
            女性一人でも安心してお越しいただけます。
          </p>
          <a
            href="/light-guide/"
            class="mt-8 inline-flex items-center gap-2 text-sm tracking-[0.14em] text-zinc-600 transition hover:text-zinc-900"
          >
            利用案内を見る
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* 6-2. ライトフォレスト紹介 ② */}
  <section class="py-20 md:py-28 bg-[#f4f5f2]">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="grid items-center gap-10 md:grid-cols-2 md:gap-16">
        <div class="order-last md:order-none">
          <p class="text-xs tracking-[0.32em] text-zinc-400">HONEST FOREST</p>
          <h2 class="mt-4 text-2xl font-semibold leading-snug text-zinc-800 md:text-3xl">
            ありのままの自然を、<br />そのままに。
          </h2>
          <p class="mt-5 text-sm leading-loose text-zinc-600 md:text-base">
            地面は土で、夜は暗く、虫も当たり前に暮らしています。<br />
            その分、森本来の心地よさがそのままあります。
          </p>
          <p class="mt-3 text-sm leading-loose text-zinc-600">
            シャワーはありませんが、水洗トイレは備えています。<br />
            虫よけと歩きやすい靴を用意して来てください。
          </p>
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/IMG_1698.JPEG"
            alt="おいらの森 ライトフォレスト — ありのままの里山の自然"
            loading="lazy"
            class="w-full object-cover"
            style="aspect-ratio:4/3;"
          />
        </div>
      </div>
    </div>
  </section>

  {/* 7. プランギャラリー */}
  <section id="plans" class="py-20 md:py-28 bg-[#f4f5f2]">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <p class="text-xs tracking-[0.32em] text-zinc-400">PLAN</p>
      <h2 class="mt-3 text-2xl font-semibold text-zinc-800 md:text-3xl">プランを選ぶ</h2>

      <div class="mt-10 grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
        {plans.map((plan) => (
          <a
            href={`https://www.489pro-x.com/ja/s/oiranomori/search/?plans=${plan.id}&show=plan`}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex flex-col justify-end overflow-hidden bg-zinc-900"
            style="aspect-ratio: 3/4;"
          >
            <Image
              src={plan.img}
              alt={plan.alt}
              width={600}
              height={800}
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/25 to-transparent transition group-hover:from-black/85"></div>
            <div class="relative z-10 p-4">
              <p class="whitespace-pre-line text-sm font-medium leading-snug text-white md:text-base">
                {plan.name}
              </p>
              <p class="mt-1 text-xs tracking-wide text-zinc-300">{plan.price}</p>
              <p class="mt-0.5 text-[10px] text-zinc-400">{plan.ci} / {plan.co}</p>
              <p class="mt-3 inline-flex items-center gap-1 text-[10px] tracking-[0.16em] text-zinc-300 transition group-hover:text-white">
                予約する
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 text-right">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-xs tracking-[0.2em] text-zinc-500 transition hover:text-zinc-800"
        >
          すべてのプランを見る
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</LpLayout>
