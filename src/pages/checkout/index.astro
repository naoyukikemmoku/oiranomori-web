---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";

const lightSites = [
  ...Array.from({ length: 37 }, (_, i) => `オートサイト ${i + 1}番`),
  "オートサイト A",
  "オートサイト B",
  "オートサイト D",
  "オートサイト E",
  "区画12",
  "区画C",
  "ソロ区画",
  "ドッグラン",
];
---

<BaseLayout
  title="チェックアウト連絡 | 里山パークおいらの森"
  noindex={true}
  description="那須烏山・里山パークおいらの森のチェックアウト連絡フォーム。お帰りの際はこちらからご連絡ください。"
>
  <Header />
  <div class="min-h-screen bg-[#f4f5f2] pt-16 pb-24">
    <div class="mx-auto max-w-2xl px-5">

      <div class="pt-12 pb-10">
        <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Checkout</p>
        <h1 class="mt-3 text-2xl font-semibold text-zinc-800 md:text-3xl">チェックアウト連絡</h1>
        <p class="mt-3 text-sm leading-loose text-zinc-500">
          お帰りの際はこちらからご連絡ください。<br />
          お荷物の確認後、スタッフが対応いたします。
        </p>
      </div>

      <form
        action="https://form.oiranomori.com/checkout.php"
        method="POST"
        class="space-y-8"
      >
        {/* ハニーポット */}
        <input type="text" name="website" tabindex="-1" autocomplete="off" style="display:none" />

        {/* お名前 */}
        <div class="space-y-1.5">
          <label for="name" class="block text-sm font-medium text-zinc-700">
            ご予約時のお名前
            <span class="ml-2 text-xs text-zinc-400">必須</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700"
            placeholder="山田 太郎"
          />
        </div>

        {/* ご利用サイト */}
        <div class="space-y-1.5">
          <label for="site" class="block text-sm font-medium text-zinc-700">
            ご利用サイト
            <span class="ml-2 text-xs text-zinc-400">必須</span>
          </label>
          <div class="relative">
            <select
              id="site"
              name="site"
              required
              class="block w-full appearance-none border-b border-zinc-400 bg-transparent py-2.5 pr-8 text-sm text-zinc-800 outline-none transition focus:border-zinc-700"
            >
              <option value="" disabled selected>サイトを選択してください</option>
              <optgroup label="ライトフォレスト">
                {lightSites.map((s) => (
                  <option value={s}>{s}</option>
                ))}
              </optgroup>
              <optgroup label="ディープフォレスト">
                <option value="ディープフォレスト">ディープフォレスト</option>
              </optgroup>
            </select>
            <svg
              class="pointer-events-none absolute right-1 top-1/2 -translate-y-1/2 text-zinc-400"
              width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </div>
        </div>

        {/* メールアドレス */}
        <div class="space-y-1.5">
          <label for="email" class="block text-sm font-medium text-zinc-700">
            メールアドレス
            <span class="ml-2 text-xs text-zinc-400">任意</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700"
            placeholder="example@mail.com"
          />
          <p class="text-xs text-zinc-400">サンキューメールを受け取る場合ご記入ください</p>
        </div>

        {/* ご意見・ご感想 */}
        <div class="space-y-1.5">
          <label for="message" class="block text-sm font-medium text-zinc-700">
            ご意見・ご感想
            <span class="ml-2 text-xs text-zinc-400">任意</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700 resize-none"
            placeholder="ご滞在の感想、ご要望など何でもお聞かせください。"
          ></textarea>
          <p class="text-xs text-zinc-400">今後の整備運営の参考に致します</p>
        </div>

        {/* 送信ボタン */}
        <div class="pt-4">
          <button
            type="submit"
            class="inline-flex items-center gap-2 border border-[color:var(--forest-700)] bg-[color:var(--forest-700)] px-8 py-3 text-sm tracking-[0.1em] text-white transition hover:bg-[color:var(--forest-600)]"
          >
            チェックアウトを連絡する
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" /><path d="M13 6l6 6-6 6" />
            </svg>
          </button>
        </div>

      </form>
    </div>
  </div>
</BaseLayout>
