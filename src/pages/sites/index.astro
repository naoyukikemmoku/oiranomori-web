---
import PageLayout from "../../layouts/PageLayout.astro";

const TITLE = "キャンプサイトを選ぶ｜里山パークおいらの森";
const DESC =
	"人数やスタイルから、あなたに合うキャンプサイトを。ソロからグループ、ドッグランまで。里山パークおいらの森の区画案内。";
const URL = "https://oiranomori.jp/sites/";

const cards = [
	{
		href: "/sites/solo/",
		label: "ソロ",
		copy: "隣を気にしない距離感。ひとりの森時間を。",
	},
	{
		href: "/sites/duo/",
		label: "デュオ・カップル",
		copy: "焚き火を挟んで向き合う、ふたりの夜。",
	},
	{
		href: "/sites/family/",
		label: "ファミリー",
		copy: "子どもが走れる広さと、トイレ至近の安心。",
	},
	{
		href: "/sites/group/",
		label: "グループ・貸切",
		copy: "連結して広く。最大150名の貸切まで。",
	},
	{
		href: "/sites/dogrun/",
		label: "ドッグラン",
		copy: "囲いの中、リードなしで遊べる貸切サイト。",
	},
];
---

<PageLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": TITLE,
      "description": DESC,
      "url": URL,
      "isPartOf": {
        "@type": "WebSite",
        "name": "里山パークおいらの森",
        "url": "https://oiranomori.jp"
      }
    })} />
  </Fragment>

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Sites</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">サイトを選ぶ</h1>
    <p class="mt-4 max-w-2xl text-sm leading-loose text-zinc-500">
      何人で、どう過ごすか。それだけ決まっていれば、サイトは選べます。
      ソロのひとり時間から、家族の週末、大人数の貸切、愛犬と走る一日まで。
      あなたに合う区画を、ここから。
    </p>
  </div>

  {/* 客層カード導線 */}
  <section class="mb-14">
    <div class="grid gap-px overflow-hidden border border-zinc-200 sm:grid-cols-2">
      {cards.map((c) => (
        <a
          href={c.href}
          class="group flex flex-col gap-2 bg-white px-6 py-7 outline outline-1 outline-zinc-100 transition hover:bg-zinc-50"
        >
          <span class="text-lg font-semibold text-zinc-800 group-hover:text-zinc-900">{c.label}</span>
          <span class="text-sm leading-loose text-zinc-600">{c.copy}</span>
          <span class="mt-1 text-xs tracking-[0.14em] text-zinc-400 transition group-hover:text-zinc-700">見る →</span>
        </a>
      ))}
    </div>
  </section>

  {/* 関連内部リンク */}
  <section class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">あわせて見る</h2>
    <ul class="space-y-3 text-sm">
      <li>
        <a href="/light-guide/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">
          ライトフォレスト 利用案内
        </a>
        <span class="ml-2 text-zinc-400">— 設備・サイズ別目安・利用ルール</span>
      </li>
      <li>
        <a href="/deep/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">
          ディープフォレスト
        </a>
        <span class="ml-2 text-zinc-400">— 静寂と焚き火のフィールド</span>
      </li>
      <li>
        <a href="/map/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">
          場内・周辺マップ
        </a>
        <span class="ml-2 text-zinc-400">— 区画の位置関係を見る</span>
      </li>
    </ul>
  </section>
</PageLayout>
