---
import PageLayout from "../../../layouts/PageLayout.astro";

const TITLE = "ソロキャンプ｜里山パークおいらの森（栃木・那須烏山）";
const DESC =
	"隣を気にしない距離感のソロ向けサイト。管理人常駐で女性ソロも安心。栃木・那須烏山でひとりの森時間を。";
const URL = "https://oiranomori.jp/sites/solo/";

// 「あなたの人数なら、このサイズ」変換ブロック（light-guide の sizeGuide 構造を流用）
const sizeGuide = [
	{
		size: "SS",
		area: "20㎡未満",
		guide: "ソロテント1張り。通称ソロ区画。プライベート感重視。",
	},
	{
		size: "S",
		area: "20〜39㎡",
		guide: "小型テント1張り＋タープ。ゆったり張りたいソロに。",
	},
];

const experiences = [
	{
		h: "隣の気配が、遠い",
		body: "森に距離をもらう。区画の間に木立が入り、視線も音も遮られる。ひとりの時間が薄まらない。",
	},
	{
		h: "女性ソロも、安心して",
		body: "管理人が常駐している。明かりのない夜も、人の気配がある安心。派手な設備はない。代わりに、静けさと、目の届く距離があります。",
	},
	{
		h: "ハンモックを、吊る",
		body: "木と木の間に。揺れながら見上げる葉の天井。ハンモック向きの区画もあります。",
	},
];
---

<PageLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": TITLE,
      "description": DESC,
      "url": URL,
      "isPartOf": {
        "@type": "WebSite",
        "name": "里山パークおいらの森",
        "url": "https://oiranomori.jp"
      }
    })} />
  </Fragment>

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Solo</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">ひとりの森時間</h1>
    <p class="mt-4 max-w-2xl text-sm leading-loose text-zinc-500">
      誰にも合わせなくていい一日。火を起こして、本を開いて、ただ森の音を聞く。
      ひとりで来るあなたのための区画があります。
    </p>
  </div>

  {/* あなたの人数なら、このサイズ */}
  <section class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">あなたなら、このサイズ</h2>
    <p class="mb-5 text-sm text-zinc-500">ソロ（2人以下）に合うのは SS・S。</p>
    <div class="overflow-x-auto border-y border-zinc-200">
      <table class="w-full min-w-[480px] text-sm">
        <thead>
          <tr class="border-b border-zinc-200 bg-zinc-50">
            <th class="px-4 py-3 text-left font-medium text-zinc-600">サイズ</th>
            <th class="px-4 py-3 text-left font-medium text-zinc-600">有効面積</th>
            <th class="px-4 py-3 text-left font-medium text-zinc-600">目安</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          {sizeGuide.map((s) => (
            <tr class="transition hover:bg-zinc-50">
              <td class="px-4 py-3 font-medium text-zinc-700">{s.size}</td>
              <td class="px-4 py-3 text-zinc-600">{s.area}</td>
              <td class="px-4 py-3 text-zinc-600">{s.guide}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {/* 動的枠プレースホルダ（②③：サイズ別空き＋個別区画一覧） */}
  <section id="size-availability" class="mb-14">
    {/* TODO: client-fetch でサイズ別空き＋個別区画一覧。App handoff 後に実装 */}
  </section>

  {/* 体験 */}
  <section class="mb-14">
    <div class="grid gap-8 sm:grid-cols-2">
      {experiences.map((e) => (
        <div class="border-t border-zinc-200 pt-5">
          <h2 class="text-lg font-semibold text-zinc-800">{e.h}</h2>
          <p class="mt-3 text-sm leading-loose text-zinc-600">{e.body}</p>
        </div>
      ))}
    </div>
  </section>

  {/* 予約導線 */}
  <section class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">予約する</h2>
    <p class="mb-5 text-sm leading-loose text-zinc-500">
      料金・空き状況は予約システムでご確認ください。平日ソロ向けの割引プランもあります。
    </p>
    <a
      href="https://www.489pro-x.com/ja/s/oiranomori/planlist/#plans"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-7 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
    >
      空き状況・予約はこちら ↗
    </a>
    {/* TODO: ソロ該当プランの個別 id に差し替え（#plans は仮置き）。proX プラン id 確定後に更新 */}
  </section>

  {/* 関連内部リンク */}
  <section class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">あわせて見る</h2>
    <ul class="space-y-3 text-sm">
      <li>
        <a href="/light-guide/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">ライトフォレスト 利用案内</a>
        <span class="ml-2 text-zinc-400">— 設備・サイズ別目安・利用ルール</span>
      </li>
      <li>
        <a href="/rental/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">レンタル</a>
        <span class="ml-2 text-zinc-400">— 手ぶらでも始められる</span>
      </li>
    </ul>
  </section>
</PageLayout>
