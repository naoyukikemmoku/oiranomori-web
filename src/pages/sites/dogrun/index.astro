---
import PageLayout from "../../../layouts/PageLayout.astro";

const TITLE = "貸切ドッグラン付きキャンプ｜里山パークおいらの森（栃木）";
const DESC =
	"囲いの中、リードなしで遊べる貸切ドッグランサイト。愛犬と泊まる栃木・那須烏山のキャンプ場。ペット可。";
const URL = "https://oiranomori.jp/sites/dogrun/";

const sizeGuide = [
	{
		size: "ドッグランサイト",
		area: "約400㎡（柵内）",
		guide: "貸切。柵に囲まれた区画を、愛犬と独占。",
	},
];

const experiences = [
	{
		h: "囲いの中で、リードを外す",
		body: "柵に囲まれた区画。外につながない代わりに、走り回れる自由を。",
	},
	{
		h: "愛犬と、同じテントで",
		body: "一緒に泊まって、一緒に朝を迎える。",
	},
	{
		h: "広さは、約400㎡を貸し切り",
		body: "他の犬を気にせず、自分たちのペースで。",
	},
];
---

<PageLayout title={TITLE} description={DESC}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": TITLE,
      "description": DESC,
      "url": URL,
      "isPartOf": {
        "@type": "WebSite",
        "name": "里山パークおいらの森",
        "url": "https://oiranomori.jp"
      }
    })} />
  </Fragment>

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Dog Run</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">犬と、過ごす</h1>
    <p class="mt-4 max-w-2xl text-sm leading-loose text-zinc-500">
      柵に囲まれた約400㎡を貸し切り。リードを外して走らせて、夜は同じテントで眠る。
      愛犬との一日を、まるごと森の中で。
    </p>
  </div>

  {/* あなたの人数なら、このサイズ */}
  <section class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">愛犬と泊まるなら、この区画</h2>
    <p class="mb-5 text-sm text-zinc-500">柵内・約400㎡を貸し切るドッグランサイト。</p>
    <div class="overflow-x-auto border-y border-zinc-200">
      <table class="w-full min-w-[480px] text-sm">
        <thead>
          <tr class="border-b border-zinc-200 bg-zinc-50">
            <th class="px-4 py-3 text-left font-medium text-zinc-600">区画</th>
            <th class="px-4 py-3 text-left font-medium text-zinc-600">広さ</th>
            <th class="px-4 py-3 text-left font-medium text-zinc-600">目安</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          {sizeGuide.map((s) => (
            <tr class="transition hover:bg-zinc-50">
              <td class="px-4 py-3 font-medium text-zinc-700">{s.size}</td>
              <td class="px-4 py-3 text-zinc-600">{s.area}</td>
              <td class="px-4 py-3 text-zinc-600">{s.guide}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {/* 動的枠プレースホルダ（②③：サイズ別空き＋個別区画一覧） */}
  <section id="size-availability" class="mb-14">
    {/* TODO: client-fetch でサイズ別空き＋個別区画一覧。App handoff 後に実装 */}
  </section>

  {/* 体験 */}
  <section class="mb-14">
    <div class="grid gap-8 sm:grid-cols-2">
      {experiences.map((e) => (
        <div class="border-t border-zinc-200 pt-5">
          <h2 class="text-lg font-semibold text-zinc-800">{e.h}</h2>
          <p class="mt-3 text-sm leading-loose text-zinc-600">{e.body}</p>
        </div>
      ))}
    </div>
  </section>

  {/* 予約導線 */}
  <section class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">予約する</h2>
    <p class="mb-5 text-sm leading-loose text-zinc-500">
      料金・空き状況は予約システムでご確認ください。
    </p>
    <a
      href="https://www.489pro-x.com/ja/s/oiranomori/planlist/#plans"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-7 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
    >
      空き状況・予約はこちら ↗
    </a>
    {/* TODO: 貸切ドッグランサイト該当プランの個別 id に差し替え（#plans は仮置き）。proX プラン id 確定後に更新 */}
  </section>

  {/* 関連内部リンク */}
  <section class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">あわせて見る</h2>
    <ul class="space-y-3 text-sm">
      <li>
        <a href="/light-guide/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">ライトフォレスト 利用案内</a>
        <span class="ml-2 text-zinc-400">— 設備・サイズ別目安・利用ルール</span>
      </li>
      <li>
        <a href="/rental/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">レンタル</a>
        <span class="ml-2 text-zinc-400">— 手ぶらでも始められる</span>
      </li>
      <li>
        <a href="/access/" class="text-zinc-600 underline underline-offset-2 transition hover:text-zinc-800">アクセス</a>
        <span class="ml-2 text-zinc-400">— 行き方・駐車場</span>
      </li>
    </ul>
  </section>
</PageLayout>
