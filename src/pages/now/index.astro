---
import FloatingNav from "../../components/FloatingNav.astro";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

// ライブ中の videoID は実行時に livecam.php から取得して埋め込む（ビルド時 fetch 禁止）。
// videoID をここに直書きしないこと（配信を作り直すと埋め込みが切れるため）。
const YT_CHANNEL_ID = "UCZ3xCKDzSHpxJm5jyWfJkbg"; // @Oiranomori 里山パークおいらの森
---

<BaseLayout
  title="現地の天気・気温・予報 | 里山パークおいらの森"
  description="おいらの森の今の天気・気象など現地情報をお知らせ。直近予報・周辺5地点の比較・警報注意報・現地センサーの現況を、キャンプ直前の準備に活用してください。"
  lastUpdated="2026年6月"
>

  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "現地の天気・気温・予報 | 里山パークおいらの森",
    "description": "おいらの森の今の天気・気象など現地情報をお知らせ。直近予報・周辺5地点の比較・警報注意報・現地センサーの現況を、キャンプ直前の準備に活用してください。",
    "url": "https://oiranomori.jp/now/",
    "isPartOf": {
      "@type": "WebSite",
      "name": "里山パークおいらの森",
      "url": "https://oiranomori.jp"
    }
  })} />

  <Header />
  <FloatingNav />

  <main class="pb-12 pt-[var(--header-offset)]">

    {/* ページヘッダー */}
    <div class="border-b border-zinc-200 bg-white px-5 py-5">
      <div class="mx-auto max-w-6xl">
        <p class="text-[11px] tracking-[0.28em] text-zinc-400 uppercase">Forest Now</p>
        <h1 class="mt-1 text-3xl font-semibold tracking-tight text-zinc-900">森の今の天気・気温・予報</h1>
        <p class="mt-1 text-xs text-zinc-500">おいら監修｜現地センサーと周辺観測をもとに構築</p>
        <a
          href="/forest-daily/"
          class="mt-2 inline-flex items-center gap-1 text-xs tracking-[0.08em] text-zinc-600 underline underline-offset-4 transition hover:text-zinc-900"
        >今日のおいらの森（日々の記録）→</a>
      </div>
    </div>

    {/* 更新ボタン（画面右下固定）。h1 ブロックと独立させ、モバイルでの改行増を防ぐ */}
    <div class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-1">
      <button
        id="btn-refresh"
        class="border border-zinc-300 bg-white px-4 py-2 text-xs tracking-[0.14em] text-zinc-700 shadow-md transition hover:border-zinc-500 hover:text-zinc-900"
      >
        最新に更新
      </button>
      <p class="text-[10px] text-zinc-500 drop-shadow-sm">ページを開いた時点の情報です</p>
    </div>

    {/* ── セクションナビ（ヘッダー直下に sticky） ────────────── */}
    <nav class="sticky top-0 z-40 border-b border-zinc-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-6xl overflow-x-auto px-5">
        {[
          { href: "#local",    label: "現地" },
          { href: "#warning",  label: "警報" },
          { href: "#forecast", label: "予報" },
          { href: "#trend",    label: "推移" },
          { href: "#aux",      label: "補助" },
        ].map((item) => (
          <a
            href={item.href}
            class="whitespace-nowrap px-4 py-3 text-sm tracking-[0.1em] text-zinc-600 transition hover:text-zinc-900"
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>

    <div class="mx-auto max-w-6xl px-5">

      {/* ═══ A4：現地の今（センサーのみ。ライブカメラは最下部 #livecam へ分離） ═══ */}
      <section id="local" class="scroll-mt-[3.5rem] py-6">
        <p class="text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Local Now</p>
        <h2 class="mt-1 mb-3 text-lg font-semibold text-zinc-800">現地の今</h2>

        {/* 上：受付棟センサー */}
        <div id="a4-uketsuke" class="border border-zinc-200 bg-white p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <p class="text-sm tracking-[0.12em] text-zinc-600">おいらの森(受付)</p>
              <div id="a4-uketsuke-icon" class="flex h-9 w-9 items-center justify-center"></div>
            </div>
            <p id="a4-uketsuke-time" class="text-xs text-zinc-500"></p>
          </div>
          <div id="a4-uketsuke-body" class="mt-3 flex flex-wrap items-end gap-x-8 gap-y-2">
            <div>
              <span id="a4-uketsuke-temp" class="text-4xl font-semibold text-zinc-800">—</span>
              <span class="text-sm text-zinc-500">℃</span>
            </div>
            <div>
              <span id="a4-uketsuke-hum" class="text-2xl font-semibold text-zinc-700">—</span>
              <span class="text-sm text-zinc-500">%（湿度）</span>
            </div>
          </div>
          <p id="a4-uketsuke-diff" class="mt-3 text-sm text-zinc-600" hidden></p>
          <p id="a4-uketsuke-down" class="mt-3 text-sm text-amber-600" hidden>
            センサー一時停止中（復旧作業中）
          </p>
        </div>

        {/* 下：那須烏山アメダス */}
        <div id="a4-amedas" class="mt-3 border border-zinc-200 bg-white p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <p class="text-sm tracking-[0.12em] text-zinc-600">那須烏山アメダス</p>
              <div id="a4-amedas-icon" class="flex h-9 w-9 items-center justify-center"></div>
            </div>
            <p id="a4-amedas-time" class="text-xs text-zinc-500"></p>
          </div>
          <div class="mt-3 grid grid-cols-2 gap-x-6 gap-y-3 md:grid-cols-4">
            <div>
              <p class="text-sm text-zinc-500">気温</p>
              <p class="mt-1"><span id="a4-amedas-temp" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-sm text-zinc-500"> ℃</span></p>
            </div>
            <div>
              <p class="text-sm text-zinc-500">風向 / 風速</p>
              <p class="mt-1"><span id="a4-amedas-wind" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-sm text-zinc-500"> m/s</span></p>
            </div>
            <div>
              <p class="text-sm text-zinc-500">降水（1h）</p>
              <p class="mt-1"><span id="a4-amedas-rain" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-sm text-zinc-500"> mm</span></p>
            </div>
            <div>
              <p class="text-sm text-zinc-500">日照（1h）</p>
              <p class="mt-1"><span id="a4-amedas-sun" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-sm text-zinc-500"> h</span></p>
            </div>
          </div>
        </div>

        {/* 周辺3都市（東京・埼玉・宇都宮）。JSで current.stations から描画 */}
        <div id="a4-cities" class="mt-3 grid grid-cols-3 gap-3">
          {/* JS で描画 */}
        </div>
      </section>

      {/* ═══ A3：警報・注意報 ═══════════════════════════════════ */}
      <section id="warning" class="scroll-mt-[3.5rem] border-t border-zinc-200 py-6">
        <p class="text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Warning / Advisory</p>
        <h2 class="mt-1 mb-3 text-lg font-semibold text-zinc-800">警報・注意報（那須烏山市）</h2>
        <div id="a3-warnings" class="text-sm text-zinc-700">
          <p class="text-zinc-500">取得中…</p>
        </div>

        {/* 雨雲レーダー：気象庁ナウキャストは frame 表示を拒否するため外部リンク化 */}
        <p class="mt-4 mb-2 text-sm text-zinc-600">雨雲レーダー</p>
        <a
          href="https://www.jma.go.jp/bosai/nowc/#lat:36.667/lon:140.13/zoom:9/coltype:HPN"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center text-sm tracking-[0.08em] text-zinc-700 underline underline-offset-4 transition hover:text-zinc-900"
        >雨雲の動きを見る（気象庁）→</a>
      </section>

      {/* ═══ A1：直近予報＋装備テキスト ═══════════════════════ */}
      <section id="forecast" class="scroll-mt-[3.5rem] border-t border-zinc-200 py-6">
        <p class="text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Forecast</p>
        <h2 class="mt-1 mb-3 text-lg font-semibold text-zinc-800">直近予報</h2>

        {/* 今日(/今夜)・明日・明後日。枠数は frames.length で2/3切替（JS）。 */}
        <div id="a1-frames-grid" class="grid grid-cols-2 gap-3">
          <div id="a1-today" class="border border-zinc-200 bg-white p-4 text-center" hidden>
            <p id="a1-today-label" class="text-sm tracking-[0.12em] text-zinc-600">今日</p>
            <p id="a1-today-date" class="mt-1 text-sm text-zinc-500">—</p>
            <div class="my-3 flex h-16 items-center justify-center" id="a1-today-icon"></div>
            <p class="text-sm"><span class="text-zinc-500">降水</span> <span class="font-medium text-zinc-800"><span id="a1-today-pop">—</span>%</span></p>
            <p class="mt-1 text-sm">
              <span class="font-medium text-red-500" id="a1-today-max">—°</span> /
              <span class="font-medium text-blue-500" id="a1-today-min">—°</span>
            </p>

            {/* 暦（控えめ）: 日の出入り・二十四節気・七十二候。JSで流し込む */}
            <div id="a1-koyomi" class="mt-4 border-t border-zinc-100 pt-3 text-[11px] leading-relaxed text-zinc-500" hidden>
              <p id="a1-koyomi-sun"></p>
              <p id="a1-koyomi-term" class="mt-0.5"></p>
              <p id="a1-koyomi-ko" class="mt-0.5"></p>
            </div>
          </div>
          <div id="a1-tomorrow" class="border border-zinc-200 bg-white p-4 text-center" hidden>
            <p class="text-sm tracking-[0.12em] text-zinc-600">明日</p>
            <p id="a1-tomorrow-date" class="mt-1 text-sm text-zinc-500">—</p>
            <div class="my-3 flex h-16 items-center justify-center" id="a1-tomorrow-icon"></div>
            <p class="text-sm"><span class="text-zinc-500">降水</span> <span class="font-medium text-zinc-800"><span id="a1-tomorrow-pop">—</span>%</span></p>
            <p class="mt-1 text-sm">
              <span class="font-medium text-red-500" id="a1-tomorrow-max">—°</span> /
              <span class="font-medium text-blue-500" id="a1-tomorrow-min">—°</span>
            </p>

            {/* 暦（控えめ）: 今日カードと同じ3項目 */}
            <div id="a1-tomorrow-koyomi" class="mt-4 border-t border-zinc-100 pt-3 text-[11px] leading-relaxed text-zinc-500" hidden>
              <p id="a1-tomorrow-koyomi-sun"></p>
              <p id="a1-tomorrow-koyomi-term" class="mt-0.5"></p>
              <p id="a1-tomorrow-koyomi-ko" class="mt-0.5"></p>
            </div>
          </div>
          {/* 明後日カード（夕17時発表など frames 3枠時のみ表示）。#a1-tomorrow と同一構造。 */}
          <div id="a1-dayafter" class="border border-zinc-200 bg-white p-4 text-center" hidden>
            <p class="text-sm tracking-[0.12em] text-zinc-600">明後日</p>
            <p id="a1-dayafter-date" class="mt-1 text-sm text-zinc-500">—</p>
            <div class="my-3 flex h-16 items-center justify-center" id="a1-dayafter-icon"></div>
            <p class="text-sm"><span class="text-zinc-500">降水</span> <span class="font-medium text-zinc-800"><span id="a1-dayafter-pop">—</span>%</span></p>
            <p class="mt-1 text-sm">
              <span class="font-medium text-red-500" id="a1-dayafter-max">—°</span> /
              <span class="font-medium text-blue-500" id="a1-dayafter-min">—°</span>
            </p>

            {/* 暦（控えめ）: 今日カードと同じ3項目 */}
            <div id="a1-dayafter-koyomi" class="mt-4 border-t border-zinc-100 pt-3 text-[11px] leading-relaxed text-zinc-500" hidden>
              <p id="a1-dayafter-koyomi-sun"></p>
              <p id="a1-dayafter-koyomi-term" class="mt-0.5"></p>
              <p id="a1-dayafter-koyomi-ko" class="mt-0.5"></p>
            </div>
          </div>
        </div>

        {/* advisory 解説テキスト。advisory.php の current.body をクライアント取得して流し込む。
            current=null 時は非表示のまま（静かに非挿入）。 */}
        <div id="a1-advisory" class="mt-4 border-l-4 border-zinc-300 py-2 pl-4" hidden>
          <p class="text-xs tracking-[0.12em] text-zinc-400 uppercase">Advisory</p>
          <p class="mt-0.5 text-sm font-medium text-zinc-700">おいらの天気解説</p>
          <p id="a1-advisory-short" class="mt-2 text-sm leading-relaxed text-zinc-700"></p>
          <p class="mt-3 text-right text-[11px] text-zinc-400">気象庁の予報をもとにおいらが解説しています。</p>
        </div>

        {/* 週間予報（weekly[1] 以降） */}
        <p class="mt-4 mb-3 text-sm text-zinc-600">週間</p>
        <div id="a1-weekly" class="flex gap-2 overflow-x-auto pb-2">
          {/* JSで weekly[1..] を描画 */}
        </div>

        {/* weekly 解説テキスト。advisory.weekly.body をクライアント取得して流し込む。
            null/空 時は非表示のまま（静かに非挿入）。週間予報の地続き。 */}
        <div id="a1-weekly-advisory" class="mt-4 border-l-4 border-zinc-300 py-2 pl-4" hidden>
          <p class="text-xs tracking-[0.12em] text-zinc-400 uppercase">Weekly Advisory</p>
          <p class="mt-0.5 text-sm font-medium text-zinc-700">おいらの週間天気解説</p>
          <p id="a1-weekly-advisory-body" class="mt-2 text-sm leading-relaxed text-zinc-700"></p>
          <p id="a1-weekly-advisory-note" class="mt-3 text-right text-[11px] text-zinc-400"></p>
        </div>
      </section>

      {/* ═══ A5：推移グラフ（過去ゾーン） ═══════════════════════ */}
      {/* 取得失敗時はセクションごと非表示（他セクションは壊さない） */}
      <section id="trend" class="scroll-mt-[3.5rem] border-t border-zinc-200 py-6" hidden>
        <div class="flex flex-wrap items-start justify-between gap-y-3 gap-x-4">
          <div>
            <p class="text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Trend</p>
            <h2 class="mt-1 text-lg font-semibold text-zinc-800">気温の推移（日平均）</h2>
          </div>
          {/* 期間切替 */}
          <div id="a5-range" class="flex flex-wrap gap-1">
            {[
              { range: "1w", label: "1週" },
              { range: "1m", label: "1ヶ月" },
              { range: "3m", label: "3ヶ月" },
              { range: "6m", label: "半年" },
              { range: "1y", label: "1年" },
            ].map((b) => (
              <button
                type="button"
                data-range={b.range}
                class="a5-range-btn border border-zinc-300 px-3 py-1 text-xs tracking-[0.1em] text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-900"
              >{b.label}</button>
            ))}
          </div>
        </div>

        {/* SVG 折れ線グラフ（自前描画）。JSで #a5-svg に series を流し込む */}
        <div class="mt-4 overflow-hidden">
          <svg id="a5-svg" viewBox="0 0 720 280" class="w-full" role="img" aria-label="おいらの森の日平均気温と、那須烏山アメダスの日最高・日平均・日最低気温の推移グラフ"></svg>
          <p id="a5-nodata" class="hidden py-8 text-center text-sm text-zinc-500">この期間の観測データはまだありません</p>
        </div>

        {/* 凡例。normal（平年線）は normal 供給後に #a5-legend-normal を表示する接続ポイント */}
        <div class="mt-3 flex flex-wrap items-center gap-x-6 gap-y-1 text-xs text-zinc-600">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#2f6f4f;"></span>おいらの森
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#dc2626;"></span>那須烏山アメダス 最高
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#b08968;"></span>那須烏山アメダス 平均
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#2563eb;"></span>那須烏山アメダス 最低
          </span>
          <span id="a5-legend-normal" class="inline-flex items-center gap-2" hidden>
            <span class="inline-block h-0.5 w-5" style="background:#9ca3af; border-top:1px dashed #9ca3af;"></span>平年値（那須烏山・2009-2020）
          </span>
        </div>

        {/* 平年比サマリ（④）。normal 未供給の間は非表示。供給後にここへ流し込む接続ポイント */}
        <div id="a5-normal-summary" class="mt-3 text-sm text-zinc-600" hidden>
          <p class="text-sm text-zinc-600">平年比（平年値：那須烏山・2009-2020）</p>
          <p id="a5-normal-summary-text" class="mt-1"></p>
        </div>
      </section>

      {/* ═══ A6：補助タブ（衛星・天気図・台風） ══════════════════ */}
      <section id="aux" class="scroll-mt-[3.5rem] border-t border-zinc-200 py-6">

        {/* 折りたたみトグル */}
        <button
          id="aux-toggle"
          class="flex w-full items-center justify-between text-left"
          aria-expanded="false"
          aria-controls="aux-body"
        >
          <span>
            <span class="block text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Satellite / Weather Map / Typhoon</span>
            <span class="mt-1 block text-lg font-semibold text-zinc-800">衛星・天気図・台風</span>
          </span>
          <span id="aux-toggle-icon" class="text-sm text-zinc-600 tracking-widest">＋ 展開</span>
        </button>

        {/* 展開コンテンツ */}
        <div id="aux-body" class="hidden">

          {/* タブ切替 */}
          <div class="mt-6 flex gap-6 border-b border-zinc-200">
            {[
              { id: "tab-sat",     label: "衛星" },
              { id: "tab-wxmap",  label: "天気図" },
              { id: "tab-typhoon", label: "台風" },
            ].map(({ id, label }) => (
              <button
                class="aux-tab pb-2 text-sm tracking-[0.14em] text-zinc-400 transition-colors hover:text-zinc-700"
                data-panel={id.replace("tab-", "panel-")}
              >
                {label}
              </button>
            ))}
          </div>

          {/* ── 衛星パネル ── */}
          <div id="panel-sat" class="aux-panel pt-6">
            <div id="sat2-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:1024/768">
              <img
                id="sat2-img"
                src=""
                alt=""
                width="1024"
                height="768"
                class="w-full object-cover"
                style="display:none"
              />
              <p id="sat2-status" class="absolute inset-0 flex items-center justify-center text-xs text-zinc-400">読み込み中…</p>
            </div>
            <div class="mt-3 flex flex-col gap-2">
              <input
                id="sat2-slider"
                type="range"
                min="0"
                value="0"
                class="aux-slider w-full"
                style="display:none"
              />
              <div class="flex items-center justify-between">
                <p id="sat2-label" class="text-sm text-zinc-600"></p>
                <p id="sat2-stale" class="hidden text-xs text-zinc-500">更新が止まっています</p>
              </div>
            </div>
          </div>

          {/* ── 天気図パネル ── */}
          <div id="panel-wxmap" class="aux-panel hidden pt-6">
            {/* モード切替 */}
            <div class="mb-4 flex gap-4">
              <button id="wxmap-mode-a" class="wxmap-mode text-sm tracking-[0.14em] text-zinc-700" data-mode="a">直近3日（3時間ごと）</button>
              <button id="wxmap-mode-b" class="wxmap-mode text-sm tracking-[0.14em] text-zinc-500" data-mode="b">過去の天気図（日次）</button>
            </div>

            {/* モードA */}
            <div id="wxmap-a-body">
              <div id="wxmap-a-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:600/581">
                <img id="wxmap-a-img" src="" alt="" width="600" height="581" class="w-full object-cover" style="display:none" />
                <p id="wxmap-a-status" class="absolute inset-0 flex items-center justify-center text-xs text-zinc-400">読み込み中…</p>
              </div>
              <div class="mt-3 flex flex-col gap-2">
                <input id="wxmap-a-slider" type="range" min="0" value="0" class="aux-slider w-full" style="display:none" />
                <p id="wxmap-a-label" class="text-sm text-zinc-600"></p>
              </div>
            </div>

            {/* モードB */}
            <div id="wxmap-b-body" class="hidden">
              <div id="wxmap-b-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:600/581">
                <img id="wxmap-b-img" src="" alt="" width="600" height="581" class="w-full object-cover" />
                <p id="wxmap-b-missing" class="absolute inset-0 hidden items-center justify-center text-xs text-zinc-400">この日の天気図はまだありません</p>
              </div>
              <div class="mt-3 flex items-center justify-between">
                <button id="wxmap-b-prev" class="text-sm text-zinc-600 hover:text-zinc-900 tracking-[0.14em]">◀ 前日</button>
                <p id="wxmap-b-label" class="text-sm text-zinc-700"></p>
                <button id="wxmap-b-next" class="text-sm text-zinc-600 hover:text-zinc-900 tracking-[0.14em]">翌日 ▶</button>
              </div>
            </div>
          </div>

          {/* ── 台風パネル ── */}
          <div id="panel-typhoon" class="aux-panel hidden pt-6">
            <div id="typhoon-body">
              <p id="typhoon-status" class="text-sm text-zinc-600">読み込み中…</p>
              {/* TODO: 第2弾で specifications.json を使った予報円描画を実装 */}
            </div>
          </div>

          {/* 出典（3タブ共通） */}
          <p class="mt-8 text-xs text-zinc-500">
            出典：<a href="https://www.jma.go.jp/" target="_blank" rel="noopener" class="underline hover:text-zinc-700">気象庁ホームページ</a>
          </p>

        </div>
      </section>

      {/* ═══ ライブカメラ（A4 から分離・最下部に独立） ══════════════
          LCP悪化回避のため YouTube iframe をファーストビューから外す。
          ライブ中の videoID は実行時に livecam.php から取得して動的に埋め込む
          （ビルド時 fetch 禁止／videoID 直書き禁止）。ナビ項目化はしない。 */}
      <section id="livecam" class="border-t border-zinc-200 py-6">
        <p class="text-[11px] tracking-[0.24em] text-zinc-400 uppercase">Live Camera</p>
        <h2 class="mt-1 mb-3 text-lg font-semibold text-zinc-800">ライブカメラ</h2>

        {/* 映像枠（aspect-video 維持）。初期はプレースホルダ。
            ライブ中のみ JS が #livecam-frame に iframe を流し込む。 */}
        <div class="relative aspect-video overflow-hidden border border-zinc-200 bg-zinc-900">
          <div id="livecam-frame" class="h-full w-full"></div>
          <div
            id="livecam-placeholder"
            class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-5 text-center"
          >
            <p id="livecam-status" class="text-sm text-zinc-300">配信状況を確認しています…</p>
            <a
              id="livecam-channel-link"
              href={`https://www.youtube.com/channel/${YT_CHANNEL_ID}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden text-sm tracking-[0.08em] text-zinc-200 underline underline-offset-4 transition hover:text-white"
            >チャンネルを開く →</a>
          </div>
        </div>

        <div class="mt-2 flex items-center justify-between gap-4">
          {/* ライブ中のみ表示。href は JS が watch?v=<videoID> に差し替える */}
          <a
            id="livecam-watch-link"
            href={`https://www.youtube.com/channel/${YT_CHANNEL_ID}/live`}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden text-sm tracking-[0.08em] text-zinc-600 underline underline-offset-4 transition hover:text-zinc-900"
          >YouTubeで見る →</a>
          {/* 鮮度注記（stale:true かつ live 表示中のみ JS が表示） */}
          <p id="livecam-stale" class="hidden text-xs text-amber-600">配信状態の確認が最新ではありません</p>
          <p class="text-xs text-zinc-500">配信は機器メンテナンス等で一時停止する場合があります</p>
        </div>
      </section>

    </div>
  </main>

  <script>
    import { iconSvg, iconColor } from "../../lib/weatherIcon";
    import { getKoyomi, getSunTimes, getMoonAge, moonPhaseSvg } from "../../lib/koyomi";

    // ════════════════════════════════════════════════════════════
    //  データ取得層（A1〜A4 共通の土台）
    //  - current / forecast / warning を Promise.allSettled で並列取得
    //  - 部分失敗・null フィールドはその箇所だけ非表示。ページ全体は壊さない
    //  - 鮮度判定・差分計算は HP 側（API に status は無い。age_seconds を使う）
    //  - フェッチ頻度は HTTP キャッシュに委ね、追加ポーリングはしない
    //    （current=60s / forecast=warning=300s）
    // ════════════════════════════════════════════════════════════
    const API = {
      current:    "https://oiranomori.com/app/weather/api/public/current.php",
      forecast:   "https://oiranomori.com/app/weather/api/public/forecast.php",
      warning:    "https://oiranomori.com/app/weather/api/public/warning.php",
      timeseries: "https://oiranomori.com/app/weather/api/public/timeseries.php",
      livecam:    "https://oiranomori.com/app/weather/api/public/livecam.php",
      advisory:   "https://oiranomori.com/app/weather/api/public/advisory.php",
    };

    // ライブカメラ（A4 から分離した #livecam で使用）
    // チャンネルリンクは Astro 側で静的描画済み（JS は videoID のみ動的差替）。
    const LIVECAM_STALE_MAX_S = 3600; // stale:true かつ checked_at がこの秒数超 → live でもプレースホルダ落とし

    // 鮮度閾値（A4 で使用）
    const STALE_WARN_S = 1200; // 20分超 → 警告色
    const STALE_DOWN_S = 3600; // 1時間超 → 停止中扱い

    const DOW = ["日", "月", "火", "水", "木", "金", "土"];

    type Json = Record<string, any>;

    const getEl = (id: string) => document.getElementById(id);
    const show = (id: string) => { const e = getEl(id); if (e) e.hidden = false; };
    const setText = (id: string, v: string) => { const e = getEl(id); if (e) e.textContent = v; };

    // 自前天気アイコン（icon_key → 同梱 SVG をインライン展開）。自前 SVG は currentColor
    // 単色設計のため、親の color（既存の text-zinc 系）を継承してネイティブに着色される。
    // 同一バンドル＝CORS 無関係・ブラウザ差なし。dev 目視がそのまま本番挙動になる。
    // icon_key=null（未知/未取り込み）は null を返し、アイコンを描かない（従来の null 耐性を踏襲）。
    function iconFromKey(iconKey: string | null | undefined, size = 36): HTMLElement | null {
      const svg = iconSvg(iconKey);
      if (!svg) return null;
      const span = document.createElement("span");
      span.className = "inline-flex items-center justify-center";
      span.style.width = `${size}px`;
      span.style.height = `${size}px`;
      span.style.color = iconColor(iconKey); // 天気カテゴリ別に着色（SVG は currentColor 単色）
      span.innerHTML = svg;
      const el = span.querySelector("svg");
      if (el) {
        el.setAttribute("width", String(size));
        el.setAttribute("height", String(size));
        (el as SVGElement).style.display = "block";
      }
      span.setAttribute("aria-hidden", "true");
      return span;
    }

    function fmtDate(iso: string): string {
      const d = new Date(iso + "T00:00:00+09:00");
      return `${d.getMonth() + 1}/${d.getDate()}(${DOW[d.getDay()]})`;
    }

    // "YYYY-MM-DD"（JST暦日）をローカルDateとして解釈（暦計算用）
    function parseLocalDate(iso: string): Date {
      const [y, m, d] = iso.split("-").map(Number);
      return new Date(y, m - 1, d);
    }

    // 暦ブロック（日の出入り・二十四節気・七十二候）を埋める。
    // prefix = "a1-koyomi"（今日）または "a1-tomorrow-koyomi"（明日）
    function renderKoyomi(date: Date, prefix: string = "a1-koyomi"): void {
      const box = getEl(prefix);
      if (!box) return;
      const sun = getSunTimes(date);
      const koyomi = getKoyomi(date);
      if (sun) setText(`${prefix}-sun`, `日の出 ${sun.rise} ／ 日の入 ${sun.set}`);
      setText(`${prefix}-term`, `二十四節気：${koyomi.solarTerm}`);
      setText(`${prefix}-ko`, `七十二候：${koyomi.ko.name}（${koyomi.ko.yomi}）`);
      box.hidden = false;
    }

    function fmtClock(iso: string): string {
      const d = new Date(iso);
      const p = (n: number) => String(n).padStart(2, "0");
      return `${d.getMonth() + 1}/${d.getDate()} ${p(d.getHours())}:${p(d.getMinutes())}`;
    }

    async function fetchJson(url: string): Promise<Json> {
      const r = await fetch(url, { cache: "default" });
      const d = await r.json();
      if (!d.ok) throw new Error("ok:false");
      return d;
    }

    // livecam.php 専用フェッチ。レスポンスに ok フィールドを前提しない
    // （{ is_live, video_id, checked_at, stale }）。HTTP/パース失敗は throw し、
    // 呼び出し側（allSettled→renderLivecam(null)）でプレースホルダに倒す。
    async function fetchLivecam(url: string): Promise<Json> {
      const r = await fetch(url, { cache: "default" });
      if (!r.ok) throw new Error(`http:${r.status}`);
      return await r.json();
    }

    // ── A1：直近予報 ─────────────────────────────────────────────
    function renderA1(forecast: Json | null, advisory: Json | null): void {
      if (!forecast) return;

      // 直近予報枠は frames（気象庁2/3枠）駆動。frames 無時は today/tomorrow に縮退。
      const frames: Json[] | null = Array.isArray(forecast.frames) ? forecast.frames : null;

      // 1枠ぶんを所定のカード（today/tomorrow/dayafter）へ描画する共通処理。
      // 既存の描画ロジック（fmtDate / iconFromKey(…,60) / null→「—」「—°」/ renderKoyomi）を踏襲。
      const drawFrame = (
        f: Json,
        slot: "today" | "tomorrow" | "dayafter",
        koyomiPrefix: string,
      ): void => {
        setText(`a1-${slot}-date`, fmtDate(f.date));
        const iconEl = getEl(`a1-${slot}-icon`);
        if (iconEl && f.icon_key) {
          const icon = iconFromKey(f.icon_key, 60);
          if (icon) iconEl.replaceChildren(icon);
        }
        setText(`a1-${slot}-pop`, f.pop != null ? String(f.pop) : "—");
        setText(`a1-${slot}-max`, f.temp_max != null ? `${f.temp_max}°` : "—°");
        setText(`a1-${slot}-min`, f.temp_min != null ? `${f.temp_min}°` : "—°");
        show(`a1-${slot}`);
        renderKoyomi(parseLocalDate(f.date), koyomiPrefix);
      };

      const grid = getEl("a1-frames-grid");
      const dayafterEl = getEl("a1-dayafter");

      if (frames) {
        // 先頭枠（今日/今夜）
        if (frames[0]) {
          drawFrame(frames[0], "today", "a1-koyomi");
          setText("a1-today-label", frames[0].kind === "tonight" ? "今夜" : "今日");
        }
        // 明日
        if (frames[1]) drawFrame(frames[1], "tomorrow", "a1-tomorrow-koyomi");
        // 明後日（3枠時のみ）
        const isThree = frames.length === 3 && !!frames[2];
        if (isThree) {
          drawFrame(frames[2], "dayafter", "a1-dayafter-koyomi");
        } else if (dayafterEl) {
          dayafterEl.hidden = true;
        }
        // グリッド列数を 2/3 で切替
        if (grid) {
          grid.classList.toggle("grid-cols-3", isThree);
          grid.classList.toggle("grid-cols-2", !isThree);
        }
      } else {
        // フォールバック（frames 無）: 従来どおり today/tomorrow を描画。明後日は隠す・2列。
        const today = forecast.today;
        if (today) {
          drawFrame(today, "today", "a1-koyomi");
          setText("a1-today-label", "今日");
        }
        const tomorrow = forecast.tomorrow;
        if (tomorrow) drawFrame(tomorrow, "tomorrow", "a1-tomorrow-koyomi");
        if (dayafterEl) dayafterEl.hidden = true;
        if (grid) {
          grid.classList.toggle("grid-cols-3", false);
          grid.classList.toggle("grid-cols-2", true);
        }
      }

      // 週間（weekly[0]=明日は描画しない）。直近枠との重複解消で slice 起点を frames.length に連動：
      // 3枠（明後日まで直近表示）→ slice(2)（明々後日〜）／2枠・frames無 → slice(1)（明後日〜）。
      const weekly: Json[] = Array.isArray(forecast.weekly) ? forecast.weekly : [];
      const weeklyStart = frames && frames.length === 3 ? 2 : 1;
      const wrap = getEl("a1-weekly");
      if (wrap && weekly.length > weeklyStart) {
        wrap.replaceChildren();
        for (const day of weekly.slice(weeklyStart)) {
          const card = document.createElement("div");
          card.className = "shrink-0 border border-zinc-200 bg-white p-3 text-center";
          card.style.width = "96px";
          const date = document.createElement("p");
          date.className = "text-xs text-zinc-500";
          date.textContent = fmtDate(day.date);
          const icon = document.createElement("div");
          icon.className = "my-2 flex h-11 items-center justify-center";
          if (day.icon_key) {
            const img = iconFromKey(day.icon_key, 44);
            if (img) icon.appendChild(img);
          }
          const pop = document.createElement("p");
          pop.className = "text-xs text-zinc-500";
          pop.textContent = day.pop != null ? `${day.pop}%` : "—";
          const temp = document.createElement("p");
          temp.className = "mt-1 text-xs";
          temp.innerHTML =
            `<span class="text-red-500">${day.temp_max != null ? day.temp_max + "°" : "—"}</span>` +
            ` / <span class="text-blue-500">${day.temp_min != null ? day.temp_min + "°" : "—"}</span>`;

          // 月齢（控えめ）: 月相アイコン＋数値
          const moon = document.createElement("p");
          moon.className = "mt-1.5 flex items-center justify-center gap-1 text-[10px] text-zinc-400";
          const age = getMoonAge(parseLocalDate(day.date));
          moon.innerHTML = `${moonPhaseSvg(age, 12)}<span>月齢${age.toFixed(0)}</span>`;

          card.append(date, icon, pop, temp, moon);
          wrap.appendChild(card);
        }
      }

      // advisory 解説テキスト（current.body のみ表示。null 時は静かに非挿入）
      const advisoryEl = getEl("a1-advisory");
      const shortEl    = getEl("a1-advisory-short");
      const body = advisory?.current?.body;
      if (advisoryEl && shortEl && typeof body === "string" && body.trim().length > 0) {
        shortEl.textContent = body.trim();
        advisoryEl.hidden = false;
      } else if (advisoryEl) {
        advisoryEl.hidden = true;
      }

      // weekly 解説テキスト（advisory.weekly.body。null/空 時は静かに非表示）。
      // 注記は target_date(YYYY-MM-DD) を「M月D日」に整形（ゼロ埋めなし・時刻省略）。
      const wkEl   = getEl("a1-weekly-advisory");
      const wkBody = getEl("a1-weekly-advisory-body");
      const wkNote = getEl("a1-weekly-advisory-note");
      const wbody  = advisory?.weekly?.body;
      if (wkEl && wkBody && typeof wbody === "string" && wbody.trim().length > 0) {
        wkBody.textContent = wbody.trim();
        const td = advisory?.weekly?.target_date;
        if (wkNote) {
          const m = typeof td === "string" ? td.match(/^(\d{4})-(\d{2})-(\d{2})$/) : null;
          wkNote.textContent = m
            ? `気象庁${Number(m[2])}月${Number(m[3])}日発表の予報に基づく`
            : "気象庁の予報に基づく";
        }
        wkEl.hidden = false;
      } else if (wkEl) {
        wkEl.hidden = true;
      }
    }

    // ── A3：警報・注意報 ─────────────────────────────────────────
    function renderA3(warning: Json | null): void {
      const wrap = getEl("a3-warnings");
      if (!wrap) return;
      if (!warning) {
        wrap.innerHTML = `<p class="text-zinc-500">警報・注意報の取得に失敗しました。</p>`;
        return;
      }

      const warnings: Json[] = Array.isArray(warning.warnings) ? warning.warnings : [];
      if (warnings.length === 0) {
        wrap.innerHTML = `<p class="text-zinc-500">現在、発表中の警報・注意報はありません。</p>`;
        return;
      }

      // level で3段階に出し分け（emergency / warning / advisory）
      const styleByLevel = (level: string) => {
        switch (level) {
          case "emergency":
            return "border-2 border-purple-600 bg-purple-50 text-purple-800 font-semibold";
          case "warning":
            return "border border-red-400 bg-red-50 text-red-700";
          default: // advisory
            return "border border-amber-400 bg-amber-50 text-amber-700";
        }
      };
      const rank = (level: string) =>
        level === "emergency" ? 0 : level === "warning" ? 1 : 2;

      const sorted = [...warnings].sort((a, b) => rank(a.level) - rank(b.level));

      wrap.replaceChildren();
      for (const w of sorted) {
        const span = document.createElement("span");
        const lv = String(w.level ?? "advisory");
        span.className = `mr-2 mb-2 inline-block px-3 py-1 text-xs ${styleByLevel(lv)}`;
        span.textContent = w.name ?? w.text ?? `コード ${w.code ?? "—"}`;
        wrap.appendChild(span);
      }
    }

    // ── A4：現地の今（受付棟・アメダス・周辺3都市）───────────────
    function renderA4(current: Json | null): void {
      const uketsuke = current?.stations?.uketsuke;
      const amedas   = current?.stations?.amedas_karasuyama;

      // --- 受付棟 ---
      const tempEl = getEl("a4-uketsuke-temp");
      const humEl  = getEl("a4-uketsuke-hum");
      const bodyEl = getEl("a4-uketsuke-body");
      const downEl = getEl("a4-uketsuke-down");
      const timeEl = getEl("a4-uketsuke-time");

      // 停止中判定：temp_c が null、または鮮度 1時間超
      const ukDown =
        !uketsuke || uketsuke.temp_c == null ||
        (uketsuke.age_seconds != null && uketsuke.age_seconds > STALE_DOWN_S);

      if (ukDown) {
        if (bodyEl) bodyEl.hidden = true;
        if (downEl) downEl.hidden = false;
      } else {
        if (bodyEl) bodyEl.hidden = false;
        if (downEl) downEl.hidden = true;
        if (tempEl) tempEl.textContent = uketsuke.temp_c.toFixed(1);
        if (humEl)  humEl.textContent  = uketsuke.humidity != null ? String(uketsuke.humidity) : "—";

        // 鮮度（20分超で警告色）と時刻スタンプ（強調）
        if (timeEl && uketsuke.observed_at) {
          timeEl.textContent = `${fmtClock(uketsuke.observed_at)} 観測`;
          timeEl.className =
            (uketsuke.age_seconds != null && uketsuke.age_seconds > STALE_WARN_S)
              ? "text-xs font-semibold text-amber-600"
              : "text-xs font-semibold text-zinc-600";
        }
      }

      // 受付棟 天気アイコン
      const ukIconEl = getEl("a4-uketsuke-icon");
      if (ukIconEl) {
        if (uketsuke?.icon_key) {
          const icon = iconFromKey(uketsuke.icon_key, 36);
          if (icon) ukIconEl.replaceChildren(icon);
          else ukIconEl.replaceChildren();
        } else {
          ukIconEl.replaceChildren();
        }
      }

      // --- 那須烏山アメダス ---
      if (amedas) {
        setText("a4-amedas-temp", amedas.temp_c != null ? amedas.temp_c.toFixed(1) : "—");
        const wind = amedas.wind_speed_mps != null ? amedas.wind_speed_mps.toFixed(1) : "—";
        const wdir = amedas.wind_direction ?? "";
        setText("a4-amedas-wind", wdir ? `${wind}（${wdir}）` : wind);
        setText("a4-amedas-rain", amedas.rainfall_1h_mm != null ? String(amedas.rainfall_1h_mm) : "—");
        setText("a4-amedas-sun",  amedas.daylight_1h_h != null ? String(amedas.daylight_1h_h) : "—");
        const aTimeEl = getEl("a4-amedas-time");
        if (aTimeEl && amedas.observed_at) {
          aTimeEl.textContent = `${fmtClock(amedas.observed_at)} 観測`;
          aTimeEl.className =
            (amedas.age_seconds != null && amedas.age_seconds > STALE_WARN_S)
              ? "text-xs font-semibold text-amber-600"
              : "text-xs font-semibold text-zinc-600";
        }
      }

      // アメダス 天気アイコン
      const amIconEl = getEl("a4-amedas-icon");
      if (amIconEl) {
        if (amedas?.icon_key) {
          const icon = iconFromKey(amedas.icon_key, 36);
          if (icon) amIconEl.replaceChildren(icon);
          else amIconEl.replaceChildren();
        } else {
          amIconEl.replaceChildren();
        }
      }

      // --- アメダス比の気温差分（受付棟 − 那須烏山アメダス） ---
      // 受付棟が落ちている場合は代替せず、差分も出さない（欠損は正直に）
      const diffEl = getEl("a4-uketsuke-diff");
      if (diffEl && !ukDown && uketsuke?.temp_c != null && amedas?.temp_c != null) {
        const diff = uketsuke.temp_c - amedas.temp_c;
        const sign = diff >= 0 ? "+" : "−";
        const note = diff < 0 ? "、林間で日陰多め" : "";
        diffEl.textContent = `アメダスより ${sign}${Math.abs(diff).toFixed(1)}℃${note}`;
        diffEl.hidden = false;
      } else if (diffEl) {
        diffEl.hidden = true;
      }

      // --- 周辺3都市（東京・埼玉・宇都宮）---
      const citiesWrap = getEl("a4-cities");
      if (citiesWrap) {
        const cityOrder = [
          { key: "amedas_tokyo",      label: "東京" },
          { key: "amedas_saitama",    label: "埼玉" },
          { key: "amedas_utsunomiya", label: "宇都宮" },
        ];
        const baseTemp = uketsuke?.temp_c ?? null;
        citiesWrap.replaceChildren();

        for (const { key, label } of cityOrder) {
          const st = current?.stations?.[key];
          const card = document.createElement("div");
          card.className = "border border-zinc-200 bg-white p-4 text-center";

          const name = document.createElement("p");
          name.className = "text-xs tracking-[0.12em] text-zinc-400";
          name.textContent = st?.label ?? label;
          card.appendChild(name);

          const iconBox = document.createElement("div");
          iconBox.className = "my-2 flex h-11 items-center justify-center";
          if (st?.icon_key) {
            const icon = iconFromKey(st.icon_key, 44);
            if (icon) iconBox.appendChild(icon);
          }
          card.appendChild(iconBox);

          const temp = document.createElement("p");
          temp.className = "text-2xl font-semibold text-zinc-800";
          temp.innerHTML = (st?.temp_c != null)
            ? `${st.temp_c.toFixed(1)}<span class="text-xs text-zinc-400"> ℃</span>`
            : `<span class="text-zinc-300">—</span>`;
          card.appendChild(temp);

          if (st?.temp_c != null && baseTemp != null) {
            const diff = st.temp_c - baseTemp;
            const sign = diff >= 0 ? "+" : "−";
            const d = document.createElement("p");
            d.className = "mt-1 text-xs text-zinc-400";
            d.textContent = `受付棟比 ${sign}${Math.abs(diff).toFixed(1)}℃`;
            card.appendChild(d);
          }

          citiesWrap.appendChild(card);
        }
      }
    }

    // ── ライブカメラ（#livecam）：実行時に livecam.php を見て埋め込み切替 ──
    // is_live:true && video_id → iframe 埋め込み（stale:true は注記つき表示、
    //   ただし checked_at が LIVECAM_STALE_MAX_S 超ならプレースホルダ落とし）
    // それ以外（false / video_id欠落 / 取得失敗 / 長期stale）→ プレースホルダ。
    //   壊れた iframe は絶対に出さない。
    function renderLivecam(data: Json | null): void {
      const frame   = getEl("livecam-frame");
      const ph      = getEl("livecam-placeholder");
      const statusEl = getEl("livecam-status");
      const chLink  = getEl("livecam-channel-link");
      const watch   = getEl("livecam-watch-link");
      const staleEl = getEl("livecam-stale");
      if (!frame || !ph) return;

      // プレースホルダへ倒す共通処理（iframe は出さない）
      const toPlaceholder = (msg: string): void => {
        frame.replaceChildren();
        ph.classList.remove("hidden");
        if (statusEl) statusEl.textContent = msg;
        if (chLink) chLink.classList.remove("hidden");
        if (watch) watch.classList.add("hidden");
        if (staleEl) staleEl.classList.add("hidden");
      };

      // 取得失敗・欠落・非ライブ → プレースホルダ
      if (!data || data.is_live !== true || !data.video_id) {
        toPlaceholder("現在ライブ配信していません");
        return;
      }

      // 長期 stale 判定：stale:true かつ checked_at が古すぎる → live を信用せず落とす
      if (data.stale === true && data.checked_at) {
        const checked = new Date(data.checked_at).getTime();
        if (!Number.isNaN(checked) &&
            (Date.now() - checked) / 1000 > LIVECAM_STALE_MAX_S) {
          toPlaceholder("現在ライブ配信していません");
          return;
        }
      }

      // --- ライブ表示 ---
      const vid = String(data.video_id);
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube.com/embed/${vid}`;
      iframe.title = "里山パークおいらの森 ライブカメラ";
      iframe.loading = "lazy";
      iframe.allowFullscreen = true;
      iframe.allow =
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
      iframe.className = "h-full w-full border-none";
      frame.replaceChildren(iframe);
      ph.classList.add("hidden");

      if (watch) {
        (watch as HTMLAnchorElement).href = `https://www.youtube.com/watch?v=${vid}`;
        watch.classList.remove("hidden");
      }
      // stale だが新しめ → 表示は出すが鮮度注記を添える（衛星タブと同作法）
      if (staleEl) staleEl.classList.toggle("hidden", data.stale !== true);
    }

    // ── A5：推移グラフ（自前インラインSVG） ─────────────────────
    const SVG_NS = "http://www.w3.org/2000/svg";
    type Point = { date: string; temp_c: number };

    // 期間切替時の再fetch。HTTPキャッシュ（max-age=3600）に委ね追加ポーリングなし。
    let a5CurrentRange = "1w";

    function svgEl(name: string, attrs: Record<string, string | number>): SVGElement {
      const el = document.createElementNS(SVG_NS, name);
      for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
      return el;
    }

    // series（date昇順の点群）を折れ線 path の d 文字列に変換。
    // 直前採用点と3日超の空白があれば M（線切り）、それ以外は L（線継続）。
    const GAP_DAYS = 3;
    function buildPath(
      points: Point[],
      xOf: (date: string) => number,
      yOf: (t: number) => number,
    ): string {
      const valid = points.filter((p) => p.temp_c != null && !Number.isNaN(p.temp_c));
      const cmds: string[] = [];
      let prevDate: string | null = null;
      for (const p of valid) {
        let cmd = "L";
        if (prevDate === null) {
          cmd = "M";
        } else {
          const diff = (new Date(p.date).getTime() - new Date(prevDate).getTime()) / 86400000;
          if (diff > GAP_DAYS) cmd = "M";
        }
        cmds.push(`${cmd}${xOf(p.date).toFixed(1)},${yOf(p.temp_c).toFixed(1)}`);
        prevDate = p.date;
      }
      return cmds.join(" ");
    }

    function drawTrend(data: Json): void {
      const svg = getEl("a5-svg");
      const nodataEl = getEl("a5-nodata");
      if (!svg) return;

      const reception: Point[] = Array.isArray(data?.series?.reception) ? data.series.reception : [];
      // amedas は {date, temp_avg, temp_max, temp_min}（後方互換で temp_c のみも許容）。
      const amedas: Json[]     = Array.isArray(data?.series?.amedas) ? data.series.amedas : [];
      // normal（平年値）は現状 null。供給されたら3本目の線として描く接続ポイント。
      const normal: Point[]    = Array.isArray(data?.series?.normal) ? data.series.normal : [];

      // 烏山アメダスを3系列（平均・最高・最低）に分解。
      // temp_avg 欠落かつ temp_c のみのレスポンスは後方互換で平均線に流す。
      const amAvg: Point[] = amedas
        .map((p) => ({ date: p.date, temp_c: p.temp_avg ?? p.temp_c }))
        .filter((p) => p.temp_c != null && !Number.isNaN(p.temp_c));
      const amMax: Point[] = amedas
        .map((p) => ({ date: p.date, temp_c: p.temp_max }))
        .filter((p) => p.temp_c != null && !Number.isNaN(p.temp_c));
      const amMin: Point[] = amedas
        .map((p) => ({ date: p.date, temp_c: p.temp_min }))
        .filter((p) => p.temp_c != null && !Number.isNaN(p.temp_c));
      const amHasData = amAvg.length > 0 || amMax.length > 0 || amMin.length > 0;

      svg.replaceChildren();

      // レイアウト
      const W = 720, H = 280;
      const padL = 36, padR = 12, padT = 12, padB = 28;

      // X軸：全系列の日付 union を昇順に（amedas の date は3系列共通）
      const allDates = Array.from(
        new Set([...reception, ...amedas, ...normal].map((p) => p.date)),
      ).sort();
      // Y軸：全系列の気温 min-max（烏山 平均/最高/最低を含む）
      const temps = [...reception, ...amAvg, ...amMax, ...amMin, ...normal]
        .map((p) => p.temp_c)
        .filter((t) => t != null && !Number.isNaN(t));

      // 空series 表示（B-5）：受付棟も烏山(3系列とも)も無いとき
      if (nodataEl) {
        const isEmpty = reception.length === 0 && !amHasData;
        nodataEl.classList.toggle("hidden", !isEmpty);
        svg.style.display = isEmpty ? "none" : "";
      }
      if (allDates.length === 0 || temps.length === 0) return;

      const minT = Math.floor(Math.min(...temps) - 1);
      const maxT = Math.ceil(Math.max(...temps) + 1);

      // X軸：実時刻ベース（時間比例。欠測区間は空白のまま）
      const tOf = (date: string) => new Date(date + "T00:00:00+09:00").getTime();
      const tMin = tOf(allDates[0]);
      const tMax = tOf(allDates[allDates.length - 1]);
      const xOf = (date: string) =>
        padL + (tMax === tMin ? 0 : ((tOf(date) - tMin) / (tMax - tMin)) * (W - padL - padR));

      const yOf = (t: number) =>
        H - padB - ((t - minT) / (maxT - minT || 1)) * (H - padT - padB);

      // Y軸グリッド（4本）
      for (let i = 0; i <= 4; i++) {
        const t = minT + ((maxT - minT) * i) / 4;
        const y = yOf(t);
        svg.appendChild(svgEl("line", { x1: padL, y1: y, x2: W - padR, y2: y, stroke: "#e5e7eb", "stroke-width": 1 }));
        const label = svgEl("text", { x: padL - 6, y: y + 3, "text-anchor": "end", "font-size": 10, fill: "#9ca3af" });
        label.textContent = `${t.toFixed(0)}°`;
        svg.appendChild(label);
      }

      // X軸ラベル（時間比例で約6点等間隔。3m以下は M/D、6m/1y は M月）
      // rangeに応じてラベル形式を切り替える。
      const rangeDays = tMax === tMin ? 1 : (tMax - tMin) / 86400000;
      const useLongLabel = rangeDays > 92;

      function xAxisLabel(date: string): string {
        const d = new Date(date + "T00:00:00+09:00");
        if (useLongLabel) {
          const mo = d.getMonth() + 1;
          // 1月（年始め）は年も出す
          if (mo === 1) return `${d.getFullYear().toString().slice(2)}/${mo}月`;
          return `${mo}月`;
        }
        return `${d.getMonth() + 1}/${d.getDate()}`;
      }

      const tickCount = 6;
      const tickDates: string[] = [];
      if (allDates.length === 1) {
        tickDates.push(allDates[0]);
      } else {
        for (let i = 0; i < tickCount; i++) {
          const targetT = tMin + (i / (tickCount - 1)) * (tMax - tMin);
          // targetT に最も近い実在日付を選ぶ
          let best = allDates[0];
          let bestDiff = Math.abs(tOf(best) - targetT);
          for (const d of allDates) {
            const diff = Math.abs(tOf(d) - targetT);
            if (diff < bestDiff) { best = d; bestDiff = diff; }
          }
          if (!tickDates.includes(best)) tickDates.push(best);
        }
      }

      for (const d of tickDates) {
        const label = svgEl("text", { x: xOf(d), y: H - 8, "text-anchor": "middle", "font-size": 10, fill: "#9ca3af" });
        label.textContent = xAxisLabel(d);
        svg.appendChild(label);
      }

      // 平年線（normal）：供給時のみ描画＋凡例・サマリ枠を表示
      const legendNormal = getEl("a5-legend-normal");
      const normalSummary = getEl("a5-normal-summary");
      if (normal.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(normal, xOf, yOf),
          fill: "none", stroke: "#9ca3af", "stroke-width": 1.5, "stroke-dasharray": "4 3",
        }));
        if (legendNormal) legendNormal.hidden = false;
        // 平年比サマリの実値表示は今回スコープ外（normal 供給後にここで算出して出す）
        if (normalSummary) normalSummary.hidden = true;
      } else {
        if (legendNormal) legendNormal.hidden = true;
        if (normalSummary) normalSummary.hidden = true;
      }

      // 烏山アメダス 最高（赤・細）
      if (amMax.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(amMax, xOf, yOf), fill: "none", stroke: "#dc2626", "stroke-width": 1.5,
        }));
      }
      // 烏山アメダス 最低（青・細）
      if (amMin.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(amMin, xOf, yOf), fill: "none", stroke: "#2563eb", "stroke-width": 1.5,
        }));
      }
      // 烏山アメダス 平均（茶・太）
      if (amAvg.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(amAvg, xOf, yOf), fill: "none", stroke: "#b08968", "stroke-width": 2,
        }));
      }
      // 受付棟（緑）※現地センサーを最前面に
      if (reception.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(reception, xOf, yOf), fill: "none", stroke: "#2f6f4f", "stroke-width": 2,
        }));
      }
    }

    async function loadTrend(range: string): Promise<void> {
      const section = getEl("trend");
      try {
        const data = await fetchJson(`${API.timeseries}?range=${range}`);
        drawTrend(data);
        if (section) section.hidden = false; // 取得成功時のみ表示
      } catch (e) {
        // 取得失敗 → A5セクションごと非表示（他セクションは壊さない）
        if (section) section.hidden = true;
        console.warn("[A5 trend]", e);
      }
    }

    function syncRangeButtons(active: string): void {
      for (const btn of document.querySelectorAll<HTMLElement>(".a5-range-btn")) {
        const isActive = btn.dataset.range === active;
        btn.classList.toggle("border-zinc-600", isActive);
        btn.classList.toggle("text-zinc-800", isActive);
        btn.classList.toggle("font-semibold", isActive);
      }
    }

    function initTrend(): void {
      for (const btn of document.querySelectorAll<HTMLElement>(".a5-range-btn")) {
        btn.addEventListener("click", () => {
          const range = btn.dataset.range ?? "1w";
          a5CurrentRange = range;
          syncRangeButtons(range);
          loadTrend(range); // range 別に再fetch・再描画
        });
      }
      syncRangeButtons(a5CurrentRange);
      // 初回ロードは init() に一任（二重fetch回避）。初期 range は 1w。
    }

    // ── 全更新 ───────────────────────────────────────────────────
    async function init(): Promise<void> {
      const btn = getEl("btn-refresh") as HTMLButtonElement | null;
      if (btn) { btn.textContent = "更新中…"; btn.disabled = true; }

      const [curR, fcR, wnR, lcR, advR] = await Promise.allSettled([
        fetchJson(API.current),
        fetchJson(API.forecast),
        fetchJson(API.warning),
        fetchLivecam(API.livecam),
        fetchJson(API.advisory),
      ]);

      const current  = curR.status === "fulfilled" ? curR.value : null;
      const forecast = fcR.status === "fulfilled" ? fcR.value : null;
      const warning  = wnR.status === "fulfilled" ? wnR.value : null;
      const livecam  = lcR.status === "fulfilled" ? lcR.value : null;
      const advisory = advR.status === "fulfilled" ? advR.value : null;

      renderA1(forecast, advisory);
      renderA3(warning);
      renderA4(current);
      renderLivecam(livecam); // 取得失敗時は null → プレースホルダ
      // A5 は現在の選択 range で再取得（HTTPキャッシュに委任）
      loadTrend(a5CurrentRange);

      if (btn) { btn.textContent = "更新"; btn.disabled = false; }
    }

    getEl("btn-refresh")?.addEventListener("click", init);
    initTrend();
    init();
  </script>

  <script>
    // ════════════════════════════════════════════════════════
    // A6 補助タブ（衛星・天気図・台風）
    // ════════════════════════════════════════════════════════

    // ── 定数 ────────────────────────────────────────────────
    const SAT_API   = "https://oiranomori.com/app/weather/api/public/satellite.php?hours=72";
    const WXMAP_API = "https://www.jma.go.jp/bosai/weather_map/data/list.json";
    const WXMAP_IMG_BASE = "https://www.jma.go.jp/bosai/weather_map/data/png/";
    const WXMAP_PAST_BASE =
      "https://www.data.jma.go.jp/yoho/data/wxchart/quick/";
    const TC_API    = "https://www.jma.go.jp/bosai/typhoon/data/targetTc.json";
    const PAST_DAYS_MAX = 90;
    // 衛星: latest から2時間超で鮮度警告
    const SAT_STALE_MS  = 2 * 60 * 60 * 1000;

    // ── ユーティリティ ─────────────────────────────────────
    const pad2 = (n: number) => String(n).padStart(2, "0");

    /** JSTのDateから「M月D日 HH:MM」ラベルを生成 */
    function jstLabel(iso: string): string {
      const d = new Date(iso);
      const jst = new Date(d.getTime() + 9 * 3600 * 1000);
      return `${jst.getUTCMonth() + 1}月${jst.getUTCDate()}日 ${pad2(jst.getUTCHours())}:${pad2(jst.getUTCMinutes())}`;
    }

    /** weather_map ファイル名から観測時刻(UTC)を読んでJSTラベルに変換
     *  ファイル名例: 20260607050900_0_Z__C_010000_20260607030000_MET_...png
     *  観測時刻 = 7番目の '_' 区切りトークン（インデックス6）= YYYYMMDDHHMMSS UTC
     */
    function wxmapFileToJstLabel(filename: string): string {
      const parts = filename.split("_");
      const obsUtc = parts[6] ?? "";
      if (obsUtc.length < 12) return filename;
      const y  = obsUtc.slice(0, 4);
      const mo = obsUtc.slice(4, 6);
      const dy = obsUtc.slice(6, 8);
      const h  = obsUtc.slice(8, 10);
      const mi = obsUtc.slice(10, 12);
      const utcDate = new Date(`${y}-${mo}-${dy}T${h}:${mi}:00Z`);
      const jst = new Date(utcDate.getTime() + 9 * 3600 * 1000);
      return `${jst.getUTCMonth() + 1}月${jst.getUTCDate()}日 ${pad2(jst.getUTCHours())}:${pad2(jst.getUTCMinutes())}`;
    }

    /** JSTの今日から offset日前の Date（UTC midnight）を返す */
    function jstDateOffset(offset: number): Date {
      const now = new Date(Date.now() + 9 * 3600 * 1000);
      return new Date(Date.UTC(
        now.getUTCFullYear(),
        now.getUTCMonth(),
        now.getUTCDate() - offset,
      ));
    }

    /** 過去天気図URL（JST朝9時 = UTC 0000）*/
    function pastWxmapUrl(d: Date): string {
      const y  = d.getUTCFullYear();
      const mo = pad2(d.getUTCMonth() + 1);
      const dy = pad2(d.getUTCDate());
      const yyyymm = `${y}${mo}`;
      const yyyymmdd = `${y}${mo}${dy}`;
      return `${WXMAP_PAST_BASE}${yyyymm}/SPAS_COLOR_${yyyymmdd}0000.png`;
    }

    /** スライダー：前後2枚を先読み */
    function preloadAround(urls: string[], idx: number, radius = 2): void {
      for (let i = idx - radius; i <= idx + radius; i++) {
        if (i < 0 || i >= urls.length || i === idx) continue;
        const img = new Image();
        img.src = urls[i];
      }
    }

    // ── 折りたたみ ─────────────────────────────────────────
    let auxInitialized = false;

    const toggleBtn  = document.getElementById("aux-toggle")!;
    const auxBody    = document.getElementById("aux-body")!;
    const toggleIcon = document.getElementById("aux-toggle-icon")!;

    toggleBtn.addEventListener("click", () => {
      const expanded = toggleBtn.getAttribute("aria-expanded") === "true";
      toggleBtn.setAttribute("aria-expanded", String(!expanded));
      if (expanded) {
        auxBody.classList.add("hidden");
        toggleIcon.textContent = "＋ 展開";
      } else {
        auxBody.classList.remove("hidden");
        toggleIcon.textContent = "－ 閉じる";
        if (!auxInitialized) {
          auxInitialized = true;
          initAux();
        }
      }
    });

    // ── タブ切替 ────────────────────────────────────────────
    const tabs   = document.querySelectorAll<HTMLButtonElement>(".aux-tab");
    const panels = document.querySelectorAll<HTMLElement>(".aux-panel");

    function switchTab(targetPanel: string): void {
      tabs.forEach((t) => {
        const active = t.dataset.panel === targetPanel;
        t.classList.toggle("text-zinc-700", active);
        t.classList.toggle("border-b-2",   active);
        t.classList.toggle("border-zinc-700", active);
        t.classList.toggle("text-zinc-400", !active);
      });
      panels.forEach((p) => p.classList.toggle("hidden", p.id !== targetPanel));
    }

    tabs.forEach((t) => {
      t.addEventListener("click", () => switchTab(t.dataset.panel!));
    });
    // 初期アクティブ
    switchTab("panel-sat");

    // ════════════════════════════════════════════════════════
    // 衛星タブ
    // ════════════════════════════════════════════════════════
    async function initSatTab(): Promise<void> {
      const imgEl    = document.getElementById("sat2-img")    as HTMLImageElement;
      const statusEl = document.getElementById("sat2-status")!;
      const slider   = document.getElementById("sat2-slider") as HTMLInputElement;
      const labelEl  = document.getElementById("sat2-label")!;
      const staleEl  = document.getElementById("sat2-stale")!;

      let frames: { datetime: string; url: string }[] = [];

      try {
        const data = await fetch(SAT_API).then((r) => r.json());
        if (!data.ok || !Array.isArray(data.frames) || data.frames.length === 0) {
          statusEl.textContent = "衛星画像は準備中です";
          return;
        }
        frames = data.frames;

        // 鮮度確認
        const latestDt = new Date(data.latest);
        if (Date.now() - latestDt.getTime() > SAT_STALE_MS) {
          staleEl.classList.remove("hidden");
        }

        slider.max   = String(frames.length - 1);
        slider.value = String(frames.length - 1);
        slider.style.display = "block";

        const showFrame = (idx: number): void => {
          const frame = frames[idx];
          imgEl.alt = `気象衛星ひまわり 赤外画像（${jstLabel(frame.datetime)}）`;
          imgEl.src = frame.url;
          imgEl.style.display  = "block";
          statusEl.style.display = "none";
          labelEl.textContent  = jstLabel(frame.datetime);
          preloadAround(frames.map((f) => f.url), idx);
        };

        showFrame(frames.length - 1);

        slider.addEventListener("input", () => {
          showFrame(Number(slider.value));
        });

      } catch {
        statusEl.textContent = "衛星画像は準備中です";
      }
    }

    // ════════════════════════════════════════════════════════
    // 天気図タブ
    // ════════════════════════════════════════════════════════
    async function initWxmapTab(): Promise<void> {
      // ── モード切替 ──
      const modeABtn = document.getElementById("wxmap-mode-a")!;
      const modeBBtn = document.getElementById("wxmap-mode-b")!;
      const bodyA    = document.getElementById("wxmap-a-body")!;
      const bodyB    = document.getElementById("wxmap-b-body")!;

      let modeAReady = false;

      function setMode(mode: "a" | "b"): void {
        const isA = mode === "a";
        modeABtn.classList.toggle("text-zinc-700", isA);
        modeABtn.classList.toggle("text-zinc-400", !isA);
        modeBBtn.classList.toggle("text-zinc-700", !isA);
        modeBBtn.classList.toggle("text-zinc-400", isA);
        bodyA.classList.toggle("hidden", !isA);
        bodyB.classList.toggle("hidden", isA);
      }

      modeABtn.addEventListener("click", () => setMode("a"));
      modeBBtn.addEventListener("click", () => setMode("b"));

      // ── モードA ──
      const imgA    = document.getElementById("wxmap-a-img")    as HTMLImageElement;
      const statusA = document.getElementById("wxmap-a-status")!;
      const sliderA = document.getElementById("wxmap-a-slider") as HTMLInputElement;
      const labelA  = document.getElementById("wxmap-a-label")!;

      async function initModeA(): Promise<void> {
        if (modeAReady) return;
        try {
          const data = await fetch(WXMAP_API).then((r) => r.json());
          const files: string[] = (data?.near?.now ?? []).slice().sort();
          if (files.length === 0) throw new Error("empty");

          const urls = files.map((f) => `${WXMAP_IMG_BASE}${f}`);

          sliderA.max   = String(files.length - 1);
          sliderA.value = String(files.length - 1);
          sliderA.style.display = "block";

          const showA = (idx: number): void => {
            imgA.src = urls[idx];
            imgA.alt = `天気図（${wxmapFileToJstLabel(files[idx])}）`;
            imgA.style.display  = "block";
            statusA.style.display = "none";
            labelA.textContent  = wxmapFileToJstLabel(files[idx]);
            preloadAround(urls, idx);
          };

          showA(files.length - 1);
          sliderA.addEventListener("input", () => showA(Number(sliderA.value)));
          modeAReady = true;

        } catch {
          // CORS 失敗等：モードA非表示でモードBのみ
          bodyA.classList.add("hidden");
          setMode("b");
          modeABtn.style.display = "none";
          console.warn("[A6/WxMap] モードAのfetchに失敗。モードBのみで稼働。");
        }
      }

      // ── モードB ──
      const imgB      = document.getElementById("wxmap-b-img")     as HTMLImageElement;
      const missingB  = document.getElementById("wxmap-b-missing")!;
      const labelB    = document.getElementById("wxmap-b-label")!;
      const prevBtn   = document.getElementById("wxmap-b-prev")!;
      const nextBtn   = document.getElementById("wxmap-b-next")!;

      let bOffset = 1; // 1=昨日（今日は0時=明朝9時まで未確定のため昨日開始）

      function showB(offset: number): void {
        bOffset = Math.max(1, Math.min(PAST_DAYS_MAX, offset));
        const d = jstDateOffset(bOffset);
        const mo = d.getUTCMonth() + 1;
        const dy = d.getUTCDate();
        const url = pastWxmapUrl(d);

        imgB.style.display    = "block";
        missingB.style.display = "none";
        missingB.classList.add("hidden");

        imgB.src = url;
        imgB.alt = `${mo}月${dy}日 朝9時の天気図`;
        labelB.textContent = `${mo}月${dy}日 朝9時の天気図`;

        imgB.onerror = () => {
          imgB.style.display = "none";
          missingB.style.display = "flex";
          missingB.classList.remove("hidden");
        };

        prevBtn.style.visibility = bOffset >= PAST_DAYS_MAX ? "hidden" : "visible";
        nextBtn.style.visibility = bOffset <= 1              ? "hidden" : "visible";
      }

      prevBtn.addEventListener("click", () => showB(bOffset + 1));
      nextBtn.addEventListener("click", () => showB(bOffset - 1));

      showB(1);

      // モードA初期fetch（初期表示はA）
      await initModeA();

      // Aのモードボタン押下時にも遅延初期化
      modeABtn.addEventListener("click", () => initModeA());
    }

    // ════════════════════════════════════════════════════════
    // 台風タブ
    // ════════════════════════════════════════════════════════
    async function initTyphoonTab(): Promise<void> {
      const bodyEl   = document.getElementById("typhoon-body")!;
      const statusEl = document.getElementById("typhoon-status")!;

      try {
        const data: unknown[] = await fetch(TC_API).then((r) => r.json());

        if (!Array.isArray(data) || data.length === 0) {
          statusEl.textContent = "現在、台風の情報はありません。";
          return;
        }

        const count = data.length;
        statusEl.textContent = "";

        const p = document.createElement("p");
        p.className = "text-sm text-zinc-600 mb-3";
        p.textContent = `現在、台風が ${count} 件発生しています。`;
        bodyEl.appendChild(p);

        const link = document.createElement("a");
        link.href      = "https://www.jma.go.jp/bosai/map.html#contents=typhoon";
        link.target    = "_blank";
        link.rel       = "noopener";
        link.className = "text-xs tracking-[0.14em] text-zinc-500 underline hover:text-zinc-700";
        link.textContent = "詳しくは気象庁の台風情報へ";
        bodyEl.appendChild(link);

      } catch {
        statusEl.textContent = "台風情報を取得できませんでした。";
      }
    }

    // ── 展開時に全タブ初期化 ────────────────────────────────
    function initAux(): void {
      Promise.allSettled([
        initSatTab(),
        initWxmapTab(),
        initTyphoonTab(),
      ]);
    }
  </script>

