---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
---

<BaseLayout
  title="森のいま | 里山パークおいらの森"
  description="おいらの森の今の天気・気象など現地情報をお知らせ。アメダスの現況や警報、週間天気予報など、キャンプに向けた直前の準備に活用してください。"
  lastUpdated="2026年5月"
>

  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
  />
  <script slot="head" is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "森のいま | 里山パークおいらの森",
    "description": "おいらの森の今の天気・気象など現地情報をお知らせ。アメダスの現況や警報、週間天気予報など、キャンプに向けた直前の準備に活用してください。",
    "url": "https://oiranomori.jp/now/",
    "isPartOf": {
      "@type": "WebSite",
      "name": "里山パークおいらの森",
      "url": "https://oiranomori.jp"
    }
  })}</script>

  <Header />

  <main class="pb-24 pt-[var(--header-offset)]">

    {/* ページヘッダー */}
    <div class="border-b border-zinc-200 bg-white px-5 py-6">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
        <div>
          <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Forest Now</p>
          <h1 class="mt-1 text-2xl font-semibold text-zinc-800">森のいま</h1>
          <p class="mt-0.5 text-xs text-zinc-400">おいら監修｜現地アメダスデータをもとに構築</p>
        </div>
        <div class="flex items-center gap-3">
          <p class="text-xs text-zinc-400">ページを開いた時点の情報です</p>
          <button
            id="btn-refresh"
            class="border border-zinc-300 bg-white px-4 py-2 text-xs tracking-[0.14em] text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800"
          >
            更新
          </button>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-5">

      {/* ── 注意報・警報 ──────────────────────────────── */}
      <section id="warning" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Warning / Advisory — 那須烏山市</p>
        <div id="warning-list" class="text-sm text-zinc-600">
          <p class="text-zinc-400">取得中…</p>
        </div>
        <div id="fire-risk" class="mt-4 hidden">
          <div id="fire-risk-inner" class="border-l-4 py-2 pl-4 text-sm"></div>
        </div>
      </section>

      {/* ── アメダス現況カード ────────────────────────── */}
      <section id="amedas" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Current Conditions — Amedas 41247</p>
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <div class="border border-zinc-200 bg-white p-5">
            <p class="text-xs tracking-[0.16em] text-zinc-400">気温</p>
            <p id="card-temp" class="mt-3 text-4xl font-semibold text-zinc-800">—</p>
            <p class="mt-1 text-xs text-zinc-400">℃</p>
          </div>
          <div class="border border-zinc-200 bg-white p-5">
            <p class="text-xs tracking-[0.16em] text-zinc-400">風速 / 風向</p>
            <p id="card-wind" class="mt-3 text-4xl font-semibold text-zinc-800">—</p>
            <p id="card-wind-dir" class="mt-1 text-xs text-zinc-400">m/s　—</p>
          </div>
          <div class="border border-zinc-200 bg-white p-5">
            <p class="text-xs tracking-[0.16em] text-zinc-400">降水量（1h）</p>
            <p id="card-precip" class="mt-3 text-4xl font-semibold text-zinc-800">—</p>
            <p class="mt-1 text-xs text-zinc-400">mm</p>
          </div>
          <div class="border border-zinc-200 bg-white p-5">
            <p class="text-xs tracking-[0.16em] text-zinc-400">日照（10分）</p>
            <p id="card-sun" class="mt-3 text-4xl font-semibold text-zinc-800">—</p>
            <p class="mt-1 text-xs text-zinc-400">分</p>
          </div>
        </div>
        <p id="amedas-time" class="mt-3 text-right text-xs text-zinc-400"></p>
      </section>

      {/* ── 気象衛星 ────────────────────────────────── */}
      <section id="satellite" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Satellite — Himawari</p>
        <div class="overflow-hidden border border-zinc-200 bg-zinc-100">
          <img
            id="sat-img"
            src=""
            alt="気象衛星ひまわり可視画像"
            class="w-full object-cover"
            style="display:none;"
          />
          <iframe
            id="sat-iframe"
            src=""
            class="h-80 w-full border-none"
            title="気象衛星ひまわり"
            style="display:none;"
          ></iframe>
          <p id="sat-loading" class="py-10 text-center text-xs text-zinc-400">衛星画像を読み込み中…</p>
        </div>
        <p id="sat-time" class="mt-2 text-right text-xs text-zinc-400"></p>
      </section>

      {/* ── 雨雲レーダー ──────────────────────────────── */}
      <section id="radar" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Radar — Nowcast</p>
        <div class="overflow-hidden border border-zinc-200">
          <iframe
            src="https://www.jma.go.jp/bosai/nowc/#lat:36.667/lon:140.13/zoom:9/coltype:HPN"
            class="h-96 w-full border-none"
            title="雨雲レーダー"
            loading="lazy"
          ></iframe>
        </div>
        <p class="mt-2 text-xs text-zinc-400">© 気象庁ナウキャスト（那須烏山周辺）</p>
      </section>

      {/* ── 天気分布予報 ────────────────────────────── */}
      <section id="wdist" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Weather Distribution</p>
        <div class="overflow-hidden border border-zinc-200">
          <iframe
            src="https://www.jma.go.jp/bosai/wdist/#lat:36.647487/lon:140.061951/zoom:9"
            class="h-96 w-full border-none"
            title="天気分布予報"
            loading="lazy"
          ></iframe>
        </div>
        <p class="mt-2 text-xs text-zinc-400">© 気象庁天気分布予報</p>
      </section>

      {/* ── 週間予報 ────────────────────────────────── */}
      <section id="forecast" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Weekly Forecast — Tochigi / Utsunomiya temp</p>
        <div id="forecast-swiper" class="swiper overflow-hidden">
          <div class="swiper-wrapper">
            {Array.from({ length: 7 }).map((_, i) => (
              <div class="swiper-slide" style="width:130px;">
                <div class="border border-zinc-200 bg-white p-4 text-center">
                  <p class="text-xs text-zinc-400" id={`fc-date-${i}`}>—</p>
                  <div class="my-3 flex h-10 items-center justify-center" id={`fc-icon-${i}`}>
                    <span class="text-zinc-300 text-lg">—</span>
                  </div>
                  <p class="text-xs" id={`fc-pop-${i}`}>
                    <span class="text-zinc-400">降水</span> —%
                  </p>
                  <p class="mt-1 text-xs" id={`fc-temp-${i}`}>
                    <span class="text-red-400">—°</span> / <span class="text-blue-400">—°</span>
                  </p>
                </div>
              </div>
            ))}
          </div>
          <div class="swiper-scrollbar mt-3 h-1 bg-zinc-200"></div>
        </div>
      </section>

      {/* ── カメラ ───────────────────────────────────── */}
      <section id="camera" class="py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Live Camera</p>
        <div class="border border-zinc-200 bg-zinc-100 py-20 text-center">
          <p class="text-sm text-zinc-400">ライブカメラは準備中です</p>
        </div>
      </section>

      {/* ── A6：補助タブ（衛星・天気図・台風） ─────────── */}
      <section id="aux" class="border-b border-zinc-200 py-8">

        {/* 折りたたみトグル */}
        <button
          id="aux-toggle"
          class="flex w-full items-center justify-between text-left"
          aria-expanded="false"
          aria-controls="aux-body"
        >
          <p class="text-xs tracking-[0.24em] text-zinc-400 uppercase">Satellite / Weather Map / Typhoon</p>
          <span id="aux-toggle-icon" class="text-xs text-zinc-400 tracking-widest">＋ 展開</span>
        </button>

        {/* 展開コンテンツ */}
        <div id="aux-body" class="hidden">

          {/* タブ切替 */}
          <div class="mt-6 flex gap-6 border-b border-zinc-200">
            {[
              { id: "tab-sat",    label: "衛星" },
              { id: "tab-wxmap", label: "天気図" },
              { id: "tab-typhoon", label: "台風" },
            ].map(({ id, label }) => (
              <button
                class="aux-tab pb-2 text-sm tracking-[0.14em] text-zinc-400 transition-colors hover:text-zinc-700"
                data-panel={id.replace("tab-", "panel-")}
              >
                {label}
              </button>
            ))}
          </div>

          {/* ── 衛星パネル ── */}
          <div id="panel-sat" class="aux-panel pt-6">
            <div id="sat2-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:1024/768">
              <img
                id="sat2-img"
                src=""
                alt=""
                width="1024"
                height="768"
                class="w-full object-cover"
                style="display:none"
              />
              <p id="sat2-status" class="absolute inset-0 flex items-center justify-center text-xs text-zinc-400">読み込み中…</p>
            </div>
            <div class="mt-3 flex flex-col gap-2">
              <input
                id="sat2-slider"
                type="range"
                min="0"
                value="0"
                class="aux-slider w-full"
                style="display:none"
              />
              <div class="flex items-center justify-between">
                <p id="sat2-label" class="text-xs text-zinc-400"></p>
                <p id="sat2-stale" class="hidden text-xs text-zinc-400">更新が止まっています</p>
              </div>
            </div>
          </div>

          {/* ── 天気図パネル ── */}
          <div id="panel-wxmap" class="aux-panel hidden pt-6">
            {/* モード切替 */}
            <div class="mb-4 flex gap-4">
              <button id="wxmap-mode-a" class="wxmap-mode text-sm tracking-[0.14em] text-zinc-700" data-mode="a">直近3日（3時間ごと）</button>
              <button id="wxmap-mode-b" class="wxmap-mode text-sm tracking-[0.14em] text-zinc-400" data-mode="b">過去の天気図（日次）</button>
            </div>

            {/* モードA */}
            <div id="wxmap-a-body">
              <div id="wxmap-a-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:600/581">
                <img id="wxmap-a-img" src="" alt="" width="600" height="581" class="w-full object-cover" style="display:none" />
                <p id="wxmap-a-status" class="absolute inset-0 flex items-center justify-center text-xs text-zinc-400">読み込み中…</p>
              </div>
              <div class="mt-3 flex flex-col gap-2">
                <input id="wxmap-a-slider" type="range" min="0" value="0" class="aux-slider w-full" style="display:none" />
                <p id="wxmap-a-label" class="text-xs text-zinc-400"></p>
              </div>
            </div>

            {/* モードB */}
            <div id="wxmap-b-body" class="hidden">
              <div id="wxmap-b-wrap" class="relative overflow-hidden bg-zinc-900" style="aspect-ratio:600/581">
                <img id="wxmap-b-img" src="" alt="" width="600" height="581" class="w-full object-cover" />
                <p id="wxmap-b-missing" class="absolute inset-0 hidden items-center justify-center text-xs text-zinc-400">この日の天気図はまだありません</p>
              </div>
              <div class="mt-3 flex items-center justify-between">
                <button id="wxmap-b-prev" class="text-xs text-zinc-400 hover:text-zinc-700 tracking-[0.14em]">◀ 前日</button>
                <p id="wxmap-b-label" class="text-xs text-zinc-600"></p>
                <button id="wxmap-b-next" class="text-xs text-zinc-400 hover:text-zinc-700 tracking-[0.14em]">翌日 ▶</button>
              </div>
            </div>
          </div>

          {/* ── 台風パネル ── */}
          <div id="panel-typhoon" class="aux-panel hidden pt-6">
            <div id="typhoon-body">
              <p id="typhoon-status" class="text-xs text-zinc-400">読み込み中…</p>
              {/* TODO: 第2弾で specifications.json を使った予報円描画を実装 */}
            </div>
          </div>

          {/* 出典（3タブ共通） */}
          <p class="mt-8 text-xs text-zinc-400">
            出典：<a href="https://www.jma.go.jp/" target="_blank" rel="noopener" class="underline hover:text-zinc-600">気象庁ホームページ</a>
          </p>

        </div>
      </section>

    </div>
  </main>

  {/* ── BottomNav ────────────────────────────────────── */}
  <nav class="fixed bottom-0 left-0 right-0 z-50 flex overflow-x-auto border-t border-zinc-700 bg-[color:var(--forest-700)]">
    {[
      { href: "#warning",   label: "注意報" },
      { href: "#amedas",    label: "現況" },
      { href: "#satellite", label: "衛星" },
      { href: "#radar",     label: "レーダー" },
      { href: "#wdist",     label: "分布予報" },
      { href: "#forecast",  label: "週間" },
      { href: "#camera",    label: "カメラ" },
      { href: "#aux",       label: "補助" },
    ].map((item) => (
      <a
        href={item.href}
        class="flex-1 whitespace-nowrap px-3 py-3 text-center text-xs tracking-[0.14em] text-zinc-300 transition hover:bg-white/10 hover:text-white"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

  <script>
    // ── 定数 ──────────────────────────────────────────────────
    const PREF_CODE    = "090000";
    const AMEDAS_CODE  = "41247";
    const CITY_NAME    = "那須烏山市";

    const WIND_DIR = [
      "静穏","N","NNE","NE","ENE","E","ESE","SE","SSE",
      "S","SSW","SW","WSW","W","WNW","NW","NNW",
    ];

    const WARNING_NAMES: Record<string, string> = {
      "10":"大雨警報","11":"洪水警報","12":"大雪警報",
      "13":"暴風警報","14":"暴風雪警報","15":"波浪警報","16":"高潮警報",
      "20":"大雨注意報","21":"洪水注意報","22":"大雪注意報",
      "23":"強風注意報","24":"風雪注意報","25":"波浪注意報","26":"高潮注意報",
      "32":"乾燥注意報","33":"なだれ注意報","34":"低温注意報",
      "35":"霜注意報","36":"着氷注意報","37":"着雪注意報",
    };

    // ── ユーティリティ ────────────────────────────────────────
    const pad = (n: number) => String(n).padStart(2, "0");

    function getSatUrl(offsetMin = 20): string {
      const ms  = Date.now() + 9 * 3600 * 1000 - offsetMin * 60 * 1000;
      const d   = new Date(ms);
      const y   = d.getUTCFullYear();
      const mo  = pad(d.getUTCMonth() + 1);
      const dy  = pad(d.getUTCDate());
      const h   = pad(d.getUTCHours());
      const mi  = pad(Math.floor(d.getUTCMinutes() / 10) * 10);
      return `https://www.jma.go.jp/bosai/himawari/data/hirv/fullcolor/jpn/${y}${mo}${dy}/${h}${mi}00_hirv_jpn.jpg`;
    }

    // ── 注意報・警報 ───────────────────────────────────────────
    async function fetchWarnings(): Promise<void> {
      const listEl = document.getElementById("warning-list")!;
      try {
        const data = await fetch(
          `https://www.jma.go.jp/bosai/warning/data/warning/${PREF_CODE}.json`
        ).then((r) => r.json());

        let warnings: { code: string; status: string }[] = [];
        for (const at of (data.areaTypes ?? [])) {
          for (const area of (at.areas ?? [])) {
            if (area.name === CITY_NAME) {
              warnings = area.warnings ?? [];
              break;
            }
          }
        }

        const active = warnings.filter((w) => w.status === "発表");

        if (active.length === 0) {
          listEl.innerHTML =
            `<span class="text-zinc-400">現在、${CITY_NAME}に発表中の注意報・警報はありません。</span>`;
        } else {
          listEl.innerHTML = active
            .map((w) => {
              const name      = WARNING_NAMES[w.code] ?? `コード ${w.code}`;
              const isWarning = parseInt(w.code) < 20;
              const cls       = isWarning
                ? "border-red-400 bg-red-50 text-red-700"
                : "border-amber-400 bg-amber-50 text-amber-700";
              return `<span class="mr-2 mb-2 inline-block border px-3 py-1 text-xs ${cls}">${name}</span>`;
            })
            .join("");
        }

        // 林野火災リスク判定（11月〜5月）
        const month     = new Date(Date.now() + 9 * 3600 * 1000).getUTCMonth() + 1;
        const inSeason  = month >= 11 || month <= 5;
        const hasDry    = active.some((w) => w.code === "32");
        const hasWind   = active.some((w) => ["13", "14", "23", "24"].includes(w.code));
        const fireEl    = document.getElementById("fire-risk")!;
        const innerEl   = document.getElementById("fire-risk-inner")!;

        if (inSeason && hasDry) {
          fireEl.classList.remove("hidden");
          if (hasWind) {
            innerEl.className = "border-l-4 border-red-500 py-2 pl-4 text-sm";
            innerEl.innerHTML =
              `<strong class="text-red-700">林野火災リスク：警報相当</strong>` +
              `<span class="ml-2 text-red-600">乾燥注意報＋強風系の警報・注意報が発表中。焚き火は十分な注意が必要です。</span>`;
          } else {
            innerEl.className = "border-l-4 border-amber-500 py-2 pl-4 text-sm";
            innerEl.innerHTML =
              `<strong class="text-amber-700">林野火災リスク：注意報相当</strong>` +
              `<span class="ml-2 text-amber-600">乾燥注意報が発表中。焚き火の管理に注意してください。</span>`;
          }
        }
      } catch (e) {
        listEl.innerHTML = `<span class="text-zinc-400">注意報・警報の取得に失敗しました。</span>`;
        console.warn("[Warning]", e);
      }
    }

    // ── アメダス現況 ────────────────────────────────────────────
    async function fetchAmedas(): Promise<void> {
      try {
        const latestTime: string = await fetch(
          "https://www.jma.go.jp/bosai/amedas/data/latest_time.json"
        ).then((r) => r.json());
        const timeStr = latestTime.replace(/[-:T]/g, "").slice(0, 12) + "00";
        const d = await fetch(
          `https://www.jma.go.jp/bosai/amedas/data/point/${AMEDAS_CODE}/${timeStr}.json`
        ).then((r) => r.json());

        const set = (id: string, val: string) => {
          const el = document.getElementById(id);
          if (el) el.textContent = val;
        };

        const temp   = d.temp?.[0];
        const wind   = d.wind?.[0];
        const wdir   = d.windDirection?.[0];
        const precip = d.precipitation1h?.[0];
        const sun    = d.sun10m?.[0];

        set("card-temp",    temp   !== undefined ? temp.toFixed(1)   : "—");
        set("card-wind",    wind   !== undefined ? wind.toFixed(1)   : "—");
        set("card-wind-dir", `m/s　${wdir !== undefined ? (WIND_DIR[wdir] ?? "—") : "—"}`);
        set("card-precip",  precip !== undefined ? precip.toFixed(1) : "—");
        set("card-sun",     sun    !== undefined ? String(sun)       : "—");

        const tEl = document.getElementById("amedas-time");
        if (tEl) tEl.textContent = `観測時刻: ${latestTime.slice(0, 16).replace("T", " ")} JST`;
      } catch (e) {
        console.warn("[Amedas]", e);
      }
    }

    // ── 気象衛星 ───────────────────────────────────────────────
    function loadSatellite(offsetMin = 20): void {
      const imgEl     = document.getElementById("sat-img") as HTMLImageElement;
      const iframeEl  = document.getElementById("sat-iframe") as HTMLIFrameElement;
      const loadingEl = document.getElementById("sat-loading")!;
      const timeEl    = document.getElementById("sat-time")!;
      const url       = getSatUrl(offsetMin);

      const tmp = new Image();
      tmp.onload = () => {
        imgEl.src          = url;
        imgEl.style.display = "block";
        loadingEl.style.display = "none";
        const m = url.match(/(\d{4})(\d{2})(\d{2})\/(\d{2})(\d{2})/);
        if (m) timeEl.textContent = `ひまわり可視: ${m[1]}/${m[2]}/${m[3]} ${m[4]}:${m[5]} JST`;
      };
      tmp.onerror = () => {
        if (offsetMin < 60) {
          loadSatellite(offsetMin + 10); // 1世代ずつ遡る
        } else {
          // 全滅 → iframe fallback
          iframeEl.src = "https://www.jma.go.jp/bosai/himawari/#zoom:6/lat:36.6/lon:140.1/coltype:VISC";
          iframeEl.style.display = "block";
          loadingEl.style.display = "none";
          timeEl.textContent = "衛星画像の直接取得に失敗しました（iframeで表示）";
        }
      };
      tmp.src = url;
    }

    // ── 週間予報 ───────────────────────────────────────────────
    async function fetchForecast(): Promise<void> {
      try {
        const data = await fetch(
          `https://www.jma.go.jp/bosai/forecast/data/forecast/${PREF_CODE}.json`
        ).then((r) => r.json());

        const weekly    = data[1];
        const wSeries   = weekly?.timeSeries?.[0];
        const popSeries = weekly?.timeSeries?.[1];
        const tSeries   = weekly?.timeSeries?.[2];

        const dates: string[] = wSeries?.timeDefines ?? [];
        const codes: string[] = wSeries?.areas?.[0]?.weatherCodes ?? [];
        const pops: string[]  = popSeries?.areas?.[0]?.pops ?? [];
        const maxT: string[]  = tSeries?.areas?.[0]?.tempsMax ?? [];
        const minT: string[]  = tSeries?.areas?.[0]?.tempsMin ?? [];

        const DOW = ["日", "月", "火", "水", "木", "金", "土"];

        dates.slice(0, 7).forEach((dateStr, i) => {
          const d     = new Date(dateStr);
          const label = `${d.getUTCMonth() + 1}/${d.getUTCDate()}(${DOW[d.getUTCDay()]})`;

          const dateEl = document.getElementById(`fc-date-${i}`);
          const iconEl = document.getElementById(`fc-icon-${i}`);
          const popEl  = document.getElementById(`fc-pop-${i}`);
          const tempEl = document.getElementById(`fc-temp-${i}`);

          if (dateEl) dateEl.textContent = label;

          if (iconEl && codes[i]) {
            const img     = document.createElement("img");
            img.src       = `https://www.jma.go.jp/bosai/forecast/img/${codes[i]}.svg`;
            img.width     = 36;
            img.height    = 36;
            img.alt       = "";
            img.className = "mx-auto";
            iconEl.replaceChildren(img);
          }

          if (popEl) {
            popEl.innerHTML = `<span class="text-zinc-400">降水</span> ${pops[i] ?? "—"}%`;
          }
          if (tempEl) {
            const mx = maxT[i] ?? "—";
            const mn = minT[i] ?? "—";
            tempEl.innerHTML =
              `<span class="text-red-400">${mx}°</span> / <span class="text-blue-400">${mn}°</span>`;
          }
        });
      } catch (e) {
        console.warn("[Forecast]", e);
      }
    }

    // ── Swiper初期化 ───────────────────────────────────────────
    function initSwiper(): void {
      if (typeof (window as any).Swiper === "undefined") {
        setTimeout(initSwiper, 150);
        return;
      }
      new (window as any).Swiper("#forecast-swiper", {
        slidesPerView: "auto",
        spaceBetween: 8,
        freeMode: true,
        scrollbar: { el: ".swiper-scrollbar", draggable: true },
      });
    }

    // ── 全更新 ─────────────────────────────────────────────────
    async function init(): Promise<void> {
      const btn = document.getElementById("btn-refresh") as HTMLButtonElement | null;
      if (btn) { btn.textContent = "更新中…"; btn.disabled = true; }
      await Promise.allSettled([fetchWarnings(), fetchAmedas(), fetchForecast()]);
      loadSatellite();
      if (btn) { btn.textContent = "更新"; btn.disabled = false; }
    }

    document.getElementById("btn-refresh")?.addEventListener("click", init);
    initSwiper();
    init();
  </script>

  <script>
    // ════════════════════════════════════════════════════════
    // A6 補助タブ（衛星・天気図・台風）
    // ════════════════════════════════════════════════════════

    // ── 定数 ────────────────────────────────────────────────
    const SAT_API   = "https://oiranomori.com/app/weather/api/public/satellite.php?hours=72";
    const WXMAP_API = "https://www.jma.go.jp/bosai/weather_map/data/list.json";
    const WXMAP_IMG_BASE = "https://www.jma.go.jp/bosai/weather_map/data/png/";
    const WXMAP_PAST_BASE =
      "https://www.data.jma.go.jp/yoho/data/wxchart/quick/";
    const TC_API    = "https://www.jma.go.jp/bosai/typhoon/data/targetTc.json";
    const PAST_DAYS_MAX = 90;
    // 衛星: latest から2時間超で鮮度警告
    const SAT_STALE_MS  = 2 * 60 * 60 * 1000;

    // ── ユーティリティ ─────────────────────────────────────
    const pad2 = (n: number) => String(n).padStart(2, "0");

    /** JSTのDateから「M月D日 HH:MM」ラベルを生成 */
    function jstLabel(iso: string): string {
      const d = new Date(iso);
      const jst = new Date(d.getTime() + 9 * 3600 * 1000);
      return `${jst.getUTCMonth() + 1}月${jst.getUTCDate()}日 ${pad2(jst.getUTCHours())}:${pad2(jst.getUTCMinutes())}`;
    }

    /** weather_map ファイル名から観測時刻(UTC)を読んでJSTラベルに変換
     *  ファイル名例: 20260607050900_0_Z__C_010000_20260607030000_MET_...png
     *  観測時刻 = 7番目の '_' 区切りトークン（インデックス6）= YYYYMMDDHHMMSS UTC
     */
    function wxmapFileToJstLabel(filename: string): string {
      const parts = filename.split("_");
      const obsUtc = parts[6] ?? "";
      if (obsUtc.length < 12) return filename;
      const y  = obsUtc.slice(0, 4);
      const mo = obsUtc.slice(4, 6);
      const dy = obsUtc.slice(6, 8);
      const h  = obsUtc.slice(8, 10);
      const mi = obsUtc.slice(10, 12);
      const utcDate = new Date(`${y}-${mo}-${dy}T${h}:${mi}:00Z`);
      const jst = new Date(utcDate.getTime() + 9 * 3600 * 1000);
      return `${jst.getUTCMonth() + 1}月${jst.getUTCDate()}日 ${pad2(jst.getUTCHours())}:${pad2(jst.getUTCMinutes())}`;
    }

    /** JSTの今日から offset日前の Date（UTC midnight）を返す */
    function jstDateOffset(offset: number): Date {
      const now = new Date(Date.now() + 9 * 3600 * 1000);
      return new Date(Date.UTC(
        now.getUTCFullYear(),
        now.getUTCMonth(),
        now.getUTCDate() - offset,
      ));
    }

    /** 過去天気図URL（JST朝9時 = UTC 0000）*/
    function pastWxmapUrl(d: Date): string {
      const y  = d.getUTCFullYear();
      const mo = pad2(d.getUTCMonth() + 1);
      const dy = pad2(d.getUTCDate());
      const yyyymm = `${y}${mo}`;
      const yyyymmdd = `${y}${mo}${dy}`;
      return `${WXMAP_PAST_BASE}${yyyymm}/SPAS_COLOR_${yyyymmdd}0000.png`;
    }

    /** スライダー：前後2枚を先読み */
    function preloadAround(urls: string[], idx: number, radius = 2): void {
      for (let i = idx - radius; i <= idx + radius; i++) {
        if (i < 0 || i >= urls.length || i === idx) continue;
        const img = new Image();
        img.src = urls[i];
      }
    }

    // ── 折りたたみ ─────────────────────────────────────────
    let auxInitialized = false;

    const toggleBtn  = document.getElementById("aux-toggle")!;
    const auxBody    = document.getElementById("aux-body")!;
    const toggleIcon = document.getElementById("aux-toggle-icon")!;

    toggleBtn.addEventListener("click", () => {
      const expanded = toggleBtn.getAttribute("aria-expanded") === "true";
      toggleBtn.setAttribute("aria-expanded", String(!expanded));
      if (expanded) {
        auxBody.classList.add("hidden");
        toggleIcon.textContent = "＋ 展開";
      } else {
        auxBody.classList.remove("hidden");
        toggleIcon.textContent = "－ 閉じる";
        if (!auxInitialized) {
          auxInitialized = true;
          initAux();
        }
      }
    });

    // ── タブ切替 ────────────────────────────────────────────
    const tabs   = document.querySelectorAll<HTMLButtonElement>(".aux-tab");
    const panels = document.querySelectorAll<HTMLElement>(".aux-panel");

    function switchTab(targetPanel: string): void {
      tabs.forEach((t) => {
        const active = t.dataset.panel === targetPanel;
        t.classList.toggle("text-zinc-700", active);
        t.classList.toggle("border-b-2",   active);
        t.classList.toggle("border-zinc-700", active);
        t.classList.toggle("text-zinc-400", !active);
        t.classList.toggle("border-b-2",   active);
      });
      panels.forEach((p) => p.classList.toggle("hidden", p.id !== targetPanel));
    }

    tabs.forEach((t) => {
      t.addEventListener("click", () => switchTab(t.dataset.panel!));
    });
    // 初期アクティブ
    switchTab("panel-sat");

    // ════════════════════════════════════════════════════════
    // 衛星タブ
    // ════════════════════════════════════════════════════════
    async function initSatTab(): Promise<void> {
      const imgEl    = document.getElementById("sat2-img")    as HTMLImageElement;
      const statusEl = document.getElementById("sat2-status")!;
      const slider   = document.getElementById("sat2-slider") as HTMLInputElement;
      const labelEl  = document.getElementById("sat2-label")!;
      const staleEl  = document.getElementById("sat2-stale")!;

      let frames: { datetime: string; url: string }[] = [];

      try {
        const data = await fetch(SAT_API).then((r) => r.json());
        if (!data.ok || !Array.isArray(data.frames) || data.frames.length === 0) {
          statusEl.textContent = "衛星画像は準備中です";
          return;
        }
        frames = data.frames;

        // 鮮度確認
        const latestDt = new Date(data.latest);
        if (Date.now() - latestDt.getTime() > SAT_STALE_MS) {
          staleEl.classList.remove("hidden");
        }

        slider.max   = String(frames.length - 1);
        slider.value = String(frames.length - 1);
        slider.style.display = "block";

        const showFrame = (idx: number): void => {
          const frame = frames[idx];
          imgEl.alt = `気象衛星ひまわり 赤外画像（${jstLabel(frame.datetime)}）`;
          imgEl.src = frame.url;
          imgEl.style.display  = "block";
          statusEl.style.display = "none";
          labelEl.textContent  = jstLabel(frame.datetime);
          preloadAround(frames.map((f) => f.url), idx);
        };

        showFrame(frames.length - 1);

        slider.addEventListener("input", () => {
          showFrame(Number(slider.value));
        });

      } catch {
        statusEl.textContent = "衛星画像は準備中です";
      }
    }

    // ════════════════════════════════════════════════════════
    // 天気図タブ
    // ════════════════════════════════════════════════════════
    async function initWxmapTab(): Promise<void> {
      // ── モード切替 ──
      const modeABtn = document.getElementById("wxmap-mode-a")!;
      const modeBBtn = document.getElementById("wxmap-mode-b")!;
      const bodyA    = document.getElementById("wxmap-a-body")!;
      const bodyB    = document.getElementById("wxmap-b-body")!;

      let modeAReady = false;

      function setMode(mode: "a" | "b"): void {
        const isA = mode === "a";
        modeABtn.classList.toggle("text-zinc-700", isA);
        modeABtn.classList.toggle("text-zinc-400", !isA);
        modeBBtn.classList.toggle("text-zinc-700", !isA);
        modeBBtn.classList.toggle("text-zinc-400", isA);
        bodyA.classList.toggle("hidden", !isA);
        bodyB.classList.toggle("hidden", isA);
      }

      modeABtn.addEventListener("click", () => setMode("a"));
      modeBBtn.addEventListener("click", () => setMode("b"));

      // ── モードA ──
      const imgA    = document.getElementById("wxmap-a-img")    as HTMLImageElement;
      const statusA = document.getElementById("wxmap-a-status")!;
      const sliderA = document.getElementById("wxmap-a-slider") as HTMLInputElement;
      const labelA  = document.getElementById("wxmap-a-label")!;

      async function initModeA(): Promise<void> {
        if (modeAReady) return;
        try {
          const data = await fetch(WXMAP_API).then((r) => r.json());
          const files: string[] = (data?.near?.now ?? []).slice().sort();
          if (files.length === 0) throw new Error("empty");

          const urls = files.map((f) => `${WXMAP_IMG_BASE}${f}`);

          sliderA.max   = String(files.length - 1);
          sliderA.value = String(files.length - 1);
          sliderA.style.display = "block";

          const showA = (idx: number): void => {
            imgA.src = urls[idx];
            imgA.alt = `天気図（${wxmapFileToJstLabel(files[idx])}）`;
            imgA.style.display  = "block";
            statusA.style.display = "none";
            labelA.textContent  = wxmapFileToJstLabel(files[idx]);
            preloadAround(urls, idx);
          };

          showA(files.length - 1);
          sliderA.addEventListener("input", () => showA(Number(sliderA.value)));
          modeAReady = true;

        } catch {
          // CORS 失敗等：モードA非表示でモードBのみ
          bodyA.classList.add("hidden");
          setMode("b");
          modeABtn.style.display = "none";
          console.warn("[A6/WxMap] モードAのfetchに失敗。モードBのみで稼働。");
        }
      }

      // ── モードB ──
      const imgB      = document.getElementById("wxmap-b-img")     as HTMLImageElement;
      const missingB  = document.getElementById("wxmap-b-missing")!;
      const labelB    = document.getElementById("wxmap-b-label")!;
      const prevBtn   = document.getElementById("wxmap-b-prev")!;
      const nextBtn   = document.getElementById("wxmap-b-next")!;

      let bOffset = 1; // 1=昨日（今日は0時=明朝9時まで未確定のため昨日開始）

      function showB(offset: number): void {
        bOffset = Math.max(1, Math.min(PAST_DAYS_MAX, offset));
        const d = jstDateOffset(bOffset);
        const mo = d.getUTCMonth() + 1;
        const dy = d.getUTCDate();
        const url = pastWxmapUrl(d);

        imgB.style.display    = "block";
        missingB.style.display = "none";
        missingB.classList.add("hidden");

        imgB.src = url;
        imgB.alt = `${mo}月${dy}日 朝9時の天気図`;
        labelB.textContent = `${mo}月${dy}日 朝9時の天気図`;

        imgB.onerror = () => {
          imgB.style.display = "none";
          missingB.style.display = "flex";
          missingB.classList.remove("hidden");
        };

        prevBtn.style.visibility = bOffset >= PAST_DAYS_MAX ? "hidden" : "visible";
        nextBtn.style.visibility = bOffset <= 1              ? "hidden" : "visible";
      }

      prevBtn.addEventListener("click", () => showB(bOffset + 1));
      nextBtn.addEventListener("click", () => showB(bOffset - 1));

      showB(1);

      // モードA初期fetch（初期表示はA）
      await initModeA();

      // Aのモードボタン押下時にも遅延初期化
      modeABtn.addEventListener("click", () => initModeA());
    }

    // ════════════════════════════════════════════════════════
    // 台風タブ
    // ════════════════════════════════════════════════════════
    async function initTyphoonTab(): Promise<void> {
      const bodyEl   = document.getElementById("typhoon-body")!;
      const statusEl = document.getElementById("typhoon-status")!;

      try {
        const data: unknown[] = await fetch(TC_API).then((r) => r.json());

        if (!Array.isArray(data) || data.length === 0) {
          statusEl.textContent = "現在、台風の情報はありません。";
          return;
        }

        const count = data.length;
        statusEl.textContent = "";

        const p = document.createElement("p");
        p.className = "text-sm text-zinc-600 mb-3";
        p.textContent = `現在、台風が ${count} 件発生しています。`;
        bodyEl.appendChild(p);

        const link = document.createElement("a");
        link.href      = "https://www.jma.go.jp/bosai/map.html#contents=typhoon";
        link.target    = "_blank";
        link.rel       = "noopener";
        link.className = "text-xs tracking-[0.14em] text-zinc-500 underline hover:text-zinc-700";
        link.textContent = "詳しくは気象庁の台風情報へ";
        bodyEl.appendChild(link);

      } catch {
        statusEl.textContent = "台風情報を取得できませんでした。";
      }
    }

    // ── 展開時に全タブ初期化 ────────────────────────────────
    function initAux(): void {
      Promise.allSettled([
        initSatTab(),
        initWxmapTab(),
        initTyphoonTab(),
      ]);
    }
  </script>

  <style>
    /* A6 スライダー装飾 */
    .aux-slider {
      -webkit-appearance: none;
      appearance: none;
      height: 2px;
      background: #d4d4d8; /* zinc-300 */
      outline: none;
      cursor: pointer;
    }
    .aux-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 14px;
      height: 14px;
      background: #52525b; /* zinc-600 */
      border-radius: 50%;
      cursor: pointer;
    }
    .aux-slider::-moz-range-thumb {
      width: 14px;
      height: 14px;
      background: #52525b;
      border: none;
      border-radius: 50%;
      cursor: pointer;
    }
  </style>

</BaseLayout>
