---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";

const YOUTUBE_VIDEO_ID = "8jz3lAgUYl8";
---

<BaseLayout
  title="森のいま | 里山パークおいらの森"
  description="おいらの森の今の天気・気象など現地情報をお知らせ。直近予報・周辺5地点の比較・警報注意報・現地センサーの現況を、キャンプ直前の準備に活用してください。"
  lastUpdated="2026年6月"
>

  <script slot="head" is:inline type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "森のいま | 里山パークおいらの森",
    "description": "おいらの森の今の天気・気象など現地情報をお知らせ。直近予報・周辺5地点の比較・警報注意報・現地センサーの現況を、キャンプ直前の準備に活用してください。",
    "url": "https://oiranomori.jp/now/",
    "isPartOf": {
      "@type": "WebSite",
      "name": "里山パークおいらの森",
      "url": "https://oiranomori.jp"
    }
  })}</script>

  <Header />

  <main class="pb-24 pt-[var(--header-offset)]">

    {/* ページヘッダー */}
    <div class="border-b border-zinc-200 bg-white px-5 py-6">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
        <div>
          <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Forest Now</p>
          <h1 class="mt-1 text-2xl font-semibold text-zinc-800">森のいま</h1>
          <p class="mt-0.5 text-xs text-zinc-400">おいら監修｜現地センサーと周辺観測をもとに構築</p>
        </div>
        <div class="flex items-center gap-3">
          <p class="text-xs text-zinc-400">ページを開いた時点の情報です</p>
          <button
            id="btn-refresh"
            class="border border-zinc-300 bg-white px-4 py-2 text-xs tracking-[0.14em] text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800"
          >
            更新
          </button>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-5">

      {/* ═══ A1：直近予報＋装備テキスト ═══════════════════════ */}
      <section id="forecast" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Forecast — 直近予報</p>

        {/* 今日・明日 */}
        <div class="grid grid-cols-2 gap-3">
          <div id="a1-today" class="border border-zinc-200 bg-white p-5 text-center" hidden>
            <p class="text-xs tracking-[0.16em] text-zinc-400">今日</p>
            <p id="a1-today-date" class="mt-1 text-xs text-zinc-400">—</p>
            <div class="my-3 flex h-12 items-center justify-center" id="a1-today-icon"></div>
            <p class="text-xs"><span class="text-zinc-400">降水</span> <span id="a1-today-pop">—</span>%</p>
            <p class="mt-1 text-xs">
              <span class="text-red-400" id="a1-today-max">—°</span> /
              <span class="text-blue-400" id="a1-today-min">—°</span>
            </p>
          </div>
          <div id="a1-tomorrow" class="border border-zinc-200 bg-white p-5 text-center" hidden>
            <p class="text-xs tracking-[0.16em] text-zinc-400">明日</p>
            <p id="a1-tomorrow-date" class="mt-1 text-xs text-zinc-400">—</p>
            <div class="my-3 flex h-12 items-center justify-center" id="a1-tomorrow-icon"></div>
            <p class="text-xs"><span class="text-zinc-400">降水</span> <span id="a1-tomorrow-pop">—</span>%</p>
            <p class="mt-1 text-xs">
              <span class="text-red-400" id="a1-tomorrow-max">—°</span> /
              <span class="text-blue-400" id="a1-tomorrow-min">—°</span>
            </p>
          </div>
        </div>

        {/* 週間予報（weekly[1] 以降） */}
        <p class="mt-6 mb-3 text-xs tracking-[0.16em] text-zinc-400">週間</p>
        <div id="a1-weekly" class="flex gap-2 overflow-x-auto pb-2">
          {/* JSで weekly[1..] を描画 */}
        </div>

        {/* 装備テキスト枠「おいらからのご案内」: advisory API 未実装のため非表示。
            P4完了後に #a1-advisory へ short/weekly を流し込む接続ポイント。 */}
        <div id="a1-advisory" class="mt-6 border-l-4 border-zinc-300 py-2 pl-4 text-sm text-zinc-600" hidden>
          <p class="text-xs tracking-[0.16em] text-zinc-400">おいらからのご案内</p>
          <p id="a1-advisory-short" class="mt-1"></p>
          <p id="a1-advisory-weekly" class="mt-1 text-zinc-500"></p>
        </div>
      </section>

      {/* ═══ A2：比較5地点カード ═══════════════════════════════ */}
      <section id="compare" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Compare — 周辺5地点</p>
        <div id="a2-cards" class="grid grid-cols-2 gap-3 md:grid-cols-5">
          {/* JSで current.stations を描画 */}
          <p class="col-span-full text-sm text-zinc-400">取得中…</p>
        </div>

        {/* 季節コメント枠: seasonal_comment API 未実装のため非表示。
            P後続で #a2-seasonal へ流し込む接続ポイント。 */}
        <div id="a2-seasonal" class="mt-4 text-sm text-zinc-500" hidden>
          <p id="a2-seasonal-text"></p>
        </div>
      </section>

      {/* ═══ A3：警報・注意報 ═══════════════════════════════════ */}
      <section id="warning" class="border-b border-zinc-200 py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Warning / Advisory — 那須烏山市</p>
        <div id="a3-warnings" class="text-sm text-zinc-600">
          <p class="text-zinc-400">取得中…</p>
        </div>

        {/* 雨雲レーダー（気象庁ナウキャスト）: 現行踏襲で残す */}
        <p class="mt-6 mb-3 text-xs tracking-[0.16em] text-zinc-400">雨雲レーダー</p>
        <div class="overflow-hidden border border-zinc-200">
          <iframe
            src="https://www.jma.go.jp/bosai/nowc/#lat:36.667/lon:140.13/zoom:9/coltype:HPN"
            class="h-96 w-full border-none"
            title="雨雲レーダー"
            loading="lazy"
          ></iframe>
        </div>
        <p class="mt-2 text-xs text-zinc-400">© 気象庁ナウキャスト（那須烏山周辺）</p>
      </section>

      {/* ═══ A4：現地の今（＋ライブカメラ） ═══════════════════ */}
      <section id="local" class="py-8">
        <p class="mb-4 text-xs tracking-[0.24em] text-zinc-400 uppercase">Local Now — 現地の今</p>

        {/* 上：受付棟センサー */}
        <div id="a4-uketsuke" class="border border-zinc-200 bg-white p-5">
          <div class="flex items-baseline justify-between">
            <p class="text-xs tracking-[0.16em] text-zinc-400">受付棟</p>
            <p id="a4-uketsuke-time" class="text-xs text-zinc-400"></p>
          </div>
          <div id="a4-uketsuke-body" class="mt-3 flex flex-wrap items-end gap-x-8 gap-y-2">
            <div>
              <span id="a4-uketsuke-temp" class="text-4xl font-semibold text-zinc-800">—</span>
              <span class="text-sm text-zinc-400">℃</span>
            </div>
            <div>
              <span id="a4-uketsuke-hum" class="text-2xl font-semibold text-zinc-700">—</span>
              <span class="text-sm text-zinc-400">%（湿度）</span>
            </div>
          </div>
          <p id="a4-uketsuke-diff" class="mt-3 text-sm text-zinc-500" hidden></p>
          <p id="a4-uketsuke-down" class="mt-3 text-sm text-amber-600" hidden>
            センサー一時停止中（復旧作業中）
          </p>
        </div>

        {/* 下：那須烏山アメダス */}
        <div id="a4-amedas" class="mt-3 border border-zinc-200 bg-white p-5">
          <div class="flex items-baseline justify-between">
            <p class="text-xs tracking-[0.16em] text-zinc-400">那須烏山アメダス</p>
            <p id="a4-amedas-time" class="text-xs text-zinc-400"></p>
          </div>
          <div class="mt-3 grid grid-cols-2 gap-x-6 gap-y-3 md:grid-cols-4">
            <div>
              <p class="text-xs text-zinc-400">気温</p>
              <p class="mt-1"><span id="a4-amedas-temp" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-xs text-zinc-400"> ℃</span></p>
            </div>
            <div>
              <p class="text-xs text-zinc-400">風向 / 風速</p>
              <p class="mt-1"><span id="a4-amedas-wind" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-xs text-zinc-400"> m/s</span></p>
            </div>
            <div>
              <p class="text-xs text-zinc-400">降水（1h）</p>
              <p class="mt-1"><span id="a4-amedas-rain" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-xs text-zinc-400"> mm</span></p>
            </div>
            <div>
              <p class="text-xs text-zinc-400">日照（1h）</p>
              <p class="mt-1"><span id="a4-amedas-sun" class="text-2xl font-semibold text-zinc-800">—</span><span class="text-xs text-zinc-400"> h</span></p>
            </div>
          </div>
        </div>

        {/* ライブカメラ（YouTube）: 現行から A4 末尾へ移設 */}
        <p class="mt-6 mb-3 text-xs tracking-[0.16em] text-zinc-400">ライブカメラ</p>
        <div class="aspect-video overflow-hidden border border-zinc-200">
          <iframe
            src={`https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}`}
            title="里山パークおいらの森 ライブカメラ"
            loading="lazy"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            class="h-full w-full border-none"
          ></iframe>
        </div>
        <div class="mt-2 flex items-center justify-between">
          <a
            href={`https://youtube.com/live/${YOUTUBE_VIDEO_ID}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs tracking-[0.1em] text-zinc-400 transition hover:text-zinc-700"
          >YouTubeで見る →</a>
          <p class="text-xs text-zinc-400">配信は機器メンテナンス等で一時停止する場合があります</p>
        </div>
      </section>

      {/* ═══ A5：推移グラフ（過去ゾーン） ═══════════════════════ */}
      {/* 取得失敗時はセクションごと非表示（他セクションは壊さない） */}
      <section id="trend" class="border-t border-zinc-200 py-8" hidden>
        <div class="flex items-center justify-between">
          <p class="text-xs tracking-[0.24em] text-zinc-400 uppercase">Trend — 気温の推移（日平均）</p>
          {/* 期間切替 1w / 1m / 3m */}
          <div id="a5-range" class="flex gap-1">
            {[
              { range: "1w", label: "1週" },
              { range: "1m", label: "1ヶ月" },
              { range: "3m", label: "3ヶ月" },
            ].map((b) => (
              <button
                type="button"
                data-range={b.range}
                class="a5-range-btn border border-zinc-300 px-3 py-1 text-xs tracking-[0.1em] text-zinc-500 transition hover:border-zinc-500 hover:text-zinc-800"
              >{b.label}</button>
            ))}
          </div>
        </div>

        {/* SVG 折れ線グラフ（自前描画）。JSで #a5-svg に series を流し込む */}
        <div class="mt-4 overflow-hidden">
          <svg id="a5-svg" viewBox="0 0 720 280" class="w-full" role="img" aria-label="受付棟とアメダスの日平均気温の推移グラフ"></svg>
        </div>

        {/* 凡例。normal（平年線）は normal 供給後に #a5-legend-normal を表示する接続ポイント */}
        <div class="mt-3 flex flex-wrap items-center gap-x-6 gap-y-1 text-xs text-zinc-500">
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#2f6f4f;"></span>受付棟
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="inline-block h-0.5 w-5" style="background:#b08968;"></span>那須烏山アメダス
          </span>
          <span id="a5-legend-normal" class="inline-flex items-center gap-2" hidden>
            <span class="inline-block h-0.5 w-5" style="background:#9ca3af; border-top:1px dashed #9ca3af;"></span>平年
          </span>
        </div>

        {/* 平年比サマリ（④）。normal 未供給の間は非表示。供給後にここへ流し込む接続ポイント */}
        <div id="a5-normal-summary" class="mt-3 text-sm text-zinc-500" hidden>
          <p id="a5-normal-summary-text"></p>
        </div>
      </section>

    </div>
  </main>

  {/* ── BottomNav ────────────────────────────────────── */}
  <nav class="fixed bottom-0 left-0 right-0 z-50 flex overflow-x-auto border-t border-zinc-700 bg-[color:var(--forest-700)]">
    {[
      { href: "#forecast", label: "予報" },
      { href: "#compare",  label: "5地点" },
      { href: "#warning",  label: "警報" },
      { href: "#local",    label: "現地" },
      { href: "#trend",    label: "推移" },
    ].map((item) => (
      <a
        href={item.href}
        class="flex-1 whitespace-nowrap px-3 py-3 text-center text-xs tracking-[0.14em] text-zinc-300 transition hover:bg-white/10 hover:text-white"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <script>
    import { jmaIconUrl } from "../../lib/jmaTelops";

    // ════════════════════════════════════════════════════════════
    //  データ取得層（A1〜A4 共通の土台）
    //  - current / forecast / warning を Promise.allSettled で並列取得
    //  - 部分失敗・null フィールドはその箇所だけ非表示。ページ全体は壊さない
    //  - 鮮度判定・差分計算は HP 側（API に status は無い。age_seconds を使う）
    //  - フェッチ頻度は HTTP キャッシュに委ね、追加ポーリングはしない
    //    （current=60s / forecast=warning=300s）
    // ════════════════════════════════════════════════════════════
    const API = {
      current:    "https://oiranomori.com/app/weather/api/public/current.php",
      forecast:   "https://oiranomori.com/app/weather/api/public/forecast.php",
      warning:    "https://oiranomori.com/app/weather/api/public/warning.php",
      timeseries: "https://oiranomori.com/app/weather/api/public/timeseries.php",
    };

    // 鮮度閾値（A4 で使用）
    const STALE_WARN_S = 1200; // 20分超 → 警告色
    const STALE_DOWN_S = 3600; // 1時間超 → 停止中扱い

    const DOW = ["日", "月", "火", "水", "木", "金", "土"];

    type Json = Record<string, any>;

    const getEl = (id: string) => document.getElementById(id);
    const show = (id: string) => { const e = getEl(id); if (e) e.hidden = false; };
    const setText = (id: string, v: string) => { const e = getEl(id); if (e) e.textContent = v; };

    // JMA 天気アイコン（weather_code → TELOPS 表で昼アイコンファイル名に解決）。
    // 表に無い未知コードは null を返し、呼び出し側でアイコンを描かない。
    function jmaIcon(code: string | number, size = 36): HTMLImageElement | null {
      const url = jmaIconUrl(code);
      if (!url) return null;
      const img = document.createElement("img");
      img.src = url;
      img.width = size; img.height = size; img.alt = ""; img.className = "mx-auto";
      // TELOPS にあっても万一 404 のときは保険で非表示（null耐性と整合）
      img.onerror = () => { img.style.display = "none"; };
      return img;
    }

    function fmtDate(iso: string): string {
      const d = new Date(iso + "T00:00:00+09:00");
      return `${d.getMonth() + 1}/${d.getDate()}(${DOW[d.getDay()]})`;
    }

    function fmtClock(iso: string): string {
      const d = new Date(iso);
      const p = (n: number) => String(n).padStart(2, "0");
      return `${d.getMonth() + 1}/${d.getDate()} ${p(d.getHours())}:${p(d.getMinutes())}`;
    }

    async function fetchJson(url: string): Promise<Json> {
      const r = await fetch(url, { cache: "default" });
      const d = await r.json();
      if (!d.ok) throw new Error("ok:false");
      return d;
    }

    // ── A1：直近予報 ─────────────────────────────────────────────
    function renderA1(forecast: Json | null): void {
      if (!forecast) return;

      // 今日
      const today = forecast.today;
      if (today) {
        setText("a1-today-date", fmtDate(today.date));
        const iconEl = getEl("a1-today-icon");
        if (iconEl && today.weather_code) {
          const icon = jmaIcon(today.weather_code, 44);
          if (icon) iconEl.replaceChildren(icon);
        }
        setText("a1-today-pop", today.pop != null ? String(today.pop) : "—");
        setText("a1-today-max", today.temp_max != null ? `${today.temp_max}°` : "—°");
        setText("a1-today-min", today.temp_min != null ? `${today.temp_min}°` : "—°");
        show("a1-today");
      }

      // 明日（weekly[0] は pop/temp が常に null。tomorrow ブロックを使う）
      const tomorrow = forecast.tomorrow;
      if (tomorrow) {
        setText("a1-tomorrow-date", fmtDate(tomorrow.date));
        const iconEl = getEl("a1-tomorrow-icon");
        if (iconEl && tomorrow.weather_code) {
          const icon = jmaIcon(tomorrow.weather_code, 44);
          if (icon) iconEl.replaceChildren(icon);
        }
        setText("a1-tomorrow-pop", tomorrow.pop != null ? String(tomorrow.pop) : "—");
        setText("a1-tomorrow-max", tomorrow.temp_max != null ? `${tomorrow.temp_max}°` : "—°");
        setText("a1-tomorrow-min", tomorrow.temp_min != null ? `${tomorrow.temp_min}°` : "—°");
        show("a1-tomorrow");
      }

      // 週間（weekly[0]=明日は描画しない。weekly[1] 以降を並べる）
      const weekly: Json[] = Array.isArray(forecast.weekly) ? forecast.weekly : [];
      const wrap = getEl("a1-weekly");
      if (wrap && weekly.length > 1) {
        wrap.replaceChildren();
        for (const day of weekly.slice(1)) {
          const card = document.createElement("div");
          card.className = "shrink-0 border border-zinc-200 bg-white p-3 text-center";
          card.style.width = "96px";
          const date = document.createElement("p");
          date.className = "text-xs text-zinc-400";
          date.textContent = fmtDate(day.date);
          const icon = document.createElement("div");
          icon.className = "my-2 flex h-9 items-center justify-center";
          if (day.weather_code) {
            const img = jmaIcon(day.weather_code, 32);
            if (img) icon.appendChild(img);
          }
          const pop = document.createElement("p");
          pop.className = "text-xs text-zinc-500";
          pop.textContent = day.pop != null ? `${day.pop}%` : "—";
          const temp = document.createElement("p");
          temp.className = "mt-1 text-xs";
          temp.innerHTML =
            `<span class="text-red-400">${day.temp_max != null ? day.temp_max + "°" : "—"}</span>` +
            ` / <span class="text-blue-400">${day.temp_min != null ? day.temp_min + "°" : "—"}</span>`;
          card.append(date, icon, pop, temp);
          wrap.appendChild(card);
        }
      }

      // 装備テキスト（advisory）は今回非表示。接続ポイント #a1-advisory のみ用意。
    }

    // ── A2：比較5地点カード ──────────────────────────────────────
    function renderA2(current: Json | null): void {
      const wrap = getEl("a2-cards");
      if (!wrap) return;
      if (!current?.stations) {
        wrap.innerHTML = `<p class="col-span-full text-sm text-zinc-400">周辺地点の取得に失敗しました。</p>`;
        return;
      }

      // 表示順：東京 / 埼玉 / 宇都宮 / 那須烏山 / 受付棟
      const order = [
        { key: "amedas_tokyo",     label: "東京" },
        { key: "amedas_saitama",   label: "埼玉" },
        { key: "amedas_utsunomiya", label: "宇都宮" },
        { key: "amedas_karasuyama", label: "那須烏山" },
        { key: "uketsuke",         label: "受付棟" },
      ];

      const baseTemp = current.stations?.uketsuke?.temp_c; // 都市比の基準＝受付棟
      wrap.replaceChildren();

      for (const { key, label } of order) {
        const st = current.stations[key];
        const card = document.createElement("div");
        card.className = "border border-zinc-200 bg-white p-4 text-center";

        const name = document.createElement("p");
        name.className = "text-xs tracking-[0.12em] text-zinc-400";
        name.textContent = st?.label ?? label;
        card.appendChild(name);

        // 天気アイコン（OpenWeather icon。実値があるのは現状 uketsuke のみ）
        const iconBox = document.createElement("div");
        iconBox.className = "my-2 flex h-9 items-center justify-center";
        if (st?.weather?.icon) {
          const img = document.createElement("img");
          img.src = `https://openweathermap.org/img/wn/${st.weather.icon}@2x.png`;
          img.width = 36; img.height = 36;
          img.alt = st.weather.text ?? "";
          img.loading = "lazy"; img.decoding = "async";
          iconBox.appendChild(img);
        }
        card.appendChild(iconBox);

        // 気温
        const temp = document.createElement("p");
        temp.className = "text-2xl font-semibold text-zinc-800";
        temp.innerHTML = (st?.temp_c != null)
          ? `${st.temp_c.toFixed(1)}<span class="text-xs text-zinc-400"> ℃</span>`
          : `<span class="text-zinc-300">—</span>`;
        card.appendChild(temp);

        // 都市比差分（受付棟基準。受付棟自身は基準なので出さない）
        if (key !== "uketsuke" && st?.temp_c != null && baseTemp != null) {
          const diff = st.temp_c - baseTemp;
          const sign = diff >= 0 ? "+" : "−";
          const d = document.createElement("p");
          d.className = "mt-1 text-xs text-zinc-400";
          d.textContent = `受付棟比 ${sign}${Math.abs(diff).toFixed(1)}℃`;
          card.appendChild(d);
        }

        wrap.appendChild(card);
      }

      // 季節コメント（seasonal_comment）は今回非表示。接続ポイント #a2-seasonal のみ用意。
    }

    // ── A3：警報・注意報 ─────────────────────────────────────────
    function renderA3(warning: Json | null): void {
      const wrap = getEl("a3-warnings");
      if (!wrap) return;
      if (!warning) {
        wrap.innerHTML = `<p class="text-zinc-400">警報・注意報の取得に失敗しました。</p>`;
        return;
      }

      const warnings: Json[] = Array.isArray(warning.warnings) ? warning.warnings : [];
      if (warnings.length === 0) {
        wrap.innerHTML = `<p class="text-zinc-400">現在、発表中の警報・注意報はありません。</p>`;
        return;
      }

      // level で3段階に出し分け（emergency / warning / advisory）
      const styleByLevel = (level: string) => {
        switch (level) {
          case "emergency":
            return "border-2 border-purple-600 bg-purple-50 text-purple-800 font-semibold";
          case "warning":
            return "border border-red-400 bg-red-50 text-red-700";
          default: // advisory
            return "border border-amber-400 bg-amber-50 text-amber-700";
        }
      };
      const rank = (level: string) =>
        level === "emergency" ? 0 : level === "warning" ? 1 : 2;

      const sorted = [...warnings].sort((a, b) => rank(a.level) - rank(b.level));

      wrap.replaceChildren();
      for (const w of sorted) {
        const span = document.createElement("span");
        const lv = String(w.level ?? "advisory");
        span.className = `mr-2 mb-2 inline-block px-3 py-1 text-xs ${styleByLevel(lv)}`;
        span.textContent = w.name ?? w.text ?? `コード ${w.code ?? "—"}`;
        wrap.appendChild(span);
      }
    }

    // ── A4：現地の今 ─────────────────────────────────────────────
    function renderA4(current: Json | null): void {
      const uketsuke = current?.stations?.uketsuke;
      const amedas   = current?.stations?.amedas_karasuyama;

      // --- 受付棟 ---
      const tempEl = getEl("a4-uketsuke-temp");
      const humEl  = getEl("a4-uketsuke-hum");
      const bodyEl = getEl("a4-uketsuke-body");
      const downEl = getEl("a4-uketsuke-down");
      const timeEl = getEl("a4-uketsuke-time");

      // 停止中判定：temp_c が null、または鮮度 1時間超
      const ukDown =
        !uketsuke || uketsuke.temp_c == null ||
        (uketsuke.age_seconds != null && uketsuke.age_seconds > STALE_DOWN_S);

      if (ukDown) {
        if (bodyEl) bodyEl.hidden = true;
        if (downEl) downEl.hidden = false;
      } else {
        if (bodyEl) bodyEl.hidden = false;
        if (downEl) downEl.hidden = true;
        if (tempEl) tempEl.textContent = uketsuke.temp_c.toFixed(1);
        if (humEl)  humEl.textContent  = uketsuke.humidity != null ? String(uketsuke.humidity) : "—";

        // 鮮度（20分超で警告色）と時刻スタンプ（強調）
        if (timeEl && uketsuke.observed_at) {
          timeEl.textContent = `${fmtClock(uketsuke.observed_at)} 観測`;
          timeEl.className =
            (uketsuke.age_seconds != null && uketsuke.age_seconds > STALE_WARN_S)
              ? "text-xs font-semibold text-amber-600"
              : "text-xs font-semibold text-zinc-600";
        }
      }

      // --- 那須烏山アメダス ---
      if (amedas) {
        setText("a4-amedas-temp", amedas.temp_c != null ? amedas.temp_c.toFixed(1) : "—");
        const wind = amedas.wind_speed_mps != null ? amedas.wind_speed_mps.toFixed(1) : "—";
        const wdir = amedas.wind_direction ?? "";
        setText("a4-amedas-wind", wdir ? `${wind}（${wdir}）` : wind);
        setText("a4-amedas-rain", amedas.rainfall_1h_mm != null ? String(amedas.rainfall_1h_mm) : "—");
        setText("a4-amedas-sun",  amedas.daylight_1h_h != null ? String(amedas.daylight_1h_h) : "—");
        const aTimeEl = getEl("a4-amedas-time");
        if (aTimeEl && amedas.observed_at) {
          aTimeEl.textContent = `${fmtClock(amedas.observed_at)} 観測`;
          aTimeEl.className =
            (amedas.age_seconds != null && amedas.age_seconds > STALE_WARN_S)
              ? "text-xs font-semibold text-amber-600"
              : "text-xs font-semibold text-zinc-600";
        }
      }

      // --- アメダス比の気温差分（受付棟 − 那須烏山アメダス） ---
      // 受付棟が落ちている場合は代替せず、差分も出さない（欠損は正直に）
      const diffEl = getEl("a4-uketsuke-diff");
      if (diffEl && !ukDown && uketsuke?.temp_c != null && amedas?.temp_c != null) {
        const diff = uketsuke.temp_c - amedas.temp_c;
        const sign = diff >= 0 ? "+" : "−";
        const note = diff < 0 ? "、林間で日陰多め" : "";
        diffEl.textContent = `アメダスより ${sign}${Math.abs(diff).toFixed(1)}℃${note}`;
        diffEl.hidden = false;
      } else if (diffEl) {
        diffEl.hidden = true;
      }
    }

    // ── A5：推移グラフ（自前インラインSVG） ─────────────────────
    const SVG_NS = "http://www.w3.org/2000/svg";
    type Point = { date: string; temp_c: number };

    // 期間切替時の再fetch。HTTPキャッシュ（max-age=3600）に委ね追加ポーリングなし。
    let a5CurrentRange = "1w";

    function svgEl(name: string, attrs: Record<string, string | number>): SVGElement {
      const el = document.createElementNS(SVG_NS, name);
      for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
      return el;
    }

    // series（date昇順の点群）を折れ線 path の d 文字列に変換
    function buildPath(
      points: Point[],
      xOf: (date: string) => number,
      yOf: (t: number) => number,
    ): string {
      return points
        .filter((p) => p.temp_c != null && !Number.isNaN(p.temp_c))
        .map((p, i) => `${i === 0 ? "M" : "L"}${xOf(p.date).toFixed(1)},${yOf(p.temp_c).toFixed(1)}`)
        .join(" ");
    }

    function drawTrend(data: Json): void {
      const svg = getEl("a5-svg");
      if (!svg) return;

      const reception: Point[] = Array.isArray(data?.series?.reception) ? data.series.reception : [];
      const amedas: Point[]    = Array.isArray(data?.series?.amedas) ? data.series.amedas : [];
      // normal（平年値）は現状 null。供給されたら3本目の線として描く接続ポイント。
      const normal: Point[]    = Array.isArray(data?.series?.normal) ? data.series.normal : [];

      svg.replaceChildren();

      // レイアウト
      const W = 720, H = 280;
      const padL = 36, padR = 12, padT = 12, padB = 28;

      // X軸：全系列の日付 union を昇順に
      const allDates = Array.from(
        new Set([...reception, ...amedas, ...normal].map((p) => p.date)),
      ).sort();
      // Y軸：全系列の気温 min-max
      const temps = [...reception, ...amedas, ...normal]
        .map((p) => p.temp_c)
        .filter((t) => t != null && !Number.isNaN(t));
      if (allDates.length === 0 || temps.length === 0) return;

      const minT = Math.floor(Math.min(...temps) - 1);
      const maxT = Math.ceil(Math.max(...temps) + 1);
      const dateIndex = new Map(allDates.map((d, i) => [d, i]));
      const xOf = (date: string) =>
        padL + (allDates.length === 1 ? 0 : ((dateIndex.get(date) ?? 0) / (allDates.length - 1)) * (W - padL - padR));
      const yOf = (t: number) =>
        H - padB - ((t - minT) / (maxT - minT || 1)) * (H - padT - padB);

      // Y軸グリッド（4本）
      for (let i = 0; i <= 4; i++) {
        const t = minT + ((maxT - minT) * i) / 4;
        const y = yOf(t);
        svg.appendChild(svgEl("line", { x1: padL, y1: y, x2: W - padR, y2: y, stroke: "#e5e7eb", "stroke-width": 1 }));
        const label = svgEl("text", { x: padL - 6, y: y + 3, "text-anchor": "end", "font-size": 10, fill: "#9ca3af" });
        label.textContent = `${t.toFixed(0)}°`;
        svg.appendChild(label);
      }

      // X軸ラベル（両端＋中央）
      const xTicks = allDates.length <= 1 ? [0] : [0, Math.floor((allDates.length - 1) / 2), allDates.length - 1];
      for (const idx of xTicks) {
        const d = allDates[idx];
        const mmdd = `${parseInt(d.slice(5, 7))}/${parseInt(d.slice(8, 10))}`;
        const label = svgEl("text", { x: xOf(d), y: H - 8, "text-anchor": "middle", "font-size": 10, fill: "#9ca3af" });
        label.textContent = mmdd;
        svg.appendChild(label);
      }

      // 平年線（normal）：供給時のみ描画＋凡例・サマリ枠を表示
      const legendNormal = getEl("a5-legend-normal");
      const normalSummary = getEl("a5-normal-summary");
      if (normal.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(normal, xOf, yOf),
          fill: "none", stroke: "#9ca3af", "stroke-width": 1.5, "stroke-dasharray": "4 3",
        }));
        if (legendNormal) legendNormal.hidden = false;
        // 平年比サマリの実値表示は今回スコープ外（normal 供給後にここで算出して出す）
        if (normalSummary) normalSummary.hidden = true;
      } else {
        if (legendNormal) legendNormal.hidden = true;
        if (normalSummary) normalSummary.hidden = true;
      }

      // アメダス（茶）
      if (amedas.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(amedas, xOf, yOf), fill: "none", stroke: "#b08968", "stroke-width": 2,
        }));
      }
      // 受付棟（緑）
      if (reception.length > 0) {
        svg.appendChild(svgEl("path", {
          d: buildPath(reception, xOf, yOf), fill: "none", stroke: "#2f6f4f", "stroke-width": 2,
        }));
      }
    }

    async function loadTrend(range: string): Promise<void> {
      const section = getEl("trend");
      try {
        const data = await fetchJson(`${API.timeseries}?range=${range}`);
        drawTrend(data);
        if (section) section.hidden = false; // 取得成功時のみ表示
      } catch (e) {
        // 取得失敗 → A5セクションごと非表示（他セクションは壊さない）
        if (section) section.hidden = true;
        console.warn("[A5 trend]", e);
      }
    }

    function syncRangeButtons(active: string): void {
      for (const btn of document.querySelectorAll<HTMLElement>(".a5-range-btn")) {
        const isActive = btn.dataset.range === active;
        btn.classList.toggle("border-zinc-600", isActive);
        btn.classList.toggle("text-zinc-800", isActive);
        btn.classList.toggle("font-semibold", isActive);
      }
    }

    function initTrend(): void {
      for (const btn of document.querySelectorAll<HTMLElement>(".a5-range-btn")) {
        btn.addEventListener("click", () => {
          const range = btn.dataset.range ?? "1w";
          a5CurrentRange = range;
          syncRangeButtons(range);
          loadTrend(range); // range 別に再fetch・再描画
        });
      }
      syncRangeButtons(a5CurrentRange);
      // 初回ロードは init() に一任（二重fetch回避）。初期 range は 1w。
    }

    // ── 全更新 ───────────────────────────────────────────────────
    async function init(): Promise<void> {
      const btn = getEl("btn-refresh") as HTMLButtonElement | null;
      if (btn) { btn.textContent = "更新中…"; btn.disabled = true; }

      const [curR, fcR, wnR] = await Promise.allSettled([
        fetchJson(API.current),
        fetchJson(API.forecast),
        fetchJson(API.warning),
      ]);

      const current  = curR.status === "fulfilled" ? curR.value : null;
      const forecast = fcR.status === "fulfilled" ? fcR.value : null;
      const warning  = wnR.status === "fulfilled" ? wnR.value : null;

      renderA1(forecast);
      renderA2(current);
      renderA3(warning);
      renderA4(current);
      // A5 は現在の選択 range で再取得（HTTPキャッシュに委任）
      loadTrend(a5CurrentRange);

      if (btn) { btn.textContent = "更新"; btn.disabled = false; }
    }

    getEl("btn-refresh")?.addEventListener("click", init);
    initTrend();
    init();
  </script>

</BaseLayout>
