---
import PageLayout from "../../layouts/PageLayout.astro";

const facilities = [
  { label: "トイレ",    value: "水洗（ライトフォレスト管理棟内）。ディープフォレスト内にはトイレ以外の場所での排泄厳禁。", avail: true  },
  { label: "水道・流し", value: "なし（炊事場不設置）。飲料水はライトフォレストで調達してください。",                  avail: false },
  { label: "直火",      value: "可。ただし立木の枯れ枝・積んである丸太の使用は厳禁。",                                avail: true  },
  { label: "火消し壺",  value: "持参必須（未持参の場合は利用不可）。受付にてレンタルあり（500円）。",                  avail: true  },
  { label: "AC電源",    value: "なし。発電機の持ち込み・使用禁止。",                                                    avail: false },
  { label: "駐車場",    value: "1予約につき1台まで広場駐車可（先着計4台）。以降は下駐車場を利用。",                    avail: true  },
  { label: "売店",      value: "なし（受付はライトフォレスト管理棟）。薪の持ち込み可。",                               avail: false },
  { label: "ゴミ",      value: "原則全て持ち帰り。灰のみライトフォレスト薪小屋の黒ペール缶（要蓋閉め）で引き取り可。",  avail: false },
];
---

<PageLayout title="ディープフォレスト 利用案内 | おいらの森">

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Deep Forest — 18+ Only</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">ディープフォレスト<br class="sm:hidden" /> 利用案内</h1>

    {/* 18歳以上の注意書き */}
    <div class="mt-5 border-l-2 border-zinc-400 pl-5">
      <p class="text-sm leading-loose text-zinc-700">
        <strong class="text-zinc-800">ディープフォレストは18歳以上限定のフィールドです。</strong><br />
        入場時に年齢確認書類（免許証・パスポート等）をご提示ください。未成年者の入場はいかなる理由でも不可です。
      </p>
    </div>

    <p class="mt-5 max-w-2xl text-base leading-loose text-zinc-600">
      樹齢80年のスギ・ヒノキが立ち並ぶ深い針葉樹林。直火、ブッシュクラフト、圧倒的な静寂。
      整備された快適さよりも、自然との真剣な対話を求める方のためのフィールドです。
    </p>
    <p class="mt-3 max-w-2xl text-sm leading-loose text-zinc-500">
      ライトフォレストから「車で約7分」の別の山脈にあります。場所は非公開のため、受付で案内を受けてください。
    </p>

    <nav class="mt-6 flex flex-wrap gap-3 text-sm">
      {[
        { href: "#checkin",  label: "チェックイン" },
        { href: "#checkout", label: "チェックアウト" },
        { href: "#facility", label: "設備・スペック" },
        { href: "#rules",    label: "禁止事項" },
        { href: "#principles", label: "基本4鉄則" },
      ].map((item) => (
        <a
          href={item.href}
          class="rounded-full border border-zinc-300 px-4 py-1.5 text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  {/* チェックイン */}
  <section id="checkin" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">チェックイン</h2>
    <dl class="divide-y divide-zinc-100 border-y border-zinc-200 text-sm">
      {[
        { label: "通常チェックイン",  value: "12:00〜17:00。受付場所はライトフォレスト管理棟。管理棟にて支払いと利用説明を受け、手続き完了となります。" },
        { label: "アーリーチェックイン", value: "09:00〜。エリアに余裕がある場合に限り可能、追加料金なし。前日までに電話または問い合わせフォームより要連絡。" },
        { label: "チェックインリミット", value: "17:00（厳守）。超過時は入場不可。連絡なき場合は無断キャンセル扱いとし、キャンセル料を請求します。遅れる場合は必ず連絡してください。" },
        { label: "直接入場特例",      value: "年間半年パスポート保持者のみ、管理棟を通らず直接入場可能です。" },
      ].map((item) => (
        <div class="grid grid-cols-[10rem_1fr] gap-4 py-5 sm:grid-cols-[14rem_1fr]">
          <dt class="text-zinc-500">{item.label}</dt>
          <dd class="text-zinc-700">{item.value}</dd>
        </div>
      ))}
    </dl>
  </section>

  {/* チェックアウト */}
  <section id="checkout" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">チェックアウト・延長</h2>
    <dl class="divide-y divide-zinc-100 border-y border-zinc-200 text-sm">
      {[
        { label: "通常チェックアウト", value: "12:00。専用のチェックアウトフォーム（HPアイコンクリック）より手続きを行ってください。管理棟へ寄る必要はありませんが、薪袋・バケツ等はライトフォレストへ返却してください。" },
        { label: "早朝出発",          value: "07:00前にチェックアウトする場合は事前にお知らせください。" },
        { label: "チェックアウト延長", value: "エリアに余裕がある場合に限り、17:00まで無料で滞在可能です。12:00前までにお知らせください。ライトフォレストとルールが異なるため混同しないよう注意してください。" },
      ].map((item) => (
        <div class="grid grid-cols-[10rem_1fr] gap-4 py-5 sm:grid-cols-[14rem_1fr]">
          <dt class="text-zinc-500">{item.label}</dt>
          <dd class="text-zinc-700">{item.value}</dd>
        </div>
      ))}
    </dl>
  </section>

  {/* 設備・スペック */}
  <section id="facility" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">設備・スペック</h2>
    <p class="mb-5 text-sm text-zinc-500">
      ディープフォレストの設備は意図的に最小限にとどめています。自然の中で完結する準備を整えてお越しください。
    </p>
    <dl class="divide-y divide-zinc-100 border-y border-zinc-200 text-sm">
      {facilities.map((item) => (
        <div class="grid grid-cols-[9rem_1fr] gap-4 py-4 sm:grid-cols-[12rem_1fr]">
          <dt class="flex items-center gap-2 text-zinc-500">
            <span
              class={`h-1.5 w-1.5 rounded-full shrink-0 ${item.avail ? "bg-[color:var(--forest-600)]" : "bg-zinc-300"}`}
            ></span>
            {item.label}
          </dt>
          <dd class="text-zinc-700">{item.value}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-6 border-l-2 border-amber-400 pl-5">
      <p class="text-sm font-semibold text-zinc-800">車両乗り入れについて</p>
      <p class="mt-2 text-sm leading-loose text-zinc-600">
        日没（18:00）以降の広場への車両乗り入れ、ドアの開閉、エンジン始動は禁止です。
        広場から先は車両進入禁止。傾斜がありキャリーカーの使用は困難なため、バックパックが便利です。
      </p>
    </div>
  </section>

  {/* 禁止事項 */}
  <section id="rules" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">禁止事項（厳守）</h2>

    <div class="grid gap-5 sm:grid-cols-2">
      {[
        {
          category: "音の制限",
          items: [
            "スピーカー、大きな音の出る行為",
            "大声での宴会",
            "発電機",
            "打ち上げ花火",
          ],
        },
        {
          category: "設営・作業",
          items: [
            "バトニング（薪割り）",
            "焚火のための穴掘り",
          ],
        },
        {
          category: "夜間行動",
          items: [
            "肝試し",
            "日没後の薪拾い",
            "目的のない「お散歩」",
          ],
        },
        {
          category: "環境破壊",
          items: [
            "樹木の損傷（立木の枯れ枝・積んである丸太の使用を含む）",
            "不法投棄",
          ],
        },
      ].map((section) => (
        <div class="border-t border-zinc-200 pt-5">
          <p class="mb-3 font-semibold text-zinc-700">{section.category}</p>
          <ul class="space-y-2">
            {section.items.map((item) => (
              <li class="flex items-start gap-2 text-sm leading-snug text-zinc-600">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-zinc-400"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  {/* 基本4鉄則 */}
  <section id="principles" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">この森の基本4鉄則</h2>
    <p class="mb-6 text-sm text-zinc-600">利用者が守るべき、この森の精神的基盤です。</p>

    <div class="divide-y divide-zinc-200 border-y border-zinc-200">
      {[
        "森の静寂と闇夜、自然の音を楽しむこと。",
        "現地で使用可能なものは「落葉・落枝」のみ。",
        "利用後は現状回復し、足跡以外の痕跡を残さないこと。",
        "トイレ以外の場所での排泄（野外排泄）は厳禁。",
      ].map((rule, i) => (
        <div class="grid grid-cols-[2rem_1fr] gap-4 py-5 text-sm">
          <p class="text-lg font-semibold text-zinc-200">{i + 1}</p>
          <p class="text-zinc-700">{rule}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ご利用ワンポイント */}
  <section class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">ご利用ワンポイント（重要事項）</h2>
    <p class="mb-5 text-sm text-zinc-600">一般的なキャンプ場との違いを認識の上、期待値を調整してお越しください。</p>

    <div class="grid gap-4 sm:grid-cols-2">
      {[
        { title: "異質の環境",   desc: "キャンプ場としての人工的な整備をしていないため、一般的なキャンプ場とは全く異なります。" },
        { title: "不便の許容",   desc: "基本的に不便な場所です。趣旨を理解の上でご利用ください。事前の下見を強く推奨します。" },
        { title: "場所は非公開", desc: "ライトフォレストから「車で約7分」の別の山脈にあります。場所は非公開のため、受付で案内を受けてください。" },
        { title: "無人管理",     desc: "ディープフォレストに管理人は常駐しません。受付はライトフォレストです。" },
        { title: "静寂の遵守",   desc: "グループで騒いだり、酒宴を楽しむ場所ではありません。お静かにお過ごしください。" },
        { title: "足元の備え",   desc: "雨後はぬかるみやすいため、長靴の携行を推奨します。" },
        { title: "装備の選択",   desc: "広場から先は車両進入禁止。傾斜がありキャリーカーの使用は困難なため、バックパックが便利です。" },
      ].map((item) => (
        <div class="border-t border-zinc-200 pt-5">
          <h3 class="text-sm font-semibold text-zinc-800">{item.title}</h3>
          <p class="mt-2 text-sm leading-loose text-zinc-600">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* 予約CTA */}
  <div class="mt-12 bg-[color:var(--forest-100)] px-8 py-10 text-center">
    <p class="text-sm text-zinc-500">ご予約・詳細料金の確認</p>
    <p class="mt-2 text-xl font-semibold text-zinc-800">予約はProX（予約システム）から</p>
    <p class="mt-3 text-sm leading-loose text-zinc-600">
      会員登録で複数プラン・複数日程の同時予約が可能です。
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-8 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
      >
        予約する ↗
      </a>
      <a
        href="/reservation-guide/"
        class="inline-flex items-center justify-center rounded-full border border-zinc-400 px-8 py-3 text-sm text-zinc-700 transition hover:border-zinc-600"
      >
        予約ガイドを見る
      </a>
    </div>
  </div>

</PageLayout>
