---
import PageLayout from "../../layouts/PageLayout.astro";

// TODO: 実際の料金に差し替え（S1=繁忙期 / S5=閑散期）
const seasons = [
  { id: "S1", label: "S1", note: "GW・お盆等" },
  { id: "S2", label: "S2", note: "土日祝・連休" },
  { id: "S3", label: "S3", note: "通常期" },
  { id: "S4", label: "S4", note: "閑散期" },
  { id: "S5", label: "S5", note: "最閑散期" },
];

// ディープは一律またはシンプルな料金体系
const sites = [
  { name: "ワイルドサイト（直火）", capacity: "1〜4名", prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
  { name: "ソロ静寂サイト",         capacity: "1名",    prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
];

const facilities = [
  { label: "トイレ",    value: "簡易水洗（男女共用）",          avail: true  },
  { label: "水場",      value: "あり（煮沸推奨）",              avail: true  },
  { label: "炊事場",    value: "なし（各サイトで完結）",        avail: false },
  { label: "AC電源",    value: "なし（発電機・大型蓄電池不可）", avail: false },
  { label: "駐車場",    value: "あり（サイト近接）",            avail: true  },
  { label: "シャワー",  value: "なし",                          avail: false },
  { label: "売店",      value: "薪のみ（要事前予約）",          avail: true  },
  { label: "ゴミ",      value: "持ち帰り（例外なし）",          avail: false },
];

const rules = [
  {
    category: "入場制限",
    items: [
      "18歳未満の入場は一切不可（年齢確認書類をご持参ください）",
      "入場時にスタッフが年齢確認を行います",
      "飲酒運転での来場は即時退場",
    ],
  },
  {
    category: "直火",
    items: [
      "指定の直火エリア内でのみ直火可",
      "風速10m/s以上の場合、スタッフの指示で焚き火禁止",
      "焚き火跡の処理は利用者の責任（灰は現地処理場へ）",
      "炭・薪・ゴミは持ち込み・持ち帰りを徹底",
    ],
  },
  {
    category: "静寂ルール",
    items: [
      "22:00〜翌6:00は完全な静寂時間",
      "発電機・大型蓄電池の持ち込み禁止",
      "音楽・動画の外部スピーカー再生禁止（イヤホン使用のこと）",
      "グループでの宴会的利用はご遠慮ください",
    ],
  },
  {
    category: "チェックイン・アウト",
    items: [
      "チェックイン：13:00〜18:00（遅延の場合は要連絡）",
      "チェックアウト：〜11:00（延長不可）",
      "深夜・早朝の入退場は周囲への配慮をお願いします",
    ],
  },
  {
    category: "ペット",
    items: [
      "可（リード着用必須）",
      "他の利用者のサイトへの侵入禁止",
      "鳴き声等で迷惑をかけた場合は退場をお願いする場合があります",
    ],
  },
  {
    category: "禁止事項",
    items: [
      "花火（打ち上げ・ロケット・爆竹）",
      "エンジン式発電機",
      "チェーンソー等の動力工具",
      "立ち入り禁止区域への侵入",
      "野生動物への餌付け",
    ],
  },
];
---

<PageLayout title="ディープフォレスト 利用案内 | おいらの森">

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Deep Forest — 18+ Only</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">ディープフォレスト<br class="sm:hidden" /> 利用案内</h1>

    {/* 18歳以上の注意書き（目立たせる） */}
    <div class="mt-5 flex items-start gap-3 rounded-xl border border-zinc-300 bg-zinc-50 px-5 py-4">
      <span class="mt-0.5 shrink-0 text-zinc-500">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </span>
      <p class="text-sm leading-loose text-zinc-600">
        <strong class="text-zinc-800">ディープフォレストは18歳以上限定のフィールドです。</strong><br />
        入場時に年齢確認書類（免許証・パスポート等）をご提示ください。未成年者の入場はいかなる理由でも不可です。
      </p>
    </div>

    <p class="mt-5 max-w-2xl text-base leading-loose text-zinc-600">
      樹齢80年のスギ・ヒノキが立ち並ぶ深い針葉樹林。直火、ブッシュクラフト、完全な静寂。
      整備された快適さよりも、自然との真剣な対話を求める方のためのフィールドです。
    </p>

    <nav class="mt-6 flex flex-wrap gap-3 text-sm">
      {[
        { href: "#price",    label: "料金" },
        { href: "#facility", label: "設備" },
        { href: "#rules",    label: "利用ルール" },
        { href: "#map",      label: "場内マップ" },
      ].map((item) => (
        <a href={item.href} class="rounded-full border border-zinc-300 px-4 py-1.5 text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800">
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  {/* 料金表 */}
  <section id="price" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">料金表</h2>
    <p class="mb-5 text-sm text-zinc-500">
      5段階シーズナリティ（S1〜S5）での変動制。詳細・空き状況は予約ページをご確認ください。<br />
      {/* TODO: 実際の料金を入力 */}
      ●印は調整中の金額です。単位：円（税込・1泊）
    </p>

    <div class="overflow-x-auto rounded-xl border border-zinc-200">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-200 bg-zinc-50">
            <th class="px-4 py-3 text-left font-medium text-zinc-600 whitespace-nowrap">サイト種別</th>
            <th class="px-3 py-3 text-center font-medium text-zinc-600 whitespace-nowrap">定員</th>
            {seasons.map((s) => (
              <th class="px-3 py-3 text-center font-medium text-zinc-600 whitespace-nowrap">
                {s.id}
                <span class="block text-[10px] font-normal text-zinc-400">{s.note}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          {sites.map((site) => (
            <tr class="hover:bg-zinc-50 transition">
              <td class="px-4 py-3 font-medium text-zinc-700 whitespace-nowrap">{site.name}</td>
              <td class="px-3 py-3 text-center text-zinc-500 whitespace-nowrap">{site.capacity}</td>
              {site.prices.map((p) => (
                <td class="px-3 py-3 text-center text-zinc-700 whitespace-nowrap">{p}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-zinc-400">※ 1サイト・1泊あたりの利用料。薪等の追加料金は別途。</p>

    <div class="mt-5">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-7 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
      >
        空き状況・予約はこちら ↗
      </a>
    </div>
  </section>

  {/* 設備 */}
  <section id="facility" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">設備</h2>
    <p class="mb-5 text-sm text-zinc-500">
      ディープフォレストの設備は意図的に最小限にとどめています。自然の中で完結する準備を整えてお越しください。
    </p>
    <dl class="divide-y divide-zinc-100 rounded-xl border border-zinc-200 overflow-hidden text-sm">
      {facilities.map((item) => (
        <div class="grid grid-cols-[9rem_1fr] gap-4 px-5 py-4 sm:grid-cols-[12rem_1fr]">
          <dt class="flex items-center gap-2 text-zinc-500">
            <span class={`h-1.5 w-1.5 rounded-full shrink-0 ${item.avail ? "bg-green-500" : "bg-zinc-300"}`}></span>
            {item.label}
          </dt>
          <dd class="text-zinc-700">{item.value}</dd>
        </div>
      ))}
    </dl>
  </section>

  {/* 利用ルール */}
  <section id="rules" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">利用ルール</h2>
    <p class="mb-6 text-sm text-zinc-500">
      ディープフォレストのルールはライトフォレストより厳格です。すべてのルールへの同意が利用の条件となります。
    </p>
    <div class="grid gap-5 sm:grid-cols-2">
      {rules.map((section) => (
        <div class="rounded-xl border border-zinc-200 p-5">
          <p class="mb-3 text-sm font-semibold text-zinc-700">{section.category}</p>
          <ul class="space-y-2">
            {section.items.map((item) => (
              <li class="flex items-start gap-2 text-sm leading-snug text-zinc-600">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-zinc-400"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="mt-5 text-sm text-zinc-500">
      ルール違反が確認された場合、退場・以降の予約キャンセルをお願いする場合があります。
      詳細は<a href="/policy/#terms" class="underline hover:text-zinc-800 transition">利用規約</a>をご確認ください。
    </p>
  </section>

  {/* 場内マップ */}
  <section id="map" class="mb-10">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">場内マップ</h2>
    {/* TODO: /public/images/map/deep-map.jpg を配置して img タグに差し替え */}
    <div class="flex min-h-[320px] items-center justify-center rounded-2xl border-2 border-dashed border-zinc-300 bg-zinc-50">
      <p class="text-sm text-zinc-400">ディープフォレスト 場内マップ（画像）を配置予定</p>
    </div>
    <p class="mt-3 text-xs text-zinc-400">※ 詳細マップは受付時にお渡しします。</p>
  </section>

  {/* 予約CTA */}
  <div class="mt-12 rounded-2xl bg-[color:var(--forest-100)] px-8 py-10 text-center">
    <p class="text-sm text-zinc-500">ご予約・詳細料金の確認</p>
    <p class="mt-2 text-xl font-semibold text-zinc-800">予約はProX（予約システム）から</p>
    <p class="mt-3 text-sm leading-loose text-zinc-600">
      会員登録で複数プラン・複数日程の同時予約が可能です。
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-8 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
      >
        予約する ↗
      </a>
      <a
        href="/reservation-guide/"
        class="inline-flex items-center justify-center rounded-full border border-zinc-400 px-8 py-3 text-sm text-zinc-700 transition hover:border-zinc-600"
      >
        予約ガイドを見る
      </a>
    </div>
  </div>

</PageLayout>
