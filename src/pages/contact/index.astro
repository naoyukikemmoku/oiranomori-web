---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
---
<BaseLayout title="お問い合わせ | 里山パークおいらの森" description="里山パークおいらの森へのお問い合わせはこちらから。ご予約・施設・その他何でもお気軽にどうぞ。TEL 050-3647-1047。">
  <Header />
  <div class="min-h-screen bg-[#f4f5f2] pt-16 pb-24">
    <div class="mx-auto max-w-2xl px-5">
      <div class="pt-12 pb-10">
        <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Contact</p>
        <h1 class="mt-3 text-2xl font-semibold text-zinc-800 md:text-3xl">お問い合わせ</h1>
        <p class="mt-3 text-sm leading-loose text-zinc-500">ご予約・施設に関するご質問はこちらからどうぞ。<br />返信が必要な場合はメールアドレスをご記入ください。</p>
      </div>
      <form action="https://form.oiranomori.com/contact.php" method="POST" class="space-y-8">
        <input type="text" name="website" tabindex="-1" autocomplete="off" style="display:none" />
        <div class="space-y-1.5">
          <label for="name" class="block text-sm font-medium text-zinc-700">お名前<span class="ml-2 text-xs text-zinc-400">任意・匿名可</span></label>
          <input type="text" id="name" name="name" autocomplete="name" class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700" placeholder="山田 太郎" />
        </div>
        <div class="space-y-1.5">
          <label for="email" class="block text-sm font-medium text-zinc-700">メールアドレス<span class="ml-2 text-xs text-zinc-400">任意・返信が必要な場合</span></label>
          <input type="email" id="email" name="email" autocomplete="email" class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700" placeholder="example@mail.com" />
        </div>
        <div class="space-y-1.5">
          <label for="subject" class="block text-sm font-medium text-zinc-700">件名<span class="ml-2 text-xs text-zinc-400">必須</span></label>
          <input type="text" id="subject" name="subject" required class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700" placeholder="例：設備について" />
        </div>
        <div class="space-y-1.5">
          <label for="message" class="block text-sm font-medium text-zinc-700">お問い合わせ内容<span class="ml-2 text-xs text-zinc-400">必須</span></label>
          <textarea id="message" name="message" rows="6" required class="block w-full border-b border-zinc-400 bg-transparent py-2.5 text-sm text-zinc-800 placeholder-zinc-300 outline-none transition focus:border-zinc-700 resize-none" placeholder="ご質問・ご意見・ご要望などをご記入ください。"></textarea>
        </div>
        <div class="pt-4">
          <button type="submit" class="inline-flex items-center gap-2 border border-[color:var(--forest-700)] bg-[color:var(--forest-700)] px-8 py-3 text-sm tracking-[0.1em] text-white transition hover:bg-[color:var(--forest-600)]">送信する<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg></button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>
