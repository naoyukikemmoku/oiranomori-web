---
import LpLayout from "../../layouts/LpLayout.astro";
import { Image } from "astro:assets";
import deepHeroImg       from "../../assets/images/deep_hero.jpg";
import deepSilentImg     from "../../assets/images/deep_silentforest.JPEG";
import deepNightImg      from "../../assets/images/deep_night.JPEG";
import deepFaceImg       from "../../assets/images/deep_face.JPEG";
import deepAnimalImg     from "../../assets/images/deep_animal.JPEG";

const experiences = [
  {
    no: "01",
    title: "耳がキーンとするほどの静寂",
    desc: "日常から切り離された場所にだけ存在する、完全な静寂。スピーカーも、エンジン音も、他人の声も届かない。ただ、風と葉擦れと、自分の呼吸だけ。",
    img: deepSilentImg,
    alt: "静まり返ったおいらの森ディープフォレストの針葉樹林",
  },
  {
    no: "02",
    title: "本物の闇に包まれる夜",
    desc: "街灯も、コンビニの灯りも届かない深い森の夜。目が慣れるまで、真っ暗な闇がある。炎の明かりがいかに人を安心させるかを、ここで初めて知る人がいる。",
    img: deepNightImg,
    alt: "焚火の灯だけが揺れるディープフォレストの野営地の夜",
  },
  {
    no: "03",
    title: "変化する森の表情",
    desc: "朝霧の中で目覚め、木漏れ日の下で朝を過ごし、夕暮れに樹齢80年以上のスギが金色に染まるのを見る。同じ場所が、何度も別の場所になる。",
    img: deepFaceImg,
    alt: "朝霧と木漏れ日が交錯するディープフォレストの森の表情",
  },
  {
    no: "04",
    title: "野生との境界線",
    desc: "獣道があり、夜には生き物の気配がある。人間が手を加えていない自然の中に立つこと。それだけで、日常の感覚が少し変わって帰ってくる。",
    img: deepAnimalImg,
    alt: "おいらの森ディープフォレストに生きる野生動物の気配",
  },
];
---

<LpLayout
  title="ディープフォレスト（野営・直火サイト） | 里山パークおいらの森"
  description="18歳以上限定・全面直火可のディープフォレスト。樹齢80年の針葉樹林で野営やブッシュクラフトに没頭できる、コアキャンパー向けのフィールドです。"
>

  {/* Hero */}
  <section
    id="top"
    class="relative flex min-h-[90vh] items-center"
  >
    <Image
      src={deepHeroImg}
      alt="栃木県那須烏山 おいらの森ディープフォレスト 樹齢80年のスギ・ヒノキが立ち並ぶ野営地"
      width={1920}
      height={1080}
      quality={80}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-5 py-28">
      <p class="text-xs tracking-[0.32em] text-zinc-400 uppercase">Deep Forest</p>
      <h1 class="mt-5 text-4xl font-semibold leading-tight text-white md:text-6xl">
        この雰囲気は、<br />いかないとわからない。
      </h1>
      <p class="mt-7 max-w-2xl text-base leading-loose text-zinc-300 md:text-lg">
        太平洋戦争で荒廃した日本の森を回復させるため、国策で植えられたスギ・ヒノキたち。
        それから約80年が経過した今、ディープフォレストの木々は大きなもので直径50cm、樹高25mを超え、
        整然と、しかし圧倒的な密度でそびえ立っています。
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full border border-white/50 bg-white/10 px-7 py-3 text-sm text-white backdrop-blur-sm transition hover:bg-white hover:text-zinc-900"
        >
          予約する
        </a>
        <a
          href="#experiences"
          class="inline-flex items-center justify-center rounded-full border border-white/30 px-7 py-3 text-sm text-white/80 transition hover:border-white/60 hover:text-white"
        >
          この森の体験
        </a>
      </div>
      <a
        href="/deep-guide/"
        class="mt-4 inline-block text-xs tracking-[0.2em] text-zinc-500 transition hover:text-zinc-300"
      >
        ディープフォレスト 利用案内 →
      </a>
    </div>
    <span class="absolute bottom-8 right-8 z-10 text-xs uppercase tracking-[0.22em] text-zinc-400 after:ml-3 after:inline-block after:h-9 after:w-px after:bg-zinc-400/60 after:align-middle">
      Scroll
    </span>
  </section>

  {/* Concept */}
  <section class="bg-[color:var(--forest-700)] py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Concept</p>
      <h2 class="mt-5 text-3xl font-semibold text-white md:text-4xl">
        樹齢80年以上のスギ・ヒノキが創り出す、<br />圧倒的な静寂と闇。
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-loose text-zinc-400">
        ディープフォレストは、コンビニも整備された炊事場もない。あるのは深い森と、直火と、静寂だけ。
        「キャンプ」ではなく「野営」を求める人のためのフィールドです。
      </p>
      <p class="mt-4 text-xs text-zinc-600">2023年、ヒロシのぼっちキャンプ（テレビ東京 Season6 #127/#128）のロケ地として使用されました。</p>
    </div>
  </section>

  {/* 4 Experiences */}
  <section id="experiences" class="bg-[color:var(--forest-700)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Experiences</p>
      <h2 class="mt-4 text-3xl font-semibold text-white md:text-4xl">4つの情緒的体験</h2>

      <div class="mt-12 grid gap-1 sm:grid-cols-2">
        {experiences.map((item) => (
          <div class="group relative overflow-hidden" style="aspect-ratio:4/3;">
            <Image
              src={item.img}
              alt={item.alt}
              width={800}
              height={600}
              quality={80}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 p-6">
              <p class="text-2xl font-semibold text-zinc-700">{item.no}</p>
              <h3 class="mt-1 text-base font-semibold text-white">{item.title}</h3>
              <p class="mt-2 text-xs leading-loose text-zinc-400">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 4 Iron Rules */}
  <section class="bg-[color:var(--forest-600)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Principles</p>
      <h2 class="mt-4 text-3xl font-semibold text-white md:text-4xl">基本の4鉄則</h2>
      <p class="mt-4 text-sm text-zinc-500">この森を利用するすべての者が守る、精神的基盤。</p>

      <dl class="mt-10 divide-y divide-zinc-700 border-t border-b border-zinc-700">
        {[
          "森の静寂と闇夜、自然の音を楽しむこと。",
          "現地で使用可能なものは「落葉・落枝」のみ。",
          "利用後は現状回復し、足跡以外の痕跡を残さないこと。",
          "野グソ禁止。トイレ以外での排泄は厳禁。",
        ].map((rule, i) => (
          <div class="grid grid-cols-[2rem_1fr] gap-4 py-5 text-sm sm:grid-cols-[3rem_1fr]">
            <dt class="text-xl font-semibold text-zinc-600">{i + 1}</dt>
            <dd class="text-zinc-300">{rule}</dd>
          </div>
        ))}
      </dl>

      <p class="mt-6 text-right">
        <a
          href="/deep-guide/"
          class="text-xs tracking-[0.2em] text-zinc-500 transition hover:text-zinc-300"
        >
          詳細な利用案内を見る →
        </a>
      </p>
    </div>
  </section>

  {/* ビジュアルブレイク */}
  <div class="relative h-[300px] overflow-hidden">
    <img
      src="/images/lp/scene-01.jpg"
      alt="ディープフォレストの深い森"
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  {/* Specs & Rules summary */}
  <section class="bg-[color:var(--forest-700)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Rules & Info</p>
      <h2 class="mt-4 text-3xl font-semibold text-white md:text-4xl">利用規定・基本情報</h2>

      <dl class="mt-10 divide-y divide-zinc-700 border-t border-b border-zinc-700">
        {[
          { label: "利用制限",         value: "18歳以上のみ（入場時に年齢確認書類を提示）" },
          { label: "チェックイン",     value: "12:00〜17:00（ライトフォレスト管理棟にて受付）" },
          { label: "チェックアウト",   value: "12:00（空きがある場合、17:00まで無料延長可）" },
          { label: "直火・焚き火",     value: "可（枯れた木の伐採、丸太の使用はご遠慮ください）" },
          { label: "火消し壺",         value: "持参必須。レンタルあり（¥500）" },
          { label: "ゴミ",             value: "原則全て持ち帰り（灰のみ指定ペール缶可）" },
          { label: "発電機・スピーカー", value: "禁止" },
          { label: "場所",             value: "非公開。受付にて案内（ライトフォレストから車で約7分）" },
        ].map((item) => (
          <div class="grid grid-cols-[9rem_1fr] gap-4 py-4 text-sm sm:grid-cols-[12rem_1fr]">
            <dt class="text-zinc-500">{item.label}</dt>
            <dd class="text-zinc-300">{item.value}</dd>
          </div>
        ))}
      </dl>

      <p class="mt-6">
        <a
          href="/deep-guide/"
          class="text-xs tracking-[0.2em] text-zinc-500 underline transition hover:text-zinc-300"
        >
          ディープフォレスト 利用案内（詳細）→
        </a>
      </p>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-[color:var(--forest-700)] py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <p class="text-xs tracking-[0.28em] text-zinc-600 uppercase">Reserve</p>
      <h2 class="mt-5 text-3xl font-semibold text-white md:text-4xl">深い森へ、踏み込む準備はできたか。</h2>
      <p class="mt-5 text-sm leading-loose text-zinc-500">
        空き状況の確認・詳細料金は予約ページから。<br />
        会員登録で複数プランの同時予約が可能です。
      </p>
      <div class="mt-10">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full border border-white/40 bg-white/10 px-10 py-4 text-sm text-white backdrop-blur-sm transition hover:bg-white hover:text-zinc-900"
        >
          予約ページへ進む
        </a>
      </div>
    </div>
  </section>

</LpLayout>
