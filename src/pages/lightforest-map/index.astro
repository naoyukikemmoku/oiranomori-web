---
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

// 場内マップ（ライトフォレスト）データ源 = App 公開API。HP側に点データは持たない。
// properties（sites_geojson.php 契約）: site_id(=site_no) / site_name / area /
//   site_type(=stock_type) / width / depth / area_sqm / usable_area_sqm /
//   site_category / sizeclass / parking_space / carside_tarp / drainage /
//   popularity / peg_type / module（＋App側で notes 追加予定）。
// popup の各属性は「値がある時だけ表示」（QGISから投入され次第 自動表示）。
const GEOJSON_URL = "https://oiranomori.com/app/camp/api/sites_geojson.php";

// ベースタイル（最下層）。未供給のため地理院標準タイルを使用。
const TILE_URL = ""; // 例: "https://example.com/ortho/{z}/{x}/{y}.png"
const FALLBACK_TILE_URL =
	"https://cyberjapandata.gsi.go.jp/xyz/std/{z}/{x}/{y}.png";

// ライトフィールド場内マップ背景（ジオリファ済みイラスト地図のXYZタイル）。
// QGIS「XYZタイルを生成」由来。site/public/lightmap/{z}/{x}/{y}.png に静的配置。
// XYZ（左上原点・tms:false）/ z15〜21 が実タイル / Webメルカトル(EPSG:3857)再投影済み。
const LIGHTFIELD = {
	url: "/lightmap/{z}/{x}/{y}.png",
	minZoom: 15,
	maxNativeZoom: 21, // 実タイル上限
	maxZoom: 22, // 21超はオーバーズームで伸ばす
	// bounds（WGS84・[[南,西],[北,東]]）。範囲外タイルの404抑制 + 初期fitBounds用。
	bounds: [
		[36.639041, 140.065615],
		[36.641562, 140.069752],
	],
};

// マーカー色分けは site_category（オート / 区画）ベース。
//   オート → #488B37 / 区画 → #C8A063 / その他・未設定 → default
const SITE_COLORS = {
	オート: "#488B37",
	区画: "#C8A063",
	default: "#4a5d4e",
};

const DEFAULT_CENTER = { lat: 36.6405, lng: 140.068 };
const DEFAULT_ZOOM = 17;
---

<BaseLayout
  title="場内マップ（ライトフォレスト）| 里山パークおいらの森"
  description="ライトフォレストの場内マップ。オートサイト・区画サイトの位置関係や各区画の広さ・設備を地図上でご確認いただけます。"
  lastUpdated="2026年6月"
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["TouristAttraction", "Place"],
      "name": "里山パークおいらの森 ライトフォレスト 場内マップ",
      "description": "栃木県那須烏山市の里山キャンプ場ライトフォレストの場内マップ。各サイトの位置関係を表示。",
      "url": "https://oiranomori.jp/lightforest-map/",
      "hasMap": "https://oiranomori.jp/lightforest-map/",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.6405,
        "longitude": 140.0680
      },
      "address": {
        "@type": "PostalAddress",
        "postalCode": "321-0525",
        "addressRegion": "栃木県",
        "addressLocality": "那須烏山市",
        "streetAddress": "福岡1047"
      },
      "containedInPlace": {
        "@type": "AdministrativeArea",
        "name": "那須烏山市"
      }
    })} />
  </Fragment>

  <Header />
  <h1 class="sr-only">場内マップ（ライトフォレスト）</h1>

  <main id="lfmap-main">
    <div id="lfmap-wrapper">
      <div id="lfmap-skeleton" aria-hidden="true">
        <svg class="spin-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
        <span>読み込み中</span>
      </div>
      <div id="lfmap-error">
        <p>マップの読み込みに失敗しました</p>
      </div>
      <div id="lfmap"></div>
    </div>
  </main>

</BaseLayout>

<style is:global>
/* ═══ Reset / global ═══ */
#lfmap-main *,
#lfmap-main *::before,
#lfmap-main *::after { box-sizing: border-box; }

/* ═══ Main ═══ */
#lfmap-main {
  height: 100vh;
  height: 100dvh;
  padding-top: var(--header-offset);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #f4f5f2;
}

/* ═══ Map wrapper ═══ */
#lfmap-wrapper {
  position: relative;
  flex: 1;
  overflow: hidden;
  background: #d1d5db;
  min-height: 0;
}
#lfmap { position: absolute; inset: 0; }

#lfmap-skeleton {
  position: absolute; inset: 0; z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: #e0e0dc;
  color: #9ca3af;
  font-size: 10px;
  letter-spacing: 0.2em;
}
.spin-icon { animation: spin 1.2s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

#lfmap-error {
  position: absolute; inset: 0; z-index: 1;
  display: none;
  align-items: center;
  justify-content: center;
  background: #1a2421;
  color: #c0c0c0;
  font-size: 12px;
  letter-spacing: 0.1em;
}

/* ═══ Leaflet popup override（白カード／枠線／影を排し、アーシー系に寄せる）═══ */
.leaflet-popup.lf-popup .leaflet-popup-content-wrapper {
  background: #f4f5f2;
  color: #1a2421;
  border-radius: 0;
  box-shadow: 0 2px 10px rgba(26, 36, 33, 0.25);
  border: none;
}
.leaflet-popup.lf-popup .leaflet-popup-content {
  margin: 12px 14px;
  font-family: "Noto Serif JP", serif;
  line-height: 1.5;
}
.leaflet-popup.lf-popup .leaflet-popup-tip {
  background: #f4f5f2;
  box-shadow: none;
}
.leaflet-popup.lf-popup a.leaflet-popup-close-button {
  color: #6b6b63;
  padding: 6px 8px 0 0;
}
.leaflet-popup.lf-popup a.leaflet-popup-close-button:hover {
  color: #1a2421;
}
.lf-pop-name {
  font-size: 14px;
  font-weight: 600;
  color: #1a2421;
}
.lf-pop-area {
  display: inline-block;
  margin-left: 6px;
  font-size: 11px;
  color: #8a8a80;
}
.lf-pop-meta {
  margin: 6px 0 0;
  font-size: 12px;
  color: #555;
  line-height: 1.6;
}
/* popup サブ（site_name 等） */
.lf-pop-sub {
  display: block;
  margin-top: 2px;
  font-size: 11px;
  color: #8a8a80;
}
/* popup 属性行（ラベル + 値） */
.lf-pop-rows {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #dcdcd4;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.lf-pop-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  font-size: 12px;
  line-height: 1.5;
}
.lf-pop-k {
  flex: 0 0 5.5em;
  color: #8a8a80;
}
.lf-pop-v {
  flex: 1;
  color: #2d3a30;
  min-width: 0;
}

/* マーカー（DivIcon） */
.lf-marker {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ═══ 現在地（GPS）コントロール ═══ */
.lf-loc-control a {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 5px;
  width: auto;
  min-width: 34px;
  height: 34px;
  padding: 0 10px;
  background: #fff;
  cursor: pointer;
  color: #2d3a30;
}
.lf-loc-control a:hover { background: #f5f5f5; }
.lf-loc-icon { display: inline-flex; align-items: center; }
.lf-loc-text {
  font-size: 12px;
  letter-spacing: 0.04em;
  white-space: nowrap;
  color: #2d3a30;
}
.lf-loc-err {
  display: none;
  position: absolute;
  right: 0;
  bottom: 40px;
  white-space: nowrap;
  background: rgba(26, 36, 33, 0.86);
  color: #fff;
  font-size: 11px;
  line-height: 1.4;
  padding: 4px 8px;
  border-radius: 3px;
}

/* 現在地の青ドット（divIcon） */
.lf-loc-dot { background: transparent; border: none; }
.lf-loc-dot-inner {
  display: block;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #4285f4;
  border: 2.5px solid #fff;
  box-shadow: 0 0 0 4px rgba(66, 133, 244, 0.25);
}
</style>

<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>

<script is:inline define:vars={{ GEOJSON_URL, TILE_URL, FALLBACK_TILE_URL, LIGHTFIELD, SITE_COLORS, DEFAULT_CENTER, DEFAULT_ZOOM }}>
  document.addEventListener("DOMContentLoaded", function () {
    var skeletonEl = document.getElementById("lfmap-skeleton");
    var errorEl    = document.getElementById("lfmap-error");

    function showError() {
      if (skeletonEl) skeletonEl.remove();
      if (errorEl) errorEl.style.display = "flex";
    }

    if (typeof L === "undefined") { showError(); return; }

    var map = L.map("lfmap", {
      center: [DEFAULT_CENTER.lat, DEFAULT_CENTER.lng],
      zoom:   DEFAULT_ZOOM,
      zoomControl: true,
    });

    // ── 重ね順: ベースタイル(tilePane z=200) → ライトフィールド背景(専用pane z=250) → サイト点(markerPane z=600)
    // 背景は tilePane と overlayPane(400) の間に専用 pane を作って載せ、重ね順を安定させる。
    map.createPane("lightfieldPane");
    map.getPane("lightfieldPane").style.zIndex = 250;
    map.getPane("lightfieldPane").style.pointerEvents = "none"; // 点クリックを妨げない

    // 最下層: ベースタイル。TILE_URL 未供給時は地理院標準タイルを暫定フォールバック。
    var tileUrl = TILE_URL || FALLBACK_TILE_URL;
    var usingFallback = !TILE_URL;
    L.tileLayer(tileUrl, {
      maxZoom: 22,
      maxNativeZoom: usingFallback ? 18 : 22,
      attribution: usingFallback
        ? '<a href="https://maps.gsi.go.jp/development/ichiran.html" target="_blank" rel="noopener">地理院タイル</a>'
        : "里山パークおいらの森",
    }).addTo(map);

    // 中間層: ライトフィールド場内マップ背景（静的XYZタイル）
    var lightfieldBounds = L.latLngBounds(LIGHTFIELD.bounds);
    L.tileLayer(LIGHTFIELD.url, {
      pane: "lightfieldPane",
      minZoom: LIGHTFIELD.minZoom,
      maxNativeZoom: LIGHTFIELD.maxNativeZoom,
      maxZoom: LIGHTFIELD.maxZoom,
      bounds: lightfieldBounds, // 範囲外タイルの404抑制
      tms: false, // XYZ（左上原点）
      attribution: "里山パークおいらの森",
    }).addTo(map);

    // 初期表示を場内（背景の範囲）にスナップ。点取得後に点範囲へ微調整する。
    map.fitBounds(lightfieldBounds, { padding: [20, 20] });

    // ── 現在地（GPS）表示 ──────────────────────────────
    // 携帯のGPSで自位置を青ドット＋精度円で表示。watchで移動に追従。
    (function () {
      var locDot = null;       // 現在地マーカー（divIcon）
      var locCircle = null;    // 精度円
      var watching = false;
      var firstFix = true;

      var SVG_NORMAL = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"'
        + ' stroke="#2d3a30" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'
        + '<circle cx="12" cy="12" r="4"/>'
        + '<line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>'
        + '<line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/></svg>';
      var SVG_LOADING = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"'
        + ' stroke="#4285f4" stroke-width="2.5" stroke-linecap="round"'
        + ' style="animation:spin 0.9s linear infinite;transform-origin:center;">'
        + '<path d="M12 3a9 9 0 1 0 9 9"/></svg>';
      var SVG_ACTIVE = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"'
        + ' stroke="#4285f4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'
        + '<circle cx="12" cy="12" r="4" fill="#4285f4"/>'
        + '<line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>'
        + '<line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/></svg>';

      // Leaflet カスタムコントロール（右下）
      var LocControl = L.Control.extend({
        options: { position: "bottomright" },
        onAdd: function () {
          var c = L.DomUtil.create("div", "leaflet-bar lf-loc-control");
          var btn = L.DomUtil.create("a", "", c);
          btn.href = "#";
          btn.title = "現在地を表示";
          btn.setAttribute("role", "button");
          btn.setAttribute("aria-label", "現在地を表示");
          // ⑥ アイコン + 「現在地」テキスト。アイコンだけ差し替えるため span に分離。
          var icon = L.DomUtil.create("span", "lf-loc-icon", btn);
          icon.innerHTML = SVG_NORMAL;
          var txt = L.DomUtil.create("span", "lf-loc-text", btn);
          txt.textContent = "現在地";
          this._btn = btn;
          this._icon = icon;
          this._err = L.DomUtil.create("div", "lf-loc-err", c);

          L.DomEvent.on(btn, "click", L.DomEvent.stop)
            .on(btn, "click", this._toggle, this);
          // コントロール上のドラッグ/スクロールが地図に伝播しないように
          L.DomEvent.disableClickPropagation(c);
          return c;
        },
        _showErr: function (msg) {
          this._err.textContent = msg;
          this._err.style.display = "block";
          var self = this;
          setTimeout(function () { self._err.style.display = "none"; }, 4000);
        },
        _toggle: function () {
          if (!navigator.geolocation) { this._showErr("非対応ブラウザ"); return; }
          if (watching) {
            // 2度押しで追従停止＋表示クリア
            map.stopLocate();
            watching = false;
            if (locDot) { map.removeLayer(locDot); locDot = null; }
            if (locCircle) { map.removeLayer(locCircle); locCircle = null; }
            this._icon.innerHTML = SVG_NORMAL;
            return;
          }
          this._icon.innerHTML = SVG_LOADING;
          firstFix = true;
          watching = true;
          // watch:true で移動に追従。enableHighAccuracy で携帯GPSを使う。
          map.locate({ watch: true, enableHighAccuracy: true, maximumAge: 5000, timeout: 15000 });
        },
        _onFound: function (e) {
          this._icon.innerHTML = SVG_ACTIVE;
          var dot = L.divIcon({
            className: "lf-loc-dot",
            html: '<span class="lf-loc-dot-inner"></span>',
            iconSize: [18, 18],
            iconAnchor: [9, 9],
          });
          if (!locDot) {
            locDot = L.marker(e.latlng, { icon: dot, zIndexOffset: 1000, interactive: false }).addTo(map);
          } else {
            locDot.setLatLng(e.latlng);
          }
          var acc = e.accuracy || 0;
          if (!locCircle) {
            locCircle = L.circle(e.latlng, {
              radius: acc, color: "#4285f4", weight: 1,
              fillColor: "#4285f4", fillOpacity: 0.12, interactive: false,
            }).addTo(map);
          } else {
            locCircle.setLatLng(e.latlng).setRadius(acc);
          }
          // 初回のみ自位置へ寄せる（以降は移動に追従しつつ勝手に画面を動かさない）
          if (firstFix) {
            firstFix = false;
            if (map.getZoom() < 18) map.setView(e.latlng, 19);
            else map.panTo(e.latlng);
          }
        },
        _onError: function (e) {
          watching = false;
          map.stopLocate();
          this._icon.innerHTML = SVG_NORMAL;
          var msg = (e && e.code === 1) ? "位置情報が許可されていません"
                  : (e && e.code === 2) ? "位置を取得できません" : "タイムアウトしました";
          this._showErr(msg);
        },
      });

      var locCtrl = new LocControl();
      map.addControl(locCtrl);
      map.on("locationfound", function (e) { locCtrl._onFound(e); });
      map.on("locationerror", function (e) { locCtrl._onError(e); });
    })();

    // site_type → 色
    // ① 色分けは site_category（オート / 区画）ベース
    function colorFor(siteCategory) {
      return SITE_COLORS[siteCategory] || SITE_COLORS.default;
    }

    // ② サイト番号マーカー：〇付き数字をやめ、site_id の値をテキストで表示
    function siteLabelIcon(label, color) {
      var s = label != null ? String(label) : "";
      // 文字数に応じてフォント・幅を調整（長い番号でも円内に収める）
      var fs = s.length >= 3 ? 9 : (s.length === 2 ? 11 : 13);
      var html =
        '<svg width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg">'
        + '<circle cx="14" cy="14" r="13" fill="' + color + '" stroke="rgba(255,255,255,0.85)" stroke-width="1.5"/>'
        + '<text x="14" y="14" text-anchor="middle" dominant-baseline="central"'
        + ' fill="white" font-family="\'Helvetica Neue\',Arial,sans-serif"'
        + ' font-weight="700" font-size="' + fs + '">' + escapeHtml(s) + '</text>'
        + '</svg>';
      return L.divIcon({
        className: "lf-marker",
        html: html,
        iconSize: [28, 28],
        iconAnchor: [14, 14],
        popupAnchor: [0, -14],
      });
    }

    // ③ トイレアイコン（site_type==="トイレ"）
    function toiletIcon() {
      var html =
        '<svg width="30" height="30" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg">'
        + '<circle cx="15" cy="15" r="14" fill="#3b5566" stroke="rgba(255,255,255,0.9)" stroke-width="1.5"/>'
        + '<text x="15" y="15" text-anchor="middle" dominant-baseline="central" font-size="15">🚻</text>'
        + '</svg>';
      return L.divIcon({
        className: "lf-marker",
        html: html,
        iconSize: [30, 30],
        iconAnchor: [15, 15],
        popupAnchor: [0, -15],
      });
    }

    // site_type がサイト点でない（設備）かどうか
    function isToilet(p) {
      return (p && p.site_type === "トイレ");
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;").replace(/'/g, "&#39;");
    }

    // 値が「実質空」か（"" / null / undefined / 数値0）を判定。0は未入力扱いで非表示。
    function hasVal(v) {
      if (v === null || v === undefined) return false;
      if (typeof v === "number") return v !== 0;
      return String(v).trim() !== "" && String(v).trim() !== "0";
    }

    // 1行（ラベル + 値）。値が空ならその行ごと省略。
    function popRow(label, value, unit) {
      if (!hasVal(value)) return "";
      var v = escapeHtml(value) + (unit || "");
      return '<div class="lf-pop-row">'
        + '<span class="lf-pop-k">' + label + "</span>"
        + '<span class="lf-pop-v">' + v + "</span>"
        + "</div>";
    }

    // ④ サイトpopup：タイトル=site_category + sizeclass、以下に属性を読みやすく配置
    function popupHtml(p) {
      p = p || {};

      // トイレ等の設備は簡素なpopup（名前のみ）
      if (isToilet(p)) {
        return '<span class="lf-pop-name">' + escapeHtml(p.site_name || "トイレ") + "</span>";
      }

      // タイトル: site_category & sizeclass（両方ある時は連結。片方でも可。無ければ site_name）
      var titleParts = [];
      if (hasVal(p.site_category)) titleParts.push(escapeHtml(p.site_category));
      if (hasVal(p.sizeclass)) titleParts.push(escapeHtml(p.sizeclass));
      var title = titleParts.length ? titleParts.join(" ") : escapeHtml(p.site_name || p.site_id || "サイト");

      // サブ: site_name（サイト1 等）を小さく添える
      var sub = hasVal(p.site_name) ? '<span class="lf-pop-sub">' + escapeHtml(p.site_name) + "</span>" : "";

      var rows = ""
        + popRow("面積", p.area_sqm, "㎡")
        + popRow("有効面積", p.usable_area_sqm, "㎡")
        + popRow("駐車スペース", p.parking_space)
        + popRow("カーサイドタープ", p.carside_tarp)
        + popRow("ペグ", p.peg_type)
        + popRow("水はけ", p.drainage)
        + popRow("人気度", p.popularity)
        + popRow("コメント", p.notes);

      var rowsHtml = rows ? '<div class="lf-pop-rows">' + rows + "</div>" : "";

      return '<span class="lf-pop-name">' + title + "</span>" + sub + rowsHtml;
    }

    // CORS: API は origin https://oiranomori.jp 限定許可。localhost 開発では弾かれ得る。
    // キャッシュ: API側 Cache-Control: public, max-age=300。多重fetchしない（1回のみ）。
    fetch(GEOJSON_URL)
      .then(function (r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function (geojson) {
        var layer = L.geoJSON(geojson, {
          // L.geoJSON は GeoJSON の [lng, lat] を自動で [lat, lng] に変換する
          pointToLayer: function (feature, latlng) {
            var p = (feature && feature.properties) || {};
            // ③ トイレはトイレアイコン
            if (isToilet(p)) {
              return L.marker(latlng, { icon: toiletIcon(), title: p.site_name || "トイレ" });
            }
            // ①② site_category 色 + site_id テキストマーカー
            var color = colorFor(p.site_category);
            return L.marker(latlng, {
              icon: siteLabelIcon(p.site_id, color),
              title: p.site_name || "",
            });
          },
          onEachFeature: function (feature, lyr) {
            var p = (feature && feature.properties) || {};
            lyr.bindPopup(popupHtml(p), { className: "lf-popup", closeButton: true });
          },
        }).addTo(map);

        if (skeletonEl) skeletonEl.remove();

        // 全点が収まるよう fitBounds（点が無ければ既定中心のまま）
        try {
          var b = layer.getBounds();
          if (b.isValid()) map.fitBounds(b, { padding: [40, 40], maxZoom: 18 });
        } catch (e) { /* noop */ }
      })
      .catch(function () { showError(); });
  });
</script>
