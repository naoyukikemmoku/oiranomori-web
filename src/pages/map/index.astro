---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import spotsRaw from "../../data/spots.json";

const API_KEY = import.meta.env.PUBLIC_GMAPS_API_KEY ?? "";

const CATEGORIES = [
  { key: "light",       label: "Light Forest" },
  { key: "food",        label: "食事" },
  { key: "bath",        label: "お風呂" },
  { key: "shopping",    label: "買い物" },
  { key: "sightseeing", label: "観光" },
  { key: "emergency",   label: "緊急・医療" },
] as const;

type Spot = { id: string; name: string; lat: number; lng: number; comment: string };

const spots: Record<string, Spot[]> = {};
for (const cat of CATEGORIES) {
  const raw = ((spotsRaw as any)[cat.key] as Spot[]) ?? [];
  spots[cat.key] = raw.filter((s) => s.name !== "" && s.lat !== 0 && s.lng !== 0);
}

const spotsJson = JSON.stringify(spots);
---

<BaseLayout
  title="マップ｜おいらの森"
  description="那須烏山・里山パークおいらの森の場内施設マップ、および周辺の食事・お風呂・買い物・観光・緊急スポットをご案内します。"
>

  <Header />

  <main class="min-h-screen bg-[#f4f5f2] pb-24 pt-[var(--header-offset)]">
    <div class="mx-auto max-w-5xl px-5">

      <div class="pt-10 pb-6">
        <p class="text-xs tracking-[0.28em] text-zinc-400 uppercase">Map</p>
        <h1 class="mt-3 text-2xl font-semibold text-zinc-800 md:text-3xl">マップ</h1>
        <p class="mt-2 text-sm text-zinc-500">場内の施設や周辺のおすすめスポットをご案内します。</p>
      </div>

      {/* タブ */}
      <div class="relative -mx-5 overflow-x-auto px-5 md:mx-0 md:px-0">
        <div id="tab-bar" class="flex min-w-max gap-0 border-b border-zinc-300">
          {CATEGORIES.map((cat) => (
            <button
              type="button"
              data-tab={cat.key}
              class="tab-btn relative shrink-0 px-4 py-3 text-sm tracking-wide text-zinc-500 transition hover:text-zinc-800"
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>

      {/* 準備中メッセージ */}
      <div id="no-data-msg" class="hidden mt-4 text-sm text-zinc-400 tracking-wide">
        このカテゴリは準備中です。
      </div>

      {/* マップ本体 */}
      <div class="relative mt-4 w-full overflow-hidden rounded-none" style="height:65vh; min-height:300px; max-height:720px;">

        {/* スケルトン */}
        <div
          id="map-skeleton"
          class="absolute inset-0 flex items-center justify-center bg-zinc-200"
          aria-hidden="true"
        >
          <div class="flex flex-col items-center gap-3 text-zinc-400">
            <svg class="animate-spin" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
            <span class="text-xs tracking-widest">読み込み中</span>
          </div>
        </div>

        {/* エラー */}
        <div
          id="map-error"
          class="absolute inset-0 hidden items-center justify-center bg-zinc-800 text-zinc-300"
        >
          <p class="text-sm tracking-wide">マップの読み込みに失敗しました</p>
        </div>

        {/* マップ */}
        <div id="map" class="absolute inset-0"></div>

      </div>

    </div>
  </main>

</BaseLayout>

<style>
  .tab-btn.is-active {
    color: #2d5a27;
    font-weight: 600;
  }
  .tab-btn.is-active::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: #2d5a27;
  }

  @media (min-height: 600px) {
    #map { height: 70vh; }
  }
</style>

<script define:vars={{ API_KEY, spotsJson }}>
  const spots = JSON.parse(spotsJson);

  const VALID_VIEWS = ["light", "food", "bath", "shopping", "sightseeing", "emergency"];
  const PIN_COLORS = {
    light:       "#2d5a27",
    food:        "#d4761e",
    bath:        "#3a8fa8",
    shopping:    "#7254b8",
    sightseeing: "#b83232",
    emergency:   "#7a0000",
  };
  const DEFAULT_CENTER = { lat: 36.6399, lng: 140.0684 };

  let gmap = null;
  let markers = [];
  let openInfoWindow = null;

  function getView() {
    const v = new URLSearchParams(window.location.search).get("view") ?? "light";
    return VALID_VIEWS.includes(v) ? v : "light";
  }

  function setTab(view) {
    document.querySelectorAll("[data-tab]").forEach(function(el) {
      el.classList.toggle("is-active", el.dataset.tab === view);
    });
    const noData = document.getElementById("no-data-msg");
    if (noData) {
      const hasSpots = (spots[view] ?? []).length > 0;
      noData.classList.toggle("hidden", hasSpots);
    }
  }

  function clearMarkers() {
    markers.forEach(function(m) { m.map = null; });
    markers = [];
    if (openInfoWindow) { openInfoWindow.close(); openInfoWindow = null; }
  }

  function makePinEl(color) {
    const el = document.createElement("div");
    el.style.cssText = [
      "width:22px", "height:22px",
      "border-radius:50% 50% 50% 0",
      "background:" + color,
      "border:2px solid #fff",
      "transform:rotate(-45deg)",
      "box-shadow:0 2px 6px rgba(0,0,0,.45)",
      "cursor:pointer",
    ].join(";");
    return el;
  }

  function showCategory(view) {
    if (!gmap) return;
    clearMarkers();
    const catSpots = spots[view] ?? [];
    if (catSpots.length === 0) {
      gmap.setCenter(DEFAULT_CENTER);
      gmap.setZoom(12);
      return;
    }
    const color = PIN_COLORS[view] ?? "#555";
    const bounds = new google.maps.LatLngBounds();
    let singlePos = null;
    catSpots.forEach(function(spot) {
      const pos = { lat: spot.lat, lng: spot.lng };
      singlePos = pos;
      const marker = new google.maps.marker.AdvancedMarkerElement({
        map: gmap,
        position: pos,
        content: makePinEl(color),
        title: spot.name,
      });
      marker.addListener("click", function() {
        if (openInfoWindow) openInfoWindow.close();
        const iw = new google.maps.InfoWindow({
          content: "<div style='font-family:sans-serif;max-width:200px;padding:2px 4px'>"
            + "<strong style='font-size:13px;color:#222'>" + spot.name + "</strong>"
            + (spot.comment
              ? "<p style='margin:5px 0 0;font-size:12px;color:#555;line-height:1.5'>" + spot.comment + "</p>"
              : "")
            + "</div>",
        });
        iw.open({ anchor: marker, map: gmap });
        openInfoWindow = iw;
      });
      markers.push(marker);
      bounds.extend(pos);
    });
    if (catSpots.length === 1) {
      gmap.setCenter(singlePos);
      gmap.setZoom(17);
    } else {
      gmap.fitBounds(bounds, 60);
    }
  }

  function switchTab(view) {
    setTab(view);
    history.pushState({ view: view }, "", "/map/?view=" + view);
    showCategory(view);
  }

  window.__initGoogleMaps = function() {
    google.maps.importLibrary("maps").then(function(mapsLib) {
      return google.maps.importLibrary("marker").then(function() {
        const mapEl = document.getElementById("map");
        gmap = new mapsLib.Map(mapEl, {
          center: DEFAULT_CENTER,
          zoom: 15,
          mapId: "DEMO_MAP_ID",
          zoomControl: true,
          mapTypeControl: false,
          streetViewControl: false,
          fullscreenControl: true,
        });
        const skeleton = document.getElementById("map-skeleton");
        if (skeleton) skeleton.remove();
        const view = getView();
        setTab(view);
        showCategory(view);
      });
    }).catch(function() {
      document.getElementById("map-skeleton")?.remove();
      const errEl = document.getElementById("map-error");
      if (errEl) errEl.style.display = "flex";
    });
  };

  document.addEventListener("DOMContentLoaded", function() {
    const initialView = getView();
    setTab(initialView);

    document.querySelectorAll("[data-tab]").forEach(function(el) {
      el.addEventListener("click", function() { switchTab(el.dataset.tab); });
    });

    window.addEventListener("popstate", function(e) {
      const view = (e.state && e.state.view) ? e.state.view : getView();
      setTab(view);
      showCategory(view);
    });

    if (!API_KEY) {
      document.getElementById("map-skeleton")?.remove();
      const errEl = document.getElementById("map-error");
      if (errEl) errEl.style.display = "flex";
      return;
    }

    const s = document.createElement("script");
    s.src = "https://maps.googleapis.com/maps/api/js?key=" + API_KEY
      + "&libraries=marker&v=weekly&loading=async&callback=__initGoogleMaps";
    s.async = true;
    document.head.appendChild(s);
  });
</script>
