---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const {
  title = "おいらの森",
  description = "栃木県那須烏山の里山にある『里山パークおいらの森』。100年先の森を育てながら、森で遊び、森に泊まる体験型キャンプ場です。",
  noindex = false,
} = Astro.props;

const BASE_URL = "https://oiranomori.jp";
const breadcrumbName = title.includes(" | ") ? title.split(" | ")[0].trim() : title;

const segmentLabels: Record<string, string> = {
  access:              "アクセス",
  about:               "運営会社・関連組織",
  checkout:            "チェックアウト連絡",
  contact:             "お問い合わせ",
  deep:                "ディープフォレスト",
  "deep-guide":        "ディープフォレスト 利用案内",
  faq:                 "よくある質問",
  firewood:            "こだわりの薪販売",
  "light-guide":       "ライトフォレスト 利用案内",
  map:                 "場内・周辺マップ",
  news:                "お知らせ",
  now:                 "森のいま",
  oiras:               "OIRAS",
  page:                "バックナンバー",
  passport:            "年間パスポート・回数券",
  policy:              "ご利用のルール",
  rental:              "レンタル",
  "reservation-guide": "予約ガイド",
  residents:           "森の住人",
  shop:                "売店",
  thanks:              "完了",
};

const pathSegments = Astro.url.pathname.split("/").filter(Boolean);

const breadcrumbJson = pathSegments.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "里山パークおいらの森", "item": BASE_URL },
    ...pathSegments.map((seg, i) => {
      const isLast = i === pathSegments.length - 1;
      const cumPath = "/" + pathSegments.slice(0, i + 1).join("/") + "/";
      const name = isLast ? breadcrumbName : (segmentLabels[seg] ?? seg);
      return { "@type": "ListItem", "position": i + 2, "name": name, "item": BASE_URL + cumPath };
    }),
  ],
}) : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? ""} />
    <meta property="og:image" content="https://oiranomori.jp/images/lp/hero.jpg" />
    <meta property="og:site_name" content="里山パークおいらの森" />
    <meta property="og:locale" content="ja_JP" />
    <!-- canonical -->
    <link rel="canonical" href={Astro.url.href} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <!-- BreadcrumbList -->
    {breadcrumbJson && <script is:inline type="application/ld+json" set:html={breadcrumbJson} />}
    <slot name="head" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-74NDHG8YJ7"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-74NDHG8YJ7');
    </script>
  </head>

  <body>
    <slot />

    <Footer />
  </body>
</html>
