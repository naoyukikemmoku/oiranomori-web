---
import LpLayout from "../../layouts/LpLayout.astro";

const plans = [
  {
    title: "ブッシュクラフトサイト",
    subtitle: "直火 / 野営",
    desc: "整備された設備に頼らず、自然そのものと向き合う区画。直火可、焚き火台不要。",
    image: "/images/lp/scene-01.jpg", // TODO: deep専用画像に差し替え
    href: "https://www.489pro-x.com/ja/s/oiranomori/planlist/",
  },
  {
    title: "ソロ静寂サイト",
    subtitle: "1名 / 孤独と静寂",
    desc: "樹齢80年のスギ・ヒノキに囲まれた、一人のための深い森。22時以降は完全な静寂が訪れる。",
    image: "/images/lp/scene-02.jpg", // TODO: deep専用画像に差し替え
    href: "https://www.489pro-x.com/ja/s/oiranomori/planlist/",
  },
  {
    title: "デュオ・ディープサイト",
    subtitle: "2名 / 焚き火",
    desc: "二人で焚き火を囲む夜。直火の炎と針葉樹の香りだけが記憶に残る。",
    image: "/images/lp/scene-03.jpg", // TODO: deep専用画像に差し替え
    href: "https://www.489pro-x.com/ja/s/oiranomori/planlist/",
  },
];

const specs = [
  { label: "利用制限", value: "18歳以上のみ（未成年者の入場不可）" },
  { label: "直火", value: "可（指定エリア内）" },
  { label: "焚き火台", value: "不要" },
  { label: "ペット", value: "可（リード着用・エリア制限あり）" },
  { label: "消灯・静寂", value: "22:00 厳守" },
  { label: "チェックイン", value: "13:00〜18:00" },
  { label: "チェックアウト", value: "〜11:00" },
];
---

<LpLayout title="ディープフォレスト | おいらの森キャンプ場">

  {/* Hero */}
  <section
    id="top"
    class="relative flex min-h-[90vh] items-center bg-cover bg-center"
    style="background-image:url('/images/lp/hero.jpg');"
  >
    {/* TODO: ディープ専用のhero画像に差し替え */}
    <div class="absolute inset-0 bg-black/65"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-5 py-28">
      <p class="text-xs tracking-[0.32em] text-zinc-400 uppercase">Deep Forest — 18+ / Direct Fire / Silence</p>
      <h1 class="mt-5 text-4xl font-semibold leading-tight text-white md:text-6xl">
        静寂の森へ、<br />道具を持って踏み込め。
      </h1>
      <p class="mt-7 max-w-2xl text-base leading-loose text-zinc-300 md:text-lg">
        樹齢80年のスギとヒノキが立ち並ぶ深い針葉樹林。<br />
        直火、ブッシュクラフト、完全な静寂——18歳以上限定の、本物の野営地。
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-white/10 border border-white/50 px-7 py-3 text-sm text-white backdrop-blur-sm transition hover:bg-white hover:text-zinc-900"
        >
          予約する
        </a>
        <a
          href="#plans"
          class="inline-flex items-center justify-center rounded-full border border-white/30 px-7 py-3 text-sm text-white/80 transition hover:border-white/60 hover:text-white"
        >
          プランを見る
        </a>
      </div>
      <a
        href="/deep-guide/"
        class="mt-4 inline-block text-xs tracking-[0.2em] text-zinc-500 hover:text-zinc-300 transition"
      >
        ディープフォレスト 利用案内 →
      </a>
    </div>
    <span class="absolute bottom-8 right-8 z-10 text-xs uppercase tracking-[0.22em] text-zinc-400 after:ml-3 after:inline-block after:h-9 after:w-px after:bg-zinc-400/60 after:align-middle">
      Scroll
    </span>
  </section>

  {/* Concept */}
  <section class="bg-[color:var(--forest-700)] py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Concept</p>
      <h2 class="mt-5 text-3xl font-semibold text-white md:text-4xl">
        自然との対話、<br />それだけを持ち帰れ。
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-loose text-zinc-400">
        ディープフォレストは、コンビニも整備された炊事場もない。あるのは深い森と、直火と、静寂だけ。
        「キャンプ」ではなく「野営」を求める人のためのフィールドです。
      </p>

      <div class="mt-12 grid gap-px border border-zinc-700 sm:grid-cols-3">
        {[
          { head: "直火", body: "焚き火台不要。地面に火を起こし、炎と向き合う原初の体験。" },
          { head: "静寂", body: "22時以降は発電機・音楽の使用禁止。針葉樹林が音を吸い込む夜。" },
          { head: "18歳以上限定", body: "未成年の入場は不可。自己責任と自然への敬意を持つ者だけに開かれた森。" },
        ].map((item) => (
          <div class="bg-[color:var(--forest-600)] p-8">
            <p class="text-xs tracking-[0.2em] text-zinc-500 uppercase">{item.head}</p>
            <p class="mt-4 text-sm leading-loose text-zinc-400">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Plans */}
  <section id="plans" class="bg-[color:var(--forest-700)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Plans</p>
      <h2 class="mt-4 text-3xl font-semibold text-white md:text-4xl">選りすぐりのプラン</h2>
      <p class="mt-3 text-sm text-zinc-500">すべてのプランは予約ページでご確認いただけます。</p>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {plans.map((plan) => (
          <a
            href={plan.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block overflow-hidden rounded-xl transition hover:opacity-90"
          >
            <figure class="aspect-[4/3] overflow-hidden">
              <img
                src={plan.image}
                alt={plan.title}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </figure>
            <div class="bg-[color:var(--forest-600)] p-5">
              <p class="text-[10px] tracking-[0.22em] text-zinc-500 uppercase">{plan.subtitle}</p>
              <h3 class="mt-2 text-lg font-semibold text-white">{plan.title}</h3>
              <p class="mt-2 text-sm leading-loose text-zinc-400">{plan.desc}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full border border-zinc-600 px-7 py-3 text-sm text-zinc-400 transition hover:border-zinc-400 hover:text-white"
        >
          すべてのプランを予約ページで確認する ↗
        </a>
      </div>
    </div>
  </section>

  {/* Specs & Rules */}
  <section class="bg-[color:var(--forest-600)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-5">
      <p class="text-xs tracking-[0.28em] text-zinc-500 uppercase">Rules & Info</p>
      <h2 class="mt-4 text-3xl font-semibold text-white md:text-4xl">利用規定・基本情報</h2>
      <p class="mt-3 text-sm leading-loose text-zinc-500">
        ディープフォレストは自然環境の保護と利用者の安全のため、いくつかのルールを設けています。<br />
        詳細は
        <a href="/deep-guide/" class="underline text-zinc-400 hover:text-zinc-200 transition">ディープフォレスト 利用案内</a>
        をご確認ください。
      </p>

      <dl class="mt-10 divide-y divide-zinc-700 border-t border-b border-zinc-700">
        {specs.map((item) => (
          <div class="grid grid-cols-[9rem_1fr] gap-4 py-4 text-sm sm:grid-cols-[12rem_1fr]">
            <dt class="text-zinc-500">{item.label}</dt>
            <dd class="text-zinc-300">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-[color:var(--forest-700)] py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-5 text-center">
      <p class="text-xs tracking-[0.28em] text-zinc-600 uppercase">Reserve</p>
      <h2 class="mt-5 text-3xl font-semibold text-white md:text-4xl">深い森へ、踏み込む準備はできたか。</h2>
      <p class="mt-5 text-sm leading-loose text-zinc-500">
        空き状況の確認・詳細料金は予約ページから。<br />
        会員登録で複数プランの同時予約が可能です。
      </p>
      <div class="mt-10">
        <a
          href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full border border-white/40 bg-white/10 px-10 py-4 text-sm text-white backdrop-blur-sm transition hover:bg-white hover:text-zinc-900"
        >
          予約ページへ進む
        </a>
      </div>
    </div>
  </section>

</LpLayout>
