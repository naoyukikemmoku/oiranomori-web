---
import PageLayout from "../../layouts/PageLayout.astro";

// TODO: 実際の料金に差し替え（S1=繁忙期 / S5=閑散期）
const seasons = [
  { id: "S1", label: "S1（最繁忙期）", note: "GW・お盆・年末年始など" },
  { id: "S2", label: "S2（繁忙期）",   note: "土日祝・連休" },
  { id: "S3", label: "S3（通常期）",   note: "平日・週末など" },
  { id: "S4", label: "S4（閑散期）",   note: "平日を中心とした時期" },
  { id: "S5", label: "S5（最閑散期）", note: "冬季平日など" },
];

const sites = [
  { name: "ファミリーサイト（AC電源付）", capacity: "〜6名", prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
  { name: "スタンダードサイト",           capacity: "〜4名", prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
  { name: "ソロサイト",                   capacity: "1名",   prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
  { name: "ハンモックサイト",             capacity: "1〜2名",prices: ["●,●●●", "●,●●●", "●,●●●", "●,●●●", "●,●●●"] },
];

const facilities = [
  { label: "トイレ",      value: "水洗（男女別）",              avail: true },
  { label: "炊事場",      value: "あり（流し台・かまど）",      avail: true },
  { label: "AC電源",      value: "一部サイトに設置",            avail: true },
  { label: "駐車場",      value: "無料（サイト横付け可）",      avail: true },
  { label: "シャワー",    value: "なし",                        avail: false },
  { label: "Wi-Fi",       value: "なし（自然の中でどうぞ）",    avail: false },
  { label: "売店",        value: "薪・着火剤など（現地購入可）", avail: true },
  { label: "ゴミ",        value: "持ち帰り",                    avail: false },
];

const rules = [
  { title: "チェックイン・アウト", body: "チェックイン 13:00〜18:00 / チェックアウト 〜11:00。時間外のご入場はご遠慮ください。" },
  { title: "焚き火",              body: "焚き火台の使用に限ります。直火は禁止です。炭・灰は現地の処理場へ。" },
  { title: "消灯・静寂時間",      body: "22:00〜翌6:00は静寂時間です。発電機・大音量の音楽の使用はご遠慮ください。" },
  { title: "ペット",              body: "可（リード着用必須）。フンの処理はオーナーの責任で行ってください。" },
  { title: "車の乗り入れ",        body: "サイトへの車横付けが可能です。ただし速度は徐行でお願いします。" },
  { title: "ゴミ",                body: "すべてお持ち帰りください。分別袋をご持参ください。" },
  { title: "子どもの利用",        body: "年齢制限なし。保護者の同伴をお願いします。" },
  { title: "禁止事項",            body: "花火（打ち上げ・ロケット）、大型発電機、サイト外の立ち入り禁止区域への侵入。" },
];
---

<PageLayout title="ライトフォレスト 利用案内 | おいらの森">

  {/* ページ見出し */}
  <div class="mb-10 border-b border-zinc-200 pb-8">
    <p class="text-xs tracking-[0.26em] text-zinc-400 uppercase">Light Forest</p>
    <h1 class="mt-3 text-3xl font-semibold text-zinc-800 md:text-4xl">ライトフォレスト<br class="sm:hidden" /> 利用案内</h1>
    <p class="mt-4 max-w-2xl text-base leading-loose text-zinc-600">
      コナラとクヌギに囲まれた明るい広葉樹林。AC電源付きサイトも完備し、はじめてのキャンプから
      ファミリーまで安心してご利用いただけます。
    </p>
    <nav class="mt-6 flex flex-wrap gap-3 text-sm">
      {[
        { href: "#price",    label: "料金" },
        { href: "#facility", label: "設備" },
        { href: "#rules",    label: "利用ルール" },
        { href: "#map",      label: "場内マップ" },
      ].map((item) => (
        <a href={item.href} class="rounded-full border border-zinc-300 px-4 py-1.5 text-zinc-600 transition hover:border-zinc-500 hover:text-zinc-800">
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  {/* 料金表 */}
  <section id="price" class="mb-14">
    <h2 class="mb-2 text-xl font-semibold text-zinc-800">料金表</h2>
    <p class="mb-5 text-sm text-zinc-500">
      料金は5段階のシーズナリティ（S1〜S5）で変動します。詳細・空き状況は予約ページをご確認ください。<br />
      {/* TODO: 実際の料金を入力 */}
      ●印は調整中の金額です。単位：円（税込・1泊）
    </p>

    {/* スクロール可能な横長テーブル */}
    <div class="overflow-x-auto rounded-xl border border-zinc-200">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-200 bg-zinc-50">
            <th class="px-4 py-3 text-left font-medium text-zinc-600 whitespace-nowrap">サイト種別</th>
            <th class="px-3 py-3 text-center font-medium text-zinc-600 whitespace-nowrap">定員</th>
            {seasons.map((s) => (
              <th class="px-3 py-3 text-center font-medium text-zinc-600 whitespace-nowrap">
                {s.id}
                <span class="block text-[10px] font-normal text-zinc-400">{s.note}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          {sites.map((site) => (
            <tr class="hover:bg-zinc-50 transition">
              <td class="px-4 py-3 font-medium text-zinc-700 whitespace-nowrap">{site.name}</td>
              <td class="px-3 py-3 text-center text-zinc-500 whitespace-nowrap">{site.capacity}</td>
              {site.prices.map((p) => (
                <td class="px-3 py-3 text-center text-zinc-700 whitespace-nowrap">{p}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-zinc-400">※ 上記は1サイト・1泊あたりの利用料です。ペット・薪等の追加料金は別途。</p>

    <div class="mt-5">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-7 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
      >
        空き状況・予約はこちら ↗
      </a>
    </div>
  </section>

  {/* 設備 */}
  <section id="facility" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">設備</h2>
    <dl class="divide-y divide-zinc-100 rounded-xl border border-zinc-200 overflow-hidden text-sm">
      {facilities.map((item) => (
        <div class="grid grid-cols-[9rem_1fr] gap-4 px-5 py-4 sm:grid-cols-[12rem_1fr]">
          <dt class="flex items-center gap-2 text-zinc-500">
            <span class={`h-1.5 w-1.5 rounded-full shrink-0 ${item.avail ? "bg-green-500" : "bg-zinc-300"}`}></span>
            {item.label}
          </dt>
          <dd class="text-zinc-700">{item.value}</dd>
        </div>
      ))}
    </dl>
  </section>

  {/* 利用ルール */}
  <section id="rules" class="mb-14">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">利用ルール</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {rules.map((rule) => (
        <div class="rounded-xl border border-zinc-200 p-5">
          <p class="mb-2 text-sm font-semibold text-zinc-700">{rule.title}</p>
          <p class="text-sm leading-loose text-zinc-600">{rule.body}</p>
        </div>
      ))}
    </div>
    <p class="mt-5 text-sm text-zinc-500">
      ルール違反が確認された場合、退場をお願いする場合があります。
      詳細は<a href="/policy/#terms" class="underline hover:text-zinc-800 transition">利用規約</a>をご確認ください。
    </p>
  </section>

  {/* 場内マップ */}
  <section id="map" class="mb-10">
    <h2 class="mb-5 text-xl font-semibold text-zinc-800">場内マップ</h2>
    {/* TODO: /public/images/map/light-map.jpg を配置して img タグに差し替え */}
    <div class="flex min-h-[320px] items-center justify-center rounded-2xl border-2 border-dashed border-zinc-300 bg-zinc-50">
      <p class="text-sm text-zinc-400">ライトフォレスト 場内マップ（画像）を配置予定</p>
    </div>
    <p class="mt-3 text-xs text-zinc-400">※ 場内の詳細マップは受付時にもお渡しします。</p>
  </section>

  {/* 予約CTA */}
  <div class="mt-12 rounded-2xl bg-[color:var(--forest-100)] px-8 py-10 text-center">
    <p class="text-sm text-zinc-500">ご予約・詳細料金の確認</p>
    <p class="mt-2 text-xl font-semibold text-zinc-800">予約はProX（予約システム）から</p>
    <p class="mt-3 text-sm leading-loose text-zinc-600">
      会員登録で複数プラン・複数日程の同時予約が可能です。
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href="https://www.489pro-x.com/ja/s/oiranomori/planlist/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full bg-[color:var(--forest-600)] px-8 py-3 text-sm text-white shadow-sm transition hover:bg-[color:var(--forest-700)]"
      >
        予約する ↗
      </a>
      <a
        href="/reservation-guide/"
        class="inline-flex items-center justify-center rounded-full border border-zinc-400 px-8 py-3 text-sm text-zinc-700 transition hover:border-zinc-600"
      >
        予約ガイドを見る
      </a>
    </div>
  </div>

</PageLayout>
